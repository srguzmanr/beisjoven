{
  "framework": "astro",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Content-Security-Policy-Report-Only",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://cdn.jsdelivr.net https://platform.twitter.com https://*.twimg.com https://www.instagram.com https://www.tiktok.com https://challenges.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https://yulkbjpotfmwqkzzfegg.supabase.co https://img.youtube.com https://www.google-analytics.com https://www.googletagmanager.com https://*.twimg.com https://*.cdninstagram.com https://*.tiktokcdn.com; media-src 'self' https://*.twimg.com; connect-src 'self' https://yulkbjpotfmwqkzzfegg.supabase.co wss://yulkbjpotfmwqkzzfegg.supabase.co https://www.google-analytics.com https://*.google-analytics.com https://*.analytics.google.com https://www.googletagmanager.com https://stats.g.doubleclick.net https://cdn.syndication.twimg.com; frame-src https://www.youtube-nocookie.com https://www.youtube.com https://platform.twitter.com https://syndication.twitter.com https://www.instagram.com https://www.tiktok.com https://challenges.cloudflare.com; frame-ancestors 'self'; base-uri 'self'; form-action 'self'"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/post/:slug*",
      "destination": "/articulo/:slug*",
      "permanent": true
    },
    {
      "source": "/noticias/:slug*",
      "destination": "/articulo/:slug*",
      "permanent": true
    },
    {
      "source": "/beisjoven/:slug*",
      "destination": "/articulo/:slug*",
      "permanent": true
    },
    {
      "source": "/profile/:path*",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/categoria/mexico",
      "destination": "/categoria/seleccion",
      "permanent": true
    },
    {
      "source": "/categoria/jovenes",
      "destination": "/categoria/juvenil",
      "permanent": true
    },
    {
      "source": "/articulo/2016/06/17/australia-es-el-primero",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/articulo/2016/06/15/nacional-premoyote",
      "destination": "/categoria/juvenil",
      "permanent": true
    },
    {
      "source": "/articulo/2016/12/10/informacion-de-bats-2018",
      "destination": "/categoria/juvenil",
      "permanent": true
    },
    {
      "source": "/articulo/prospectos-lmb-grandes-ligas-2026",
      "destination": "/categoria/mlb",
      "permanent": true
    },
    {
      "source": "/articulo/mexicanos-mlb-temporada-2026",
      "destination": "/categoria/mlb",
      "permanent": true
    },
    {
      "source": "/articulo/spring-training-2026-mexicanos",
      "destination": "/categoria/mlb",
      "permanent": true
    },
    {
      "source": "/articulo/softbol-femenil-mexico-seleccion-mundial",
      "destination": "/categoria/softbol",
      "permanent": true
    },
    {
      "source": "/video/resumen-puerto-rico-vs-mexico-rojo-serie-del-caribe-2026",
      "destination": "/categoria/seleccion",
      "permanent": true
    },
    {
      "source": "/video/mexico-rojo-campeon-de-la-serie-del-caribe-2026",
      "destination": "/categoria/seleccion",
      "permanent": true
    },
    {
      "source": "/video/serie-del-caribe-2026-mexico-rojo-vs-puerto-rico",
      "destination": "/categoria/seleccion",
      "permanent": true
    },
    {
      "source": "/video/diablos-rojos-derrotan-a-pericos-serie-del-rey-lmb-2025",
      "destination": "/categoria/liga-mexicana",
      "permanent": true
    },
    {
      "source": "/envivo",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/newsletter",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/videos",
      "destination": "/",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/admin/:path*",
      "destination": "/admin"
    }
  ]
}
