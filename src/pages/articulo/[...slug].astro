---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import CategoryPill from '@/components/CategoryPill.astro';
import ArticleCard from '@/components/ArticleCard.astro';
import ShareButtons from '@/components/ShareButtons.astro';
import MostReadWidget from '@/components/MostReadWidget.astro';
import SectionTitle from '@/components/SectionTitle.astro';
import TuHistoriaCTA from '@/components/TuHistoriaCTA.astro';
import ArticleMeta from '@/components/ArticleMeta.astro';
import AdSlot from '@/components/AdSlot.astro';
import {
  getArticuloBySlug,
  getRelatedArticulos,
  getMasLeidosByCategoria,
  getTagsByArticuloId,
} from '@/lib/supabase';
import { renderContent } from '@/lib/content';
import { ensureOgImage } from '@/lib/og-image-generator';
import { SITE_URL } from '@/lib/site';

const { slug } = Astro.params;
const articulo = await getArticuloBySlug(slug!);

if (!articulo) {
  return Astro.redirect('/404');
}

const supabaseUrl = 'https://yulkbjpotfmwqkzzfegg.supabase.co';
const supabaseAnonKey = import.meta.env.SUPABASE_ANON_KEY
  || 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inl1bGtianBvdGZtd3FrenpmZWdnIiwicm9sZSI6ImFub24iLCJpYXQiOjE3Njk2OTk3NTYsImV4cCI6MjA4NTI3NTc1Nn0.PK8mq4CeQkTdurdJ1EV_GOkrY2X4SCsst8O1NnoBWAU';

const [related, masLeidos, tags, ogImageUrl] = await Promise.all([
  getRelatedArticulos(articulo.id, articulo.categoria_id),
  getMasLeidosByCategoria(articulo.categoria.slug, 5, articulo.id),
  getTagsByArticuloId(articulo.id),
  ensureOgImage(articulo.imagen_url),
]);

const masLeidosScope = {
  type: 'article-context' as const,
  articleId: articulo.id,
  categorySlug: articulo.categoria.slug,
  categoryDisplayName: articulo.categoria.nombre,
};
const articleUrl = `${SITE_URL}/articulo/${articulo.slug}`;
const renderedBody = renderContent(articulo.contenido);

// ADS-STD-01 — Slot A: mid-article, anchored right after the 3rd top-level
// paragraph (placement standard: after the 3rd–4th paragraph). Articles with
// fewer than 4 paragraphs render uninterrupted — no mid-slot — so at least
// one paragraph always follows the ad.
function splitAfterParagraph(html: string, n: number): [string, string] {
  const parts = html.split('</p>');
  if (parts.length < n + 2) return [html, ''];
  const first = parts.slice(0, n).join('</p>') + '</p>';
  const second = parts.slice(n).join('</p>');
  return [first, second];
}
const [bodyFirst, bodySecond] = splitAfterParagraph(renderedBody, 3);

// Detect which embed scripts are needed at build time
const needsTwitterScript = renderedBody.includes('class="twitter-embed"')
  || renderedBody.includes('class="twitter-tweet"');
const needsInstagramScript = renderedBody.includes('class="instagram-media"');
const needsTikTokScript = renderedBody.includes('class="tiktok-embed"');
const needsGalleryLightbox = renderedBody.includes('data-gallery="true"');

// JSON-LD BreadcrumbList for this article
const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": `${SITE_URL}/` },
    {
      "@type": "ListItem",
      "position": 2,
      "name": articulo.categoria?.nombre || 'Noticias',
      "item": `${SITE_URL}/categoria/${articulo.categoria?.slug || ''}`,
    },
    { "@type": "ListItem", "position": 3, "name": articulo.titulo },
  ],
};

// JSON-LD for this article
const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "NewsArticle",
  "headline": articulo.titulo,
  "description": articulo.extracto || '',
  "image": articulo.imagen_url ? [articulo.imagen_url] : [],
  "datePublished": articulo.fecha || articulo.created_at,
  "dateModified": articulo.updated_at || articulo.fecha || articulo.created_at,
  "author": {
    "@type": "Person",
    "name": articulo.autor?.nombre || 'Redacción Beisjoven',
    "url": `${SITE_URL}/autor/${articulo.autor?.slug || 'redaccion'}`,
  },
  "publisher": {
    "@type": "Organization",
    "name": "Beisjoven",
    "logo": {
      "@type": "ImageObject",
      "url": `${SITE_URL}/brand/logo-lockup.png`,
    },
  },
  "mainEntityOfPage": { "@type": "WebPage", "@id": articleUrl },
  "url": articleUrl,
  "articleSection": articulo.categoria?.nombre || 'Noticias',
  "inLanguage": "es-MX",
};
---

<BaseLayout
  title={`${articulo.titulo} - Beisjoven`}
  description={articulo.extracto || ''}
  image={ogImageUrl ?? articulo.imagen_url}
  url={articleUrl}
  type="article"
  publishedTime={articulo.fecha || articulo.created_at}
  modifiedTime={articulo.updated_at || articulo.fecha}
  section={articulo.categoria?.nombre}
  author={articulo.autor?.nombre}
  jsonLd={[articleJsonLd, breadcrumbJsonLd]}
>
  <Breadcrumb items={[
    { text: 'Inicio', href: '/' },
    { text: articulo.categoria?.nombre || 'Noticias', href: `/categoria/${articulo.categoria?.slug || ''}` },
    { text: articulo.titulo },
  ]} />

  <article class="max-w-7xl mx-auto px-4 py-6">
    <!-- Article Header -->
    <header class="max-w-3xl mx-auto mb-6 lg:mx-0">
      {articulo.categoria && (
        <CategoryPill name={articulo.categoria.nombre} slug={articulo.categoria.slug} size="md" />
      )}
      <h1 class="text-2xl md:text-4xl font-extrabold text-navy mt-3 mb-4 leading-tight" style="letter-spacing: -0.02em;">
        {articulo.titulo}
      </h1>
      <ArticleMeta
        fecha={articulo.fecha}
        autorNombre={articulo.autor?.nombre}
        readMinutes={articulo.read_time_minutes}
        variant="article"
      />
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Article Body -->
      <div class="lg:col-span-2">
        <!-- Hero Image — full-width on mobile -->
        <figure class="mb-6 -mx-4 md:mx-0">
          <img
            src={articulo.imagen_url}
            alt={articulo.titulo}
            loading="eager"
            class="w-full md:rounded-lg"
          />
          {(articulo.pie_de_foto || articulo.foto_credito) && (
            <figcaption class="flex flex-wrap justify-between gap-x-3 gap-y-0.5 px-4 md:px-0 pt-1.5">
              {articulo.pie_de_foto && (
                <span class="text-sm text-gray-500 italic leading-snug">{articulo.pie_de_foto}</span>
              )}
              {articulo.foto_credito && (
                <span class="text-xs text-gray-400 italic leading-snug flex-shrink-0">{articulo.foto_credito}</span>
              )}
            </figcaption>
          )}
        </figure>

        <!-- Content -->
        {bodySecond ? (
          <>
            <div class="prose max-w-none" set:html={bodyFirst} />
            {/* HOUSE-ADS-01 — in-article, prose width.
                ADS-GOLIVE-PREP-01: slot id frozen as 'article-body' (ex slot-a). */}
            <div class="bj-adslot-inarticle">
              <AdSlot slotId="article-body" variant="prose" />
            </div>
            <div class="prose max-w-none" set:html={bodySecond} />
          </>
        ) : (
          <div class="prose max-w-none" set:html={renderedBody} />
        )}

        <!-- Tags -->
        {tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mt-6">
            {tags.map((tag) => (
              <a
                href={`/tag/${tag.slug}`}
                class="inline-block text-xs font-semibold px-3 py-1 rounded-full border border-navy text-navy hover:bg-navy hover:text-white transition-colors"
              >
                {tag.nombre}
              </a>
            ))}
          </div>
        )}

        <!-- Share -->
        <ShareButtons url={articleUrl} title={articulo.titulo} />

        <!-- Related Articles -->
        {related.length > 0 && (
          <section class="mt-10">
            <SectionTitle title="Artículos relacionados" />
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              {related.map((a) => (
                <ArticleCard article={a} />
              ))}
            </div>
          </section>
        )}

        <!-- Tu Historia CTA — ONSITE-TUHISTORIA-01: between Relacionados and the footer ad slot -->
        <TuHistoriaCTA placement="article-footer" />

        {/* HOUSE-ADS-01 — end-of-note. ADS-FOOTER-ACT-01: active — fetch,
            waterfall and tracking identical to article-body ("Pie de
            Artículo", CEDISMAN package).
            ADS-GOLIVE-PREP-01: slot id frozen as 'article-footer' (ex slot-c). */}
        <div class="bj-adslot-endnote">
          <AdSlot slotId="article-footer" variant="prose" />
        </div>
      </div>

      <!-- Sticky Sidebar -->
      <aside>
        <div class="sticky top-20 space-y-6">
          <MostReadWidget articles={masLeidos} scope={masLeidosScope} />
        </div>
      </aside>
    </div>
  </article>

  <!-- Embed scripts: only included when the article actually has that embed type -->
  {needsTwitterScript && (
    <script is:inline>
      window.twttr = (function(d, s, id) {
        var js, fjs = d.getElementsByTagName(s)[0],
          t = window.twttr || {};
        if (d.getElementById(id)) return t;
        js = d.createElement(s);
        js.id = id;
        js.src = "https://platform.twitter.com/widgets.js";
        fjs.parentNode.insertBefore(js, fjs);
        t._e = [];
        t.ready = function(f) { t._e.push(f); };
        return t;
      }(document, "script", "twitter-wjs"));

      twttr.ready(function(twttr) {
        // New format: div.twitter-embed[data-tweet-id]
        document.querySelectorAll('.twitter-embed[data-tweet-id]').forEach(function(el) {
          var id = el.getAttribute('data-tweet-id');
          if (id) {
            twttr.widgets.createTweet(id, el, {
              dnt: true,
              align: 'center'
            });
          }
        });
        // Legacy format: blockquote.twitter-tweet (auto-scanned by widgets.js)
      });
    </script>
  )}
  {needsInstagramScript && (
    <script async src="https://www.instagram.com/embed.js" is:inline></script>
  )}
  {needsTikTokScript && (
    <script async src="https://www.tiktok.com/embed.js" is:inline></script>
  )}

  {needsGalleryLightbox && (
    <script is:inline>
    (function() {
      var galleries = document.querySelectorAll('.gallery[data-gallery]');
      if (!galleries.length) return;

      var overlay, imgWrap, captionEl, counterEl, images, current;

      function createLightbox() {
        overlay = document.createElement('div');
        overlay.className = 'lightbox-overlay';
        overlay.innerHTML =
          '<button class="lightbox-close" aria-label="Cerrar">&times;</button>' +
          '<div class="lightbox-counter"></div>' +
          '<button class="lightbox-arrow lightbox-arrow--prev" aria-label="Anterior">&#8249;</button>' +
          '<button class="lightbox-arrow lightbox-arrow--next" aria-label="Siguiente">&#8250;</button>' +
          '<div class="lightbox-img-wrap"><img src="" alt="" /></div>' +
          '<div class="lightbox-caption"></div>';
        document.body.appendChild(overlay);

        imgWrap = overlay.querySelector('.lightbox-img-wrap img');
        captionEl = overlay.querySelector('.lightbox-caption');
        counterEl = overlay.querySelector('.lightbox-counter');

        overlay.querySelector('.lightbox-close').addEventListener('click', close);
        overlay.querySelector('.lightbox-arrow--prev').addEventListener('click', function() { navigate(-1); });
        overlay.querySelector('.lightbox-arrow--next').addEventListener('click', function() { navigate(1); });
        overlay.addEventListener('click', function(e) {
          if (e.target === overlay || e.target.classList.contains('lightbox-img-wrap')) close();
        });

        // Keyboard navigation
        document.addEventListener('keydown', function(e) {
          if (!overlay.classList.contains('is-visible')) return;
          if (e.key === 'Escape') close();
          if (e.key === 'ArrowLeft') navigate(-1);
          if (e.key === 'ArrowRight') navigate(1);
        });

        // Touch swipe (horizontal: navigate; vertical down: close)
        var touchStartX = 0, touchEndX = 0, touchStartY = 0, touchEndY = 0;
        overlay.addEventListener('touchstart', function(e) {
          touchStartX = e.changedTouches[0].screenX;
          touchStartY = e.changedTouches[0].screenY;
        }, { passive: true });
        overlay.addEventListener('touchend', function(e) {
          touchEndX = e.changedTouches[0].screenX;
          touchEndY = e.changedTouches[0].screenY;
          var diffX = touchStartX - touchEndX;
          var diffY = touchStartY - touchEndY;
          if (Math.abs(diffY) > Math.abs(diffX)) {
            // Vertical swipe dominates — swipe down closes
            if (diffY < -80) close();
          } else if (Math.abs(diffX) > 50) {
            navigate(diffX > 0 ? 1 : -1);
          }
        }, { passive: true });
      }

      function open(galleryImages, index) {
        if (!overlay) createLightbox();
        images = galleryImages;
        current = index;
        show();
        overlay.classList.add('is-visible');
        document.body.style.overflow = 'hidden';
      }

      function close() {
        overlay.classList.remove('is-visible');
        document.body.style.overflow = '';
      }

      function navigate(dir) {
        current = (current + dir + images.length) % images.length;
        show();
      }

      function show() {
        var img = images[current];
        imgWrap.src = img.src;
        imgWrap.alt = img.caption || '';
        var captionHtml = '';
        if (img.caption) captionHtml += img.caption;
        if (img.credit) captionHtml += ' <span>' + img.credit + '</span>';
        captionEl.innerHTML = captionHtml;
        captionEl.style.display = captionHtml ? '' : 'none';
        counterEl.textContent = (current + 1) + '/' + images.length;
      }

      // Bind click events on gallery images
      galleries.forEach(function(gallery) {
        var figures = gallery.querySelectorAll('figure');
        var galleryImages = Array.from(figures).map(function(fig) {
          var imgEl = fig.querySelector('img');
          var captionEl = fig.querySelector('figcaption');
          var creditSpan = captionEl ? captionEl.querySelector('span') : null;
          var captionText = captionEl ? (captionEl.childNodes[0]?.textContent || '').trim() : '';
          return {
            src: imgEl ? imgEl.src : '',
            caption: captionText,
            credit: creditSpan ? creditSpan.textContent.trim() : ''
          };
        });

        figures.forEach(function(fig, i) {
          fig.style.cursor = 'pointer';
          fig.addEventListener('click', function() { open(galleryImages, i); });
        });
      });
    })();
    </script>
  )}

  <!-- Increment views + GA4 scroll-depth events -->
  <script define:vars={{ articuloId: articulo.id, supabaseUrl, anonKey: supabaseAnonKey }}>
    fetch(`${supabaseUrl}/rest/v1/rpc/increment_vistas`, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'apikey': anonKey,
        'Authorization': `Bearer ${anonKey}`,
      },
      body: JSON.stringify({ articulo_id: articuloId }),
    }).catch(err => console.error('[increment_vistas] Failed:', err));

    (function() {
      let fired50 = false;
      let firedComplete = false;
      function onScroll() {
        if (typeof gtag !== 'function') return;
        const scrollHeight = document.documentElement.scrollHeight;
        if (scrollHeight <= window.innerHeight) return;
        const progress = (window.scrollY + window.innerHeight) / scrollHeight;
        if (!fired50 && progress >= 0.5) {
          fired50 = true;
          gtag('event', 'article_read_50', { articulo_id: articuloId });
        }
        if (!firedComplete && progress >= 0.95) {
          firedComplete = true;
          gtag('event', 'article_read_complete', { articulo_id: articuloId });
          window.removeEventListener('scroll', onScroll);
        }
      }
      window.addEventListener('scroll', onScroll, { passive: true });
    })();
  </script>

  <style>
    /* HOUSE-ADS-01 — in-article (Slot A) and end-of-note (Slot C) spacing. */
    .bj-adslot-inarticle {
      margin: 32px 0;
    }

    .bj-adslot-endnote {
      margin-top: 32px;
      margin-bottom: 48px;
    }
  </style>
</BaseLayout>
