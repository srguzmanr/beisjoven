---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import ArticleCard from '@/components/ArticleCard.astro';
import MostReadWidget from '@/components/MostReadWidget.astro';
import { getArticulosWbc2026Paginados, getMasLeidos } from '@/lib/supabase';
import { buildPage, parsePageParam } from '@/lib/pagination';

const PAGE_SIZE = 20;

const currentPage = parsePageParam(Astro.params.page);
if (currentPage === null) return Astro.redirect('/404');

const [{ articulos, total }, masLeidos] = await Promise.all([
  getArticulosWbc2026Paginados(PAGE_SIZE, (currentPage - 1) * PAGE_SIZE),
  getMasLeidos(5),
]);

const page = buildPage(articulos, total, currentPage, PAGE_SIZE, `/wbc-2026`);
if (currentPage > page.lastPage) return Astro.redirect('/404');

const title = 'World Baseball Classic 2026 - Beisjoven';
const description = 'Cobertura completa del World Baseball Classic 2026. Noticias, análisis, roster de México y más.';
---

<BaseLayout
  title={title}
  description={description}
  url="https://beisjoven.com/wbc-2026"
>
  <Breadcrumb items={[
    { text: 'Inicio', href: '/' },
    { text: 'World Baseball Classic 2026' },
  ]} />

  <div class="max-w-7xl mx-auto px-4 py-6">
    <header class="mb-6">
      <h1 class="text-2xl md:text-3xl font-bold text-navy uppercase tracking-wide">World Baseball Classic 2026</h1>
      <p class="text-gris-text mt-1">{description}</p>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Articles Grid -->
      <div class="lg:col-span-2">
        {page.data.length > 0 ? (
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {page.data.map((a, i) => (
              <ArticleCard article={a} eager={i < 4} />
            ))}
          </div>
        ) : (
          <p class="text-gris-text py-8 text-center">No hay artículos del WBC 2026 todavía.</p>
        )}

        <!-- Pagination -->
        {page.lastPage > 1 && (
          <nav class="flex justify-center gap-2 mt-8" aria-label="Paginación">
            {page.url.prev && (
              <a href={page.url.prev} class="px-4 py-2 text-sm font-medium rounded-lg bg-gris-bg text-navy hover:bg-gray-200 transition-colors">
                &larr; Anterior
              </a>
            )}
            <span class="px-4 py-2 text-sm text-gris-muted">
              Página {page.currentPage} de {page.lastPage}
            </span>
            {page.url.next && (
              <a href={page.url.next} class="px-4 py-2 text-sm font-medium rounded-lg bg-gris-bg text-navy hover:bg-gray-200 transition-colors">
                Siguiente &rarr;
              </a>
            )}
          </nav>
        )}
      </div>

      <!-- Sidebar -->
      <aside class="space-y-6">
        <MostReadWidget articles={masLeidos} />
      </aside>
    </div>
  </div>
</BaseLayout>
