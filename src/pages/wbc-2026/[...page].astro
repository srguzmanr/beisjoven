---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import ArticleCard from '@/components/ArticleCard.astro';
import SectionTitle from '@/components/SectionTitle.astro';
import MostReadWidget from '@/components/MostReadWidget.astro';
import { getArticulosWbc2026Paginados, getMasLeidos } from '@/lib/supabase';

export async function getStaticPaths() {
  // Single path — pagination handled via query params like the category pages
  return [{ params: { page: undefined } }];
}

const page = Number(Astro.url.searchParams.get('page')) || 1;
const perPage = 20;
const offset = (page - 1) * perPage;

const [{ articulos, total }, masLeidos] = await Promise.all([
  getArticulosWbc2026Paginados(perPage, offset),
  getMasLeidos(5),
]);

const totalPages = Math.ceil(total / perPage);

const title = 'World Baseball Classic 2026 - Beisjoven';
const description = 'Cobertura completa del World Baseball Classic 2026. Noticias, análisis, roster de México y más.';
---

<BaseLayout
  title={title}
  description={description}
  url="https://beisjoven.com/wbc-2026"
>
  <Breadcrumb items={[
    { text: 'Inicio', href: '/' },
    { text: 'World Baseball Classic 2026' },
  ]} />

  <div class="max-w-7xl mx-auto px-4 py-6">
    <header class="mb-6">
      <h1 class="text-2xl md:text-3xl font-bold text-navy uppercase tracking-wide">World Baseball Classic 2026</h1>
      <p class="text-gris-text mt-1">{description}</p>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Articles Grid -->
      <div class="lg:col-span-2">
        {articulos.length > 0 ? (
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {articulos.map((a, i) => (
              <ArticleCard article={a} eager={i < 4} />
            ))}
          </div>
        ) : (
          <p class="text-gris-text py-8 text-center">No hay artículos del WBC 2026 todavía.</p>
        )}

        <!-- Pagination -->
        {totalPages > 1 && (
          <nav class="flex justify-center gap-2 mt-8" aria-label="Paginación">
            {page > 1 && (
              <a href={`/wbc-2026?page=${page - 1}`} class="px-4 py-2 text-sm font-medium rounded-lg bg-gris-bg text-navy hover:bg-gray-200 transition-colors">
                &larr; Anterior
              </a>
            )}
            <span class="px-4 py-2 text-sm text-gris-muted">
              Página {page} de {totalPages}
            </span>
            {page < totalPages && (
              <a href={`/wbc-2026?page=${page + 1}`} class="px-4 py-2 text-sm font-medium rounded-lg bg-gris-bg text-navy hover:bg-gray-200 transition-colors">
                Siguiente &rarr;
              </a>
            )}
          </nav>
        )}
      </div>

      <!-- Sidebar -->
      <aside class="space-y-6">
        <MostReadWidget articles={masLeidos} />
      </aside>
    </div>
  </div>
</BaseLayout>
