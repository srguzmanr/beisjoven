---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import ArticleCard from '@/components/ArticleCard.astro';
import MostReadWidget from '@/components/MostReadWidget.astro';
import BackToTop from '@/components/BackToTop.astro';
import {
  getCategoriaBySlug,
  getArticulosByCategoriaPaginados,
  getMasLeidosByCategoria,
} from '@/lib/supabase';
import { buildPage, parsePageParam } from '@/lib/pagination';
import { getCategoryAccent, getCategoryLabel } from '@/lib/categoryAccents.js';

const PAGE_SIZE = 20;
const { slug } = Astro.params;

const currentPage = parsePageParam(Astro.params.page);
if (currentPage === null) return Astro.redirect('/404');

const categoria = await getCategoriaBySlug(slug!);
if (!categoria) return Astro.redirect('/404');

const [{ articulos, total }, masLeidos] = await Promise.all([
  getArticulosByCategoriaPaginados(slug!, PAGE_SIZE, (currentPage - 1) * PAGE_SIZE),
  getMasLeidosByCategoria(slug!, 5),
]);

const page = buildPage(articulos, total, currentPage, PAGE_SIZE, `/categoria/${slug}`);
if (currentPage > page.lastPage) return Astro.redirect('/404');

const masLeidosScope = {
  type: 'category' as const,
  slug: categoria.slug,
  displayName: categoria.nombre,
};

const categoryDescriptions: Record<string, string> = {
  'mlb': 'Mexicanos en Grandes Ligas, estadísticas, trades y más del béisbol de las mayores.',
  'liga-mexicana': 'Cobertura completa de la Liga Mexicana de Béisbol, Liga Mexicana del Pacífico y ligas profesionales.',
  'seleccion': 'Selección Mexicana de béisbol y softbol. Clásico Mundial, Premier12, WBSC y más.',
  'softbol': 'Softbol mexicano. Liga Nacional, selección femenil, torneos internacionales.',
  'juvenil': 'Béisbol y softbol juvenil. Prospectos, ligas menores, desarrollo deportivo.',
  'opinion': 'Columnas de opinión y análisis sobre el béisbol y softbol mexicano.',
};

const description = categoryDescriptions[slug!] || `Noticias y artículos de ${categoria.nombre} en Beisjoven.`;
const categoryUrl = `https://beisjoven.com/categoria/${slug}`;
const accent = getCategoryAccent(slug!);
const kickerLabel = getCategoryLabel(slug!);

const hasMore = !!page.url.next;
---

<BaseLayout
  title={`${categoria.nombre}${page.currentPage > 1 ? ` - Página ${page.currentPage}` : ''} - Beisjoven`}
  description={description}
  url={categoryUrl}
>
  <Breadcrumb items={[
    { text: 'Inicio', href: '/' },
    { text: categoria.nombre },
  ]} />

  <!-- Category header band -->
  <div class="archive-header" style={`--accent:${accent}`}>
    <div class="bj-container">
      <span class="bj-kicker mb-3" style={`--kicker:${accent}`}>{kickerLabel}</span>
      <h1 class="font-heading text-h2 text-navy" style="font-weight:800;">{categoria.nombre}</h1>
      <p class="archive-header__desc">{description}</p>
    </div>
  </div>

  <div class="bj-container py-8">
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_300px] gap-10 xl:gap-14 items-start">

      <!-- Articles feed -->
      <div>
        {page.data.length > 0 ? (
          <div
            id="articles-grid"
            class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-2 xl:grid-cols-3 gap-5"
            data-category-slug={slug}
            data-category-name={categoria.nombre}
            data-page-size={PAGE_SIZE}
            data-next-offset={page.currentPage * PAGE_SIZE}
            data-total-pages={page.lastPage}
            data-current-page={page.currentPage}
          >
            {page.data.map((article, idx) => (
              <ArticleCard article={article} eager={idx < 4} />
            ))}
          </div>
        ) : (
          <p class="text-[color:var(--ink-3)] py-12 text-center font-body">No hay artículos en esta categoría todavía.</p>
        )}

        <!-- Load More / Pagination -->
        <div id="load-more-container" class="mt-10 flex flex-col items-center gap-3">
          {hasMore ? (
            <Fragment>
              <button
                id="load-more-btn"
                type="button"
                class="archive-load-more-btn"
              >
                Cargar más artículos
              </button>
              <a
                id="next-page-link"
                href={page.url.next}
                class="archive-page-hint"
              >
                Página {page.currentPage} de {page.lastPage} &middot; Ver siguiente página
              </a>
            </Fragment>
          ) : page.lastPage > 1 ? (
            <p class="text-sm text-[color:var(--ink-3)] text-center py-2 font-body">
              Has visto todos los artículos de {categoria.nombre}
            </p>
          ) : null}
        </div>
      </div>

      <!-- Sidebar -->
      <aside class="archive-sidebar">
        <div class="sticky top-24">
          <MostReadWidget articles={masLeidos} scope={masLeidosScope} />
        </div>
      </aside>

    </div>
  </div>

  {hasMore && (
    <Fragment>
      <script is:inline src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
      <script is:inline src="/js/category-load-more.js"></script>
    </Fragment>
  )}

  <BackToTop />

  <style>
    .archive-header {
      padding-top: 2rem;
      padding-bottom: 2rem;
      border-bottom: 1px solid var(--rule);
    }

    .archive-header__desc {
      font-family: var(--font-body);
      font-size: 1rem;
      line-height: 1.65;
      color: var(--ink-2);
      margin-top: 0.5rem;
      max-width: 56ch;
    }

    .archive-load-more-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 48px;
      padding: 0 2rem;
      border-radius: var(--radius-pill);
      background: var(--navy);
      color: #fff;
      font-family: var(--font-body);
      font-size: 0.9375rem;
      font-weight: 600;
      letter-spacing: 0.01em;
      border: none;
      cursor: pointer;
      transition: background 0.18s, box-shadow 0.18s;
      box-shadow: var(--shadow-sm);
      width: 100%;
      max-width: 20rem;
    }
    .archive-load-more-btn:hover {
      background: var(--navy-700);
      box-shadow: var(--shadow-md);
    }
    .archive-load-more-btn:focus-visible {
      outline: 2px solid var(--gold);
      outline-offset: 2px;
    }

    .archive-page-hint {
      font-family: var(--font-body);
      font-size: 0.8125rem;
      color: var(--ink-3);
      text-decoration: none;
      transition: color 0.15s;
    }
    .archive-page-hint:hover {
      color: var(--navy);
      text-decoration: underline;
    }

    /* Sidebar: only show on lg+ */
    .archive-sidebar {
      display: none;
    }
    @media (min-width: 1024px) {
      .archive-sidebar {
        display: block;
      }
    }
  </style>
</BaseLayout>
