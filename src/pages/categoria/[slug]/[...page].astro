---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import ArticleCard from '@/components/ArticleCard.astro';
import MostReadWidget from '@/components/MostReadWidget.astro';
import {
  getCategorias,
  getCategoriaBySlug,
  getAllArticulosByCategoria,
  getMasLeidos,
} from '@/lib/supabase';

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const categorias = await getCategorias();
  const allData = await Promise.all(
    categorias.map(async (cat) => {
      const articulos = await getAllArticulosByCategoria(cat.slug);
      return { cat, articulos };
    })
  );

  return allData.flatMap(({ cat, articulos }) =>
    paginate(articulos, {
      params: { slug: cat.slug },
      pageSize: 20,
    })
  );
};

const { slug } = Astro.params;
const { page } = Astro.props;
const [categoria, masLeidos] = await Promise.all([
  getCategoriaBySlug(slug!),
  getMasLeidos(5),
]);

if (!categoria) {
  return Astro.redirect('/404');
}

const categoryDescriptions: Record<string, string> = {
  'mlb': 'Mexicanos en Grandes Ligas, estadísticas, trades y más del béisbol de las mayores.',
  'liga-mexicana': 'Cobertura completa de la Liga Mexicana de Béisbol, Liga Mexicana del Pacífico y ligas profesionales.',
  'seleccion': 'Selección Mexicana de béisbol y softbol. Clásico Mundial, Premier12, WBSC y más.',
  'softbol': 'Softbol mexicano. Liga Nacional, selección femenil, torneos internacionales.',
  'juvenil': 'Béisbol y softbol juvenil. Prospectos, ligas menores, desarrollo deportivo.',
  'opinion': 'Columnas de opinión y análisis sobre el béisbol y softbol mexicano.',
};

const description = categoryDescriptions[slug!] || `Noticias y artículos de ${categoria.nombre} en Beisjoven.`;
const categoryUrl = `https://beisjoven.com/categoria/${slug}`;
---

<BaseLayout
  title={`${categoria.nombre}${page.currentPage > 1 ? ` - Página ${page.currentPage}` : ''} - Beisjoven`}
  description={description}
  url={categoryUrl}
>
  <Breadcrumb items={[
    { text: 'Inicio', href: '/' },
    { text: categoria.nombre },
  ]} />

  <div class="max-w-7xl mx-auto px-4 py-6">
    <header class="mb-6">
      <h1 class="text-2xl md:text-3xl font-bold text-navy uppercase tracking-wide">{categoria.nombre}</h1>
      <p class="text-gris-text mt-1">{description}</p>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Articles Grid -->
      <div class="lg:col-span-2">
        {page.data.length > 0 ? (
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {page.data.map((a, i) => (
              <ArticleCard article={a} eager={i < 4} />
            ))}
          </div>
        ) : (
          <p class="text-gris-text py-8 text-center">No hay artículos en esta categoría todavía.</p>
        )}

        <!-- Pagination -->
        {page.lastPage > 1 && (
          <nav class="flex justify-center gap-2 mt-8" aria-label="Paginación">
            {page.url.prev && (
              <a href={page.url.prev} class="px-4 py-2 text-sm font-medium rounded-lg bg-gris-bg text-navy hover:bg-gray-200 transition-colors">
                &larr; Anterior
              </a>
            )}
            <span class="px-4 py-2 text-sm text-gris-muted">
              Página {page.currentPage} de {page.lastPage}
            </span>
            {page.url.next && (
              <a href={page.url.next} class="px-4 py-2 text-sm font-medium rounded-lg bg-gris-bg text-navy hover:bg-gray-200 transition-colors">
                Siguiente &rarr;
              </a>
            )}
          </nav>
        )}
      </div>

      <!-- Sidebar -->
      <aside class="space-y-6">
        <MostReadWidget articles={masLeidos} />
      </aside>
    </div>
  </div>
</BaseLayout>
