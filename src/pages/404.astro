---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Página no encontrada - Beisjoven" noIndex={true}>
  <div class="max-w-2xl mx-auto px-4 py-20 text-center">
    <h1 class="text-6xl font-black text-navy/20 mb-4">404</h1>
    <h2 class="text-2xl font-bold text-navy mb-4">Página no encontrada</h2>
    <p class="text-gris-text mb-8">
      La página que buscas no existe o fue movida. Prueba buscando en nuestro sitio.
    </p>
    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      <a href="/" class="px-6 py-2.5 bg-navy text-white font-medium rounded-lg hover:bg-navy-dark transition-colors">
        Ir al inicio
      </a>
      <a href="/buscar" class="px-6 py-2.5 bg-gris-bg text-navy font-medium rounded-lg hover:bg-gray-200 transition-colors">
        Buscar artículos
      </a>
    </div>
  </div>
</BaseLayout>
