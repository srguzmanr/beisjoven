---
/**
 * Admin panel — served as a standalone page.
 * During migration, the existing vanilla JS admin is embedded directly.
 * The admin JS/CSS files remain in the repo root and are served from /public in the Astro build.
 *
 * Post-migration (Phase 2), this can be rebuilt as a proper Astro island with React/Preact.
 */
export const prerender = true;
---

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="robots" content="noindex, nofollow">
    <title>Admin - Beisjoven</title>

    <!-- Theme init — set [data-theme] before paint to avoid FOUC -->
    <script is:inline>
        (function () {
            try {
                var path = window.location.pathname || '';
                // Login stays light regardless of saved preference.
                if (path === '/login' || path.indexOf('/login') === 0) {
                    document.documentElement.setAttribute('data-theme', 'light');
                    return;
                }
                var saved = localStorage.getItem('bj-admin-theme');
                var prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
                var theme = saved || (prefersDark ? 'dark' : 'light');
                document.documentElement.setAttribute('data-theme', theme);
            } catch (e) {
                document.documentElement.setAttribute('data-theme', 'light');
            }
        })();
    </script>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <!-- Admin Styles -->
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="/css/admin.css">
    <link rel="stylesheet" href="/css/admin-mobile-fix.css">
</head>
<body>
    <main id="main-content">
        <div style="text-align:center;padding:4rem;">
            <p>Cargando admin...</p>
        </div>
    </main>

    <!-- Supabase -->
    <script is:inline src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>

    <!-- Admin Scripts -->
    <script is:inline src="/js/supabase.js"></script>
    <script is:inline src="/data/database.js"></script>
    <script is:inline src="/js/api.js"></script>
    <script is:inline src="/js/components.js"></script>
    <script is:inline src="/js/pages.js"></script>
    <script is:inline src="/js/router.js"></script>
    <script is:inline src="/js/auth.js"></script>
    <script is:inline src="/js/media-library-core.js"></script>
    <script is:inline src="/js/tiptap-editor.js"></script>
    <script is:inline src="/js/article-preview.js"></script>
    <script is:inline src="/js/tag-picker.js"></script>
    <script is:inline src="/js/admin.js"></script>
    <!--
      Publishing/editing writes to Supabase and goes live via SSR + ISR
      (~60s, see astro.config.mjs). No Vercel deploy hook / rebuild is
      triggered from the client — do not re-introduce one here.
    -->

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Register admin routes only
            Router.register('/login', AdminPages.login);
            Router.register('/admin', AdminPages.dashboard);
            Router.register('/admin/articulos', AdminPages.articles);
            Router.register('/admin/nuevo', AdminPages.editor);
            Router.register('/admin/editar/:id', AdminPages.editor);
            Router.register('/admin/medios', AdminPages.medios);
            Router.register('/admin/historias', ctx => AdminPages.historias(ctx));
            Router.register('/admin/videos', AdminPages.videosList);
            Router.register('/admin/videos/nuevo', AdminPages.videoEditor);
            Router.register('/admin/videos/editar/:id', AdminPages.videoEditor);
            Router.register('/admin/usuarios', AdminPages.usuarios);
            Router.register('/admin/quick-hits', AdminPages.quickHits);

            Auth.init().then(() => {
                // After each route change: cleanup editor artifacts + inject bottom tabs
                var origHandleRoute = Router.handleRoute.bind(Router);
                Router.handleRoute = function(fullPath) {
                    // Stop autosave timer + beforeunload when leaving any page
                    Autosave.stop();
                    // Remove editor sticky bar if lingering from editor page
                    var stickyBar = document.getElementById('admin-sticky-bar');
                    if (stickyBar) stickyBar.remove();

                    // Re-apply saved admin theme when leaving /login
                    try {
                        var path = (fullPath || '').split('?')[0];
                        if (path !== '/login' && path.indexOf('/login') !== 0) {
                            var saved = localStorage.getItem('bj-admin-theme');
                            var prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
                            var theme = saved || (prefersDark ? 'dark' : 'light');
                            document.documentElement.setAttribute('data-theme', theme);
                        }
                    } catch (e) {}

                    origHandleRoute(fullPath);
                    // Defer so the DOM has rendered
                    setTimeout(function() {
                        AdminComponents.injectBottomTabs();
                        if (AdminComponents.updateHistoriasBadge) AdminComponents.updateHistoriasBadge();
                    }, 50);
                };
                Router.init();
            });
        });
    </script>
</body>
</html>
