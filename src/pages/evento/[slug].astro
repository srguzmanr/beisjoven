---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import CategoryPill from '@/components/CategoryPill.astro';
import ArticleCard from '@/components/ArticleCard.astro';
import {
  getAllEventoSlugs,
  getEventoBySlug,
  getArticulosByEvento,
} from '@/lib/supabase';
import { formatDate } from '@/lib/content';

export async function getStaticPaths() {
  const slugs = await getAllEventoSlugs();
  return slugs.map((slug: string) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const evento = await getEventoBySlug(slug!);

if (!evento) {
  return Astro.redirect('/404');
}

const articulos = await getArticulosByEvento(evento.id);
const eventUrl = `https://beisjoven.com/evento/${evento.slug}`;

const fechaInicio = formatDate(evento.fecha_inicio);
const fechaFin = evento.fecha_fin ? formatDate(evento.fecha_fin) : null;
const fechaDisplay = fechaFin ? `${fechaInicio} – ${fechaFin}` : fechaInicio;
---

<BaseLayout
  title={`${evento.nombre} - Beisjoven`}
  description={evento.descripcion || `Cobertura especial: ${evento.nombre}`}
  image={evento.imagen_url}
  url={eventUrl}
>
  <Breadcrumb items={[
    { text: 'Inicio', href: '/' },
    { text: evento.nombre },
  ]} />

  <!-- Hero -->
  <header class="relative overflow-hidden">
    {evento.imagen_url ? (
      <div class="absolute inset-0">
        <img
          src={evento.imagen_url}
          alt={evento.nombre}
          class="w-full h-full object-cover"
          loading="eager"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-navy via-navy/70 to-navy/40"></div>
      </div>
    ) : (
      <div class="absolute inset-0 bg-navy"></div>
    )}
    <div class="relative max-w-7xl mx-auto px-4 py-12 md:py-20">
      <div class="max-w-3xl">
        {evento.categoria && (
          <CategoryPill name={evento.categoria.nombre} slug={evento.categoria.slug} size="md" />
        )}
        <h1 class="text-3xl md:text-5xl font-extrabold text-white mt-3 mb-4 leading-tight" style="letter-spacing: -0.02em;">
          {evento.nombre}
        </h1>
        {evento.descripcion && (
          <p class="text-white/80 text-lg mb-6 leading-relaxed max-w-2xl">{evento.descripcion}</p>
        )}
        <div class="flex flex-wrap gap-4 text-sm text-white/70">
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            {fechaDisplay}
          </span>
          {evento.sede && (
            <span class="flex items-center gap-1.5">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              {evento.sede}{evento.ciudad ? `, ${evento.ciudad}` : ''}
            </span>
          )}
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
            {articulos.length} artículo{articulos.length !== 1 ? 's' : ''}
          </span>
        </div>
      </div>
    </div>
  </header>

  <!-- Articles Grid -->
  <div class="max-w-7xl mx-auto px-4 py-8">
    {articulos.length > 0 ? (
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <div class="lg:col-span-2">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            {articulos.map((a, i) => (
              <ArticleCard article={a} eager={i < 4} />
            ))}
          </div>
        </div>

        <!-- Sidebar: Event Info -->
        <aside>
          <div class="sticky top-20 space-y-6">
            <div class="bg-gris-bg rounded-lg p-5">
              <h3 class="text-sm font-bold uppercase tracking-wider text-navy mb-4 pb-2 border-b border-gris-border">
                Info del evento
              </h3>
              <dl class="space-y-3 text-sm">
                <div>
                  <dt class="font-semibold text-navy">Fechas</dt>
                  <dd class="text-gris-text">{fechaDisplay}</dd>
                </div>
                {evento.sede && (
                  <div>
                    <dt class="font-semibold text-navy">Sede</dt>
                    <dd class="text-gris-text">{evento.sede}{evento.ciudad ? `, ${evento.ciudad}` : ''}</dd>
                  </div>
                )}
                {evento.categoria && (
                  <div>
                    <dt class="font-semibold text-navy">Categoría</dt>
                    <dd class="mt-1">
                      <CategoryPill name={evento.categoria.nombre} slug={evento.categoria.slug} />
                    </dd>
                  </div>
                )}
              </dl>
            </div>
          </div>
        </aside>
      </div>
    ) : (
      <div class="text-center py-16 text-gris-muted">
        <p class="text-lg">Aún no hay artículos para este evento.</p>
        <p class="text-sm mt-2">La cobertura comenzará pronto.</p>
      </div>
    )}
  </div>
</BaseLayout>
