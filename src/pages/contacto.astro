---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
---

<BaseLayout
  title="Contacto - Beisjoven"
  description="Contáctanos para colaboraciones, notas de prensa, correcciones o cualquier consulta sobre béisbol y softbol mexicano."
>
  <Breadcrumb items={[
    { text: 'Inicio', href: '/' },
    { text: 'Contacto' },
  ]} />

  <div class="max-w-2xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold text-navy mb-4">Contacto</h1>
    <p class="text-gris-text mb-8">
      ¿Tienes una nota de prensa, quieres colaborar con Beisjoven, o necesitas reportar una corrección? Escríbenos.
    </p>

    <div class="bg-gris-bg rounded-lg p-6 space-y-4">
      <div>
        <h3 class="font-semibold text-navy">Email</h3>
        <a href="mailto:contacto@beisjoven.com" class="text-steel-blue hover:underline">contacto@beisjoven.com</a>
      </div>
      <div>
        <h3 class="font-semibold text-navy">Redes sociales</h3>
        <div class="flex gap-4 mt-2">
          <a href="https://facebook.com/beisjoven" target="_blank" rel="noopener" class="text-steel-blue hover:text-navy transition-colors">Facebook</a>
          <a href="https://instagram.com/beisjoven" target="_blank" rel="noopener" class="text-steel-blue hover:text-navy transition-colors">Instagram</a>
          <a href="https://x.com/beisjoven" target="_blank" rel="noopener" class="text-steel-blue hover:text-navy transition-colors">X (Twitter)</a>
        </div>
      </div>
    </div>

    <p class="contacto-aviso">
      <strong>Aviso de Privacidad Simplificado.</strong> Beisjoven (operado por Noboru LLC, EE.&nbsp;UU.)
      recaba su nombre, correo electrónico y el contenido del mensaje únicamente para responder a su
      consulta. No utilizamos estos datos para finalidades distintas sin su consentimiento. Consulte el
      Aviso Integral en <a href="/privacidad">beisjoven.com/privacidad</a>.
    </p>
  </div>

  <style>
    .contacto-aviso {
      margin-top: 1.5rem;
      font-size: 12px;
      line-height: 1.55;
      color: #6B7280;
    }
    .contacto-aviso a {
      color: inherit;
      text-decoration: underline;
    }
    .contacto-aviso a:hover {
      color: #1B2A4A;
    }
  </style>
</BaseLayout>
