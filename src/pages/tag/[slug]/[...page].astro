---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import ArticleCard from '@/components/ArticleCard.astro';
import MostReadWidget from '@/components/MostReadWidget.astro';
import {
  getTags,
  getTagBySlug,
  getAllArticulosByTag,
  getMasLeidos,
} from '@/lib/supabase';

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const tags = await getTags();
  const allData = await Promise.all(
    tags.map(async (tag) => {
      const articulos = await getAllArticulosByTag(tag.slug);
      return { tag, articulos };
    })
  );

  return allData.flatMap(({ tag, articulos }) =>
    paginate(articulos, {
      params: { slug: tag.slug },
      pageSize: 20,
    })
  );
};

const { slug } = Astro.params;
const { page } = Astro.props;
const [tag, masLeidos] = await Promise.all([
  getTagBySlug(slug!),
  getMasLeidos(5),
]);

if (!tag) {
  return Astro.redirect('/404');
}

const description = `Artículos etiquetados con "${tag.nombre}" en Beisjoven. Béisbol y softbol mexicano.`;
const tagUrl = `https://beisjoven.com/tag/${slug}`;
---

<BaseLayout
  title={`Tag: ${tag.nombre}${page.currentPage > 1 ? ` - Página ${page.currentPage}` : ''} — Beisjoven`}
  description={description}
  url={tagUrl}
>
  <Breadcrumb items={[
    { text: 'Inicio', href: '/' },
    { text: `Tag: ${tag.nombre}` },
  ]} />

  <div class="max-w-7xl mx-auto px-4 py-6">
    <header class="mb-6">
      <h1 class="text-2xl md:text-3xl font-bold text-navy uppercase tracking-wide">{tag.nombre}</h1>
      <p class="text-gris-text mt-1">{description}</p>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Articles Grid -->
      <div class="lg:col-span-2">
        {page.data.length > 0 ? (
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {page.data.map((a, i) => (
              <ArticleCard article={a} eager={i < 4} />
            ))}
          </div>
        ) : (
          <p class="text-gris-text py-8 text-center">No hay artículos con este tag todavía.</p>
        )}

        <!-- Pagination -->
        {page.lastPage > 1 && (
          <nav class="flex justify-center gap-2 mt-8" aria-label="Paginación">
            {page.url.prev && (
              <a href={page.url.prev} class="px-4 py-2 text-sm font-medium rounded-lg bg-gris-bg text-navy hover:bg-gray-200 transition-colors">
                &larr; Anterior
              </a>
            )}
            <span class="px-4 py-2 text-sm text-gris-muted">
              Página {page.currentPage} de {page.lastPage}
            </span>
            {page.url.next && (
              <a href={page.url.next} class="px-4 py-2 text-sm font-medium rounded-lg bg-gris-bg text-navy hover:bg-gray-200 transition-colors">
                Siguiente &rarr;
              </a>
            )}
          </nav>
        )}
      </div>

      <!-- Sidebar -->
      <aside class="space-y-6">
        <MostReadWidget articles={masLeidos} />
      </aside>
    </div>
  </div>
</BaseLayout>
