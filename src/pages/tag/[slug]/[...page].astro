---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import ArticleCard from '@/components/ArticleCard.astro';
import MostReadWidget from '@/components/MostReadWidget.astro';
import {
  getTagBySlug,
  getArticulosByTagPaginados,
  getMasLeidos,
} from '@/lib/supabase';
import { buildPage, parsePageParam } from '@/lib/pagination';

const PAGE_SIZE = 20;
const { slug } = Astro.params;

const currentPage = parsePageParam(Astro.params.page);
if (currentPage === null) return Astro.redirect('/404');

const tag = await getTagBySlug(slug!);
if (!tag) return Astro.redirect('/404');

const [{ articulos, total }, masLeidos] = await Promise.all([
  getArticulosByTagPaginados(slug!, PAGE_SIZE, (currentPage - 1) * PAGE_SIZE),
  getMasLeidos(5),
]);

const page = buildPage(articulos, total, currentPage, PAGE_SIZE, `/tag/${slug}`);
if (currentPage > page.lastPage) return Astro.redirect('/404');

const description = `Artículos etiquetados con "${tag.nombre}" en Beisjoven. Béisbol y softbol mexicano.`;
const tagUrl = `https://beisjoven.com/tag/${slug}`;
---

<BaseLayout
  title={`Tag: ${tag.nombre}${page.currentPage > 1 ? ` - Página ${page.currentPage}` : ''} — Beisjoven`}
  description={description}
  url={tagUrl}
>
  <Breadcrumb items={[
    { text: 'Inicio', href: '/' },
    { text: `Tag: ${tag.nombre}` },
  ]} />

  <!-- Tag header band -->
  <div class="archive-header">
    <div class="bj-container">
      <span class="bj-kicker mb-3">ETIQUETA</span>
      <h1 class="font-heading text-h2 text-navy" style="font-weight:800;">{tag.nombre}</h1>
      <p class="archive-header__desc">{description}</p>
    </div>
  </div>

  <div class="bj-container py-8">
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_300px] gap-10 xl:gap-14 items-start">

      <!-- Articles grid -->
      <div>
        {page.data.length > 0 ? (
          <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-5">
            {page.data.map((a, i) => (
              <ArticleCard article={a} eager={i < 4} />
            ))}
          </div>
        ) : (
          <p class="text-[color:var(--ink-3)] py-12 text-center font-body">No hay artículos con este tag todavía.</p>
        )}

        <!-- Pagination -->
        {page.lastPage > 1 && (
          <nav class="flex flex-wrap justify-center gap-3 mt-10" aria-label="Paginación">
            {page.url.prev && (
              <a href={page.url.prev} class="archive-page-btn">
                &larr; Anterior
              </a>
            )}
            <span class="archive-page-info">
              Página {page.currentPage} de {page.lastPage}
            </span>
            {page.url.next && (
              <a href={page.url.next} class="archive-page-btn">
                Siguiente &rarr;
              </a>
            )}
          </nav>
        )}
      </div>

      <!-- Sidebar -->
      <aside class="archive-sidebar">
        <div class="sticky top-24">
          <MostReadWidget articles={masLeidos} />
        </div>
      </aside>

    </div>
  </div>

  <style>
    .archive-header {
      padding-top: 2rem;
      padding-bottom: 2rem;
      border-bottom: 1px solid var(--rule);
    }

    .archive-header__desc {
      font-family: var(--font-body);
      font-size: 1rem;
      line-height: 1.65;
      color: var(--ink-2);
      margin-top: 0.5rem;
      max-width: 56ch;
    }

    .archive-page-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 48px;
      padding: 0 1.5rem;
      border-radius: var(--radius-pill);
      background: var(--surface-2);
      border: 1px solid var(--rule-strong);
      color: var(--navy);
      font-family: var(--font-body);
      font-size: 0.9375rem;
      font-weight: 600;
      text-decoration: none;
      transition: background 0.15s, border-color 0.15s, box-shadow 0.15s;
    }
    .archive-page-btn:hover {
      background: var(--navy);
      border-color: var(--navy);
      color: #fff;
      box-shadow: var(--shadow-sm);
    }

    .archive-page-info {
      display: inline-flex;
      align-items: center;
      min-height: 48px;
      padding: 0 1rem;
      font-family: var(--font-body);
      font-size: 0.875rem;
      color: var(--ink-3);
    }

    /* Sidebar: only show on lg+ */
    .archive-sidebar {
      display: none;
    }
    @media (min-width: 1024px) {
      .archive-sidebar {
        display: block;
      }
    }
  </style>
</BaseLayout>
