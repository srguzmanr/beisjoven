---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import ArticleCard from '@/components/ArticleCard.astro';
import MostReadWidget from '@/components/MostReadWidget.astro';
import { getAutorBySlug, getArticulosByAutorPaginados, getMasLeidos } from '@/lib/supabase';
import { buildPage, parsePageParam } from '@/lib/pagination';

const PAGE_SIZE = 20;
const { slug } = Astro.params;

const currentPage = parsePageParam(Astro.params.page);
if (currentPage === null) return Astro.redirect('/404');

const autor = await getAutorBySlug(slug as string);
if (!autor) return Astro.redirect('/404');

const [{ articulos, total }, masLeidos] = await Promise.all([
  getArticulosByAutorPaginados(slug as string, PAGE_SIZE, (currentPage - 1) * PAGE_SIZE),
  getMasLeidos(5),
]);

const page = buildPage(articulos, total, currentPage, PAGE_SIZE, `/autor/${autor.slug}`);
if (currentPage > page.lastPage) return Astro.redirect('/404');

const SITE = 'https://beisjoven.com';
const autorUrl = `${SITE}/autor/${autor.slug}`;

const personJsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": autor.nombre,
  "url": autorUrl,
  ...(autor.avatar_url ? { "image": autor.avatar_url } : {}),
  ...(autor.bio ? { "description": autor.bio } : {}),
  "worksFor": {
    "@type": "Organization",
    "name": "Beisjoven",
    "url": SITE,
  },
};
---

<BaseLayout
  title={`${autor.nombre}${page.currentPage > 1 ? ` — Página ${page.currentPage}` : ''} — Beisjoven`}
  description={`${autor.nombre} — Artículos y cobertura en Beisjoven`}
  image={autor.avatar_url || undefined}
  url={autorUrl}
  jsonLd={personJsonLd}
>
  <Breadcrumb items={[
    { text: 'Inicio', href: '/' },
    { text: autor.nombre },
  ]} />

  <!-- Author header band -->
  <div class="archive-header">
    <div class="bj-container">
      <span class="bj-kicker mb-4">AUTOR</span>
      <div class="author-identity">
        {autor.avatar_url && (
          <img
            src={autor.avatar_url}
            alt={autor.nombre}
            class="author-avatar"
            loading="lazy"
          />
        )}
        <div>
          <h1 class="font-heading text-h2 text-navy" style="font-weight:800;">{autor.nombre}</h1>
          {autor.bio && (
            <p class="archive-header__desc">{autor.bio}</p>
          )}
          <p class="author-count">{page.total} artículo{page.total !== 1 ? 's' : ''} publicado{page.total !== 1 ? 's' : ''}</p>
        </div>
      </div>
    </div>
  </div>

  <div class="bj-container py-8">
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_300px] gap-10 xl:gap-14 items-start">

      <!-- Articles grid -->
      <div>
        {page.data.length > 0 ? (
          <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-5">
            {page.data.map((a, i) => (
              <ArticleCard article={a} eager={i < 4} />
            ))}
          </div>
        ) : (
          <p class="text-[color:var(--ink-3)] text-center py-12 font-body">Este autor no tiene artículos publicados.</p>
        )}

        <!-- Pagination -->
        {page.lastPage > 1 && (
          <nav class="flex flex-wrap justify-center gap-3 mt-10" aria-label="Paginación">
            {page.url.prev && (
              <a href={page.url.prev} class="archive-page-btn">
                &larr; Anterior
              </a>
            )}
            <span class="archive-page-info">
              Página {page.currentPage} de {page.lastPage}
            </span>
            {page.url.next && (
              <a href={page.url.next} class="archive-page-btn">
                Siguiente &rarr;
              </a>
            )}
          </nav>
        )}
      </div>

      <!-- Sidebar -->
      <aside class="archive-sidebar">
        <div class="sticky top-24">
          <MostReadWidget articles={masLeidos} />
        </div>
      </aside>

    </div>
  </div>

  <style>
    .archive-header {
      padding-top: 2rem;
      padding-bottom: 2rem;
      border-bottom: 1px solid var(--rule);
    }

    .archive-header__desc {
      font-family: var(--font-body);
      font-size: 1rem;
      line-height: 1.65;
      color: var(--ink-2);
      margin-top: 0.4rem;
      max-width: 56ch;
    }

    .author-identity {
      display: flex;
      align-items: flex-start;
      gap: 1.25rem;
      flex-wrap: wrap;
    }

    .author-avatar {
      width: 72px;
      height: 72px;
      border-radius: 50%;
      object-fit: cover;
      flex-shrink: 0;
      border: 2px solid var(--rule-strong);
    }

    .author-count {
      font-family: var(--font-body);
      font-size: 0.8125rem;
      color: var(--ink-3);
      margin-top: 0.375rem;
    }

    .archive-page-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 48px;
      padding: 0 1.5rem;
      border-radius: var(--radius-pill);
      background: var(--surface-2);
      border: 1px solid var(--rule-strong);
      color: var(--navy);
      font-family: var(--font-body);
      font-size: 0.9375rem;
      font-weight: 600;
      text-decoration: none;
      transition: background 0.15s, border-color 0.15s, box-shadow 0.15s;
    }
    .archive-page-btn:hover {
      background: var(--navy);
      border-color: var(--navy);
      color: #fff;
      box-shadow: var(--shadow-sm);
    }

    .archive-page-info {
      display: inline-flex;
      align-items: center;
      min-height: 48px;
      padding: 0 1rem;
      font-family: var(--font-body);
      font-size: 0.875rem;
      color: var(--ink-3);
    }

    /* Sidebar: only show on lg+ */
    .archive-sidebar {
      display: none;
    }
    @media (min-width: 1024px) {
      .archive-sidebar {
        display: block;
      }
    }
  </style>
</BaseLayout>
