---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import ArticleCard from '@/components/ArticleCard.astro';
import MostReadWidget from '@/components/MostReadWidget.astro';
import { getAutorBySlug, getArticulosByAutorPaginados, getMasLeidos } from '@/lib/supabase';
import { buildPage, parsePageParam } from '@/lib/pagination';

const PAGE_SIZE = 20;
const { slug } = Astro.params;

const currentPage = parsePageParam(Astro.params.page);
if (currentPage === null) return Astro.redirect('/404');

const autor = await getAutorBySlug(slug as string);
if (!autor) return Astro.redirect('/404');

const [{ articulos, total }, masLeidos] = await Promise.all([
  getArticulosByAutorPaginados(slug as string, PAGE_SIZE, (currentPage - 1) * PAGE_SIZE),
  getMasLeidos(5),
]);

const page = buildPage(articulos, total, currentPage, PAGE_SIZE, `/autor/${autor.slug}`);
if (currentPage > page.lastPage) return Astro.redirect('/404');

const SITE = 'https://beisjoven.com';
const autorUrl = `${SITE}/autor/${autor.slug}`;

const personJsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": autor.nombre,
  "url": autorUrl,
  ...(autor.avatar_url ? { "image": autor.avatar_url } : {}),
  ...(autor.bio ? { "description": autor.bio } : {}),
  "worksFor": {
    "@type": "Organization",
    "name": "Beisjoven",
    "url": SITE,
  },
};
---

<BaseLayout
  title={`${autor.nombre}${page.currentPage > 1 ? ` — Página ${page.currentPage}` : ''} — Beisjoven`}
  description={`${autor.nombre} — Artículos y cobertura en Beisjoven`}
  image={autor.avatar_url || undefined}
  url={autorUrl}
  jsonLd={personJsonLd}
>
  <Breadcrumb items={[
    { text: 'Inicio', href: '/' },
    { text: autor.nombre },
  ]} />

  <div class="max-w-7xl mx-auto px-4 py-6">
    <!-- Author Header -->
    <header class="flex flex-col sm:flex-row items-start sm:items-center gap-4 mb-8 pb-6 border-b border-gris-border">
      {autor.avatar_url && (
        <img
          src={autor.avatar_url}
          alt={autor.nombre}
          class="w-20 h-20 rounded-full object-cover flex-shrink-0"
        />
      )}
      <div>
        <h1 class="text-2xl md:text-3xl font-bold text-navy">{autor.nombre}</h1>
        {autor.bio && <p class="text-gris-text mt-1 max-w-2xl">{autor.bio}</p>}
        <p class="text-sm text-gris-muted mt-1">{page.total} artículos publicados</p>
      </div>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Articles Grid -->
      <div class="lg:col-span-2">
        {page.data.length > 0 ? (
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {page.data.map((a, i) => (
              <ArticleCard article={a} eager={i < 4} />
            ))}
          </div>
        ) : (
          <p class="text-gris-text text-center py-8">Este autor no tiene artículos publicados.</p>
        )}

        <!-- Pagination -->
        {page.lastPage > 1 && (
          <nav class="flex justify-center gap-2 mt-8" aria-label="Paginación">
            {page.url.prev && (
              <a href={page.url.prev} class="px-4 py-2 text-sm font-medium rounded-lg bg-gris-bg text-navy hover:bg-gray-200 transition-colors">
                &larr; Anterior
              </a>
            )}
            <span class="px-4 py-2 text-sm text-gris-muted">
              Página {page.currentPage} de {page.lastPage}
            </span>
            {page.url.next && (
              <a href={page.url.next} class="px-4 py-2 text-sm font-medium rounded-lg bg-gris-bg text-navy hover:bg-gray-200 transition-colors">
                Siguiente &rarr;
              </a>
            )}
          </nav>
        )}
      </div>

      <!-- Sidebar -->
      <aside class="space-y-6">
        <MostReadWidget articles={masLeidos} />
      </aside>
    </div>
  </div>
</BaseLayout>
