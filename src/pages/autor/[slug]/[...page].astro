---
import type { GetStaticPaths, Page } from 'astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import ArticleCard from '@/components/ArticleCard.astro';
import MostReadWidget from '@/components/MostReadWidget.astro';
import { getAutores, getAutorBySlug, getAllArticulosByAutor, getMasLeidos, type Articulo } from '@/lib/supabase';

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const autores = await getAutores();
  const allData = await Promise.all(
    autores.map(async (autor) => {
      const articulos = await getAllArticulosByAutor(autor.slug);
      return { autor, articulos };
    })
  );

  return allData.flatMap(({ autor, articulos }) =>
    paginate(articulos, {
      params: { slug: autor.slug },
      pageSize: 20,
    })
  );
};

interface Props {
  page: Page<Articulo>;
}

const { slug } = Astro.params;
const { page } = Astro.props as unknown as Props;

const [autor, masLeidos] = await Promise.all([
  getAutorBySlug(slug as string),
  getMasLeidos(5),
]);

if (!autor) {
  return Astro.redirect('/404');
}

const SITE = 'https://beisjoven.com';
const autorUrl = `${SITE}/autor/${autor.slug}`;

const personJsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": autor.nombre,
  "url": autorUrl,
  ...(autor.avatar_url ? { "image": autor.avatar_url } : {}),
  ...(autor.bio ? { "description": autor.bio } : {}),
  "worksFor": {
    "@type": "Organization",
    "name": "Beisjoven",
    "url": SITE,
  },
};
---

<BaseLayout
  title={`${autor.nombre}${page.currentPage > 1 ? ` — Página ${page.currentPage}` : ''} — Beisjoven`}
  description={`${autor.nombre} — Artículos y cobertura en Beisjoven`}
  image={autor.avatar_url || undefined}
  url={autorUrl}
  jsonLd={personJsonLd}
>
  <Breadcrumb items={[
    { text: 'Inicio', href: '/' },
    { text: autor.nombre },
  ]} />

  <div class="max-w-7xl mx-auto px-4 py-6">
    <!-- Author Header -->
    <header class="flex flex-col sm:flex-row items-start sm:items-center gap-4 mb-8 pb-6 border-b border-gris-border">
      {autor.avatar_url && (
        <img
          src={autor.avatar_url}
          alt={autor.nombre}
          class="w-20 h-20 rounded-full object-cover flex-shrink-0"
        />
      )}
      <div>
        <h1 class="text-2xl md:text-3xl font-bold text-navy">{autor.nombre}</h1>
        {autor.bio && <p class="text-gris-text mt-1 max-w-2xl">{autor.bio}</p>}
        <p class="text-sm text-gris-muted mt-1">{page.total} artículos publicados</p>
      </div>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Articles Grid -->
      <div class="lg:col-span-2">
        {page.data.length > 0 ? (
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {page.data.map((a, i) => (
              <ArticleCard article={a} eager={i < 4} />
            ))}
          </div>
        ) : (
          <p class="text-gris-text text-center py-8">Este autor no tiene artículos publicados.</p>
        )}

        <!-- Pagination -->
        {page.lastPage > 1 && (
          <nav class="flex justify-center gap-2 mt-8" aria-label="Paginación">
            {page.url.prev && (
              <a href={page.url.prev} class="px-4 py-2 text-sm font-medium rounded-lg bg-gris-bg text-navy hover:bg-gray-200 transition-colors">
                &larr; Anterior
              </a>
            )}
            <span class="px-4 py-2 text-sm text-gris-muted">
              Página {page.currentPage} de {page.lastPage}
            </span>
            {page.url.next && (
              <a href={page.url.next} class="px-4 py-2 text-sm font-medium rounded-lg bg-gris-bg text-navy hover:bg-gray-200 transition-colors">
                Siguiente &rarr;
              </a>
            )}
          </nav>
        )}
      </div>

      <!-- Sidebar -->
      <aside class="space-y-6">
        <MostReadWidget articles={masLeidos} />
      </aside>
    </div>
  </div>
</BaseLayout>
