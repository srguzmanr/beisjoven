---
import BaseLayout from '@/layouts/BaseLayout.astro';
import HeroDefault from '@/components/HeroDefault.astro';
import MixedFeed from '@/components/MixedFeed.astro';
import JuvenilRail from '@/components/JuvenilRail.astro';
import Gallery from '@/components/Gallery.astro';
import CategorySection from '@/components/CategorySection.astro';
import NewsletterBlock from '@/components/NewsletterBlock.astro';
import AdSlot from '@/components/AdSlot.astro';
import {
  supabaseServer,
  getArticulos,
  getPortadaSlots,
  getEventosActivos,
  type Articulo,
} from '@/lib/supabase';

// Fetch all data in parallel at build time
const [
  articulos,
  portadaSlots,
  eventosActivos,
] = await Promise.all([
  getArticulos(12),
  getPortadaSlots(),
  getEventosActivos(),
]);

const eventoActivo = eventosActivos[0] || null;
// EDITOR-20 F2 — curación separada del contenido: slot 1 manda sobre el
// hero; sin slot (o tabla aún no creada) la portada vive por recencia.
const hero = portadaSlots.get(1) ?? articulos[0] ?? null;
const heroId = hero?.id ?? -1;

// MixedFeed data (DESIGN-04b). Joined select returns categorias/autores as
// nested objects; we flatten to the StoryCard / ListCard prop shape below.
const FEED_SELECT =
  'id, slug, titulo, extracto, imagen_url, fecha, read_time_minutes, categorias!inner(slug, nombre), autores(nombre)';

const thirtyDaysAgo = new Date(Date.now() - 30 * 24 * 60 * 60 * 1000)
  .toISOString()
  .split('T')[0];

const [latestRes, masLeidosWindowRes, videosRes] = await Promise.all([
  supabaseServer
    .from('articulos')
    .select(FEED_SELECT)
    .eq('publicado', true)
    .neq('id', heroId)
    .order('fecha', { ascending: false })
    .limit(8),
  supabaseServer
    .from('articulos')
    .select(FEED_SELECT)
    .eq('publicado', true)
    .gte('fecha', thirtyDaysAgo)
    .order('vistas', { ascending: false })
    .limit(4),
  supabaseServer
    .from('videos')
    .select('id, titulo, thumbnail_url, youtube_id')
    .eq('publicado', true)
    .order('fecha', { ascending: false })
    .limit(4),
]);

let masLeidosRaw = masLeidosWindowRes.data ?? [];
if (masLeidosRaw.length < 4) {
  const { data: fallback } = await supabaseServer
    .from('articulos')
    .select(FEED_SELECT)
    .eq('publicado', true)
    .order('vistas', { ascending: false })
    .limit(4);
  masLeidosRaw = fallback ?? [];
}

type FeedRow = {
  id: number;
  slug: string;
  titulo: string;
  extracto: string | null;
  imagen_url: string | null;
  fecha: string;
  read_time_minutes: number;
  categorias: { slug: string; nombre: string } | { slug: string; nombre: string }[] | null;
  autores: { nombre: string } | { nombre: string }[] | null;
};

function flatten(rows: FeedRow[] | null) {
  return (rows ?? []).map((r) => {
    const cat = Array.isArray(r.categorias) ? r.categorias[0] : r.categorias;
    const aut = Array.isArray(r.autores) ? r.autores[0] : r.autores;
    return {
      id: r.id,
      slug: r.slug,
      titulo: r.titulo,
      extracto: r.extracto,
      imagen_url: r.imagen_url,
      fecha: r.fecha,
      read_time_minutes: r.read_time_minutes ?? 1,
      categoria_slug: cat?.slug ?? '',
      categoria_nombre: cat?.nombre ?? '',
      autor_nombre: aut?.nombre ?? null,
    };
  });
}

// EDITOR-20 F2 — slots 2–5 ocupan su posición exacta en "Lo último";
// las posiciones sin curar (o cuyo artículo es ya el hero) se llenan
// por recencia. Un artículo fijado nunca se duplica en el relleno.
function articuloToFeedItem(a: Articulo) {
  return {
    id: a.id,
    slug: a.slug,
    titulo: a.titulo,
    extracto: a.extracto,
    imagen_url: a.imagen_url,
    fecha: a.fecha,
    read_time_minutes: a.read_time_minutes ?? 1,
    categoria_slug: a.categoria?.slug ?? '',
    categoria_nombre: a.categoria?.nombre ?? '',
    autor_nombre: a.autor?.nombre ?? null,
  };
}

const pinnedIds = new Set(
  [2, 3, 4, 5]
    .map((n) => portadaSlots.get(n)?.id)
    .filter((id): id is number => typeof id === 'number'),
);
const fillPool = flatten(latestRes.data as FeedRow[] | null).filter(
  (r) => !pinnedIds.has(r.id),
);
const latest: ReturnType<typeof articuloToFeedItem>[] = [];
for (const slotN of [2, 3, 4, 5]) {
  const pinned = portadaSlots.get(slotN);
  if (pinned && pinned.id !== heroId) {
    latest.push(articuloToFeedItem(pinned));
  } else {
    const next = fillPool.shift();
    if (next) latest.push(next);
  }
}

const masLeidos = flatten(masLeidosRaw as FeedRow[]);
const videos = videosRes.data ?? [];

// DESIGN-04c: Juvenil rail — 3 most-recent juvenil articles for the
// "Nuestra obsesión" navy module. Separate from the per-category rail
// (which DESIGN-04e will remove); shape is autor flattened, category
// is implicit in the module.
type JuvenilRow = {
  id: number;
  slug: string;
  titulo: string;
  extracto: string | null;
  imagen_url: string | null;
  fecha: string;
  read_time_minutes: number | null;
  autores: { nombre: string } | { nombre: string }[] | null;
};

const { data: juvenilRailRaw } = await supabaseServer
  .from('articulos')
  .select(
    'id, slug, titulo, extracto, imagen_url, fecha, read_time_minutes, categorias!inner(slug), autores(nombre)'
  )
  .eq('categorias.slug', 'juvenil')
  .eq('publicado', true)
  .order('fecha', { ascending: false })
  .limit(3);

const juvenilRail = ((juvenilRailRaw ?? []) as JuvenilRow[]).map((row) => {
  const aut = Array.isArray(row.autores) ? row.autores[0] : row.autores;
  return {
    slug: row.slug,
    titulo: row.titulo,
    extracto: row.extracto,
    imagen_url: row.imagen_url,
    fecha: row.fecha,
    read_time_minutes: row.read_time_minutes ?? 1,
    autor_nombre: aut?.nombre ?? 'Redacción Beisjoven',
  };
});

---

<BaseLayout>
  {/* Active Event Banner */}
  {eventoActivo && (
    <a href={`/evento/${eventoActivo.slug}`} class="block bg-rojo hover:bg-rojo-dark transition-colors">
      <div class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between gap-4">
        <div class="flex items-center gap-3 min-w-0">
          <span class="bg-white/20 text-white text-[10px] font-bold uppercase px-2 py-1 rounded-sm tracking-wider flex-shrink-0">
            Evento
          </span>
          <span class="text-white font-bold text-sm truncate">
            {eventoActivo.nombre}
          </span>
          {eventoActivo.ciudad && (
            <span class="text-white/70 text-xs hidden sm:inline flex-shrink-0">
              {eventoActivo.ciudad}
            </span>
          )}
        </div>
        <span class="text-white/90 text-xs font-semibold flex-shrink-0 whitespace-nowrap">
          Ver cobertura &rarr;
        </span>
      </div>
    </a>
  )}

  <!-- Hero Section -->
  <div class="max-w-7xl mx-auto px-4 py-8">
    <section class="mb-12">
      {hero && <HeroDefault story={hero} />}
    </section>
  </div>

  {/* LEADER-01 — homepage leaderboard: below hero, above mixed feed.
      ADS-GOLIVE-PREP-01: slot id frozen as 'home-top'. */}
  <section class="bj-leaderboard-zone">
    <div class="bj-leaderboard-zone__container">
      <AdSlot slotId="home-top" format="leaderboard" />
    </div>
  </section>

  <MixedFeed latest={latest} masLeidos={masLeidos} videos={videos} />

  {/* HOUSE-ADS-01 — homepage in-feed, between blocks.
      ADS-GOLIVE-PREP-01: slot id frozen as 'home-mid' (ex slot-b). */}
  <section class="bj-adslot-feed">
    <div class="bj-adslot-feed__container">
      <AdSlot slotId="home-mid" variant="card" />
    </div>
  </section>

  {juvenilRail.length > 0 && <JuvenilRail stories={juvenilRail} />}

  <!-- DESIGN-04d: Gallery — "La semana, en imágenes" -->
  <Gallery />

  <!-- DESIGN-04e → HF-02: Per-category sections as full-bleed alternating
       bands (blanco / --bg-2, empezando en blanco). La frontera entre
       secciones es el cambio de color de fondo. -->
  <CategorySection slug="mlb" displayName="MLB" band="bg" />
  <CategorySection slug="liga-mexicana" displayName="Ligas Mexicanas" band="bg-2" />
  <CategorySection slug="seleccion" displayName="Selección" band="bg" />
  <CategorySection slug="softbol" displayName="Softbol" band="bg-2" />
  <CategorySection slug="opinion" displayName="Opinión" band="bg" />

  {/* NewsletterBlock conserva su tarjeta --bg-2 con borde (HF-02: solo se
      envuelve en banda blanca full-bleed; contenido y copy intactos). */}
  <section class="newsletter-band">
    <div class="newsletter-band__container">
      <NewsletterBlock />
    </div>
  </section>

  <style>
    /* LEADER-01 — leaderboard zone wrapper (max 970px, centered). At 375px the
       16px side padding leaves 343px → the 320×50 box centers, no overflow. */
    .bj-leaderboard-zone {
      background: #fff;
      padding: 8px 0 24px;
    }

    @media (min-width: 768px) {
      .bj-leaderboard-zone {
        padding: 16px 32px 32px;
      }
    }

    .bj-leaderboard-zone__container {
      max-width: 970px;
      margin: 0 auto;
      padding: 0 16px;
    }

    @media (min-width: 768px) {
      .bj-leaderboard-zone__container {
        padding: 0;
      }
    }

    /* HOUSE-ADS-01 — Slot B in-feed wrapper (card footprint, centered). */
    .bj-adslot-feed {
      background: #fff;
      padding: 8px 0 24px;
    }

    @media (min-width: 768px) {
      .bj-adslot-feed {
        padding: 16px 32px 32px;
      }
    }

    .bj-adslot-feed__container {
      max-width: var(--w-page);
      margin: 0 auto;
      padding: 0 16px;
      display: flex;
      justify-content: center;
    }

    @media (min-width: 768px) {
      .bj-adslot-feed__container {
        padding: 0;
      }
    }

    .newsletter-band {
      background: var(--bg);
      padding: var(--section) 0;
    }

    @media (min-width: 768px) {
      .newsletter-band {
        padding: var(--section-lg) 32px;
      }
    }

    .newsletter-band__container {
      max-width: var(--w-page);
      margin: 0 auto;
      padding: 0 16px;
    }

    @media (min-width: 768px) {
      .newsletter-band__container {
        padding: 0;
      }
    }
  </style>
</BaseLayout>
