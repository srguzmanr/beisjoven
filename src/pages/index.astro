---
import BaseLayout from '@/layouts/BaseLayout.astro';
import HeroDefault from '@/components/HeroDefault.astro';
import HeroSplit from '@/components/HeroSplit.astro';
import ArticleCard from '@/components/ArticleCard.astro';
import SectionTitle from '@/components/SectionTitle.astro';
import QuickHitsBar from '@/components/QuickHitsBar.astro';
import SponsorReservation from '@/components/SponsorReservation.astro';
import MixedFeed from '@/components/MixedFeed.astro';
import JuvenilRail from '@/components/JuvenilRail.astro';
import Gallery from '@/components/Gallery.astro';
import {
  supabaseServer,
  getArticulos,
  getArticulosDestacados,
  getArticulosByCategoria,
  getEventosActivos,
  getQuickHitsActivos,
} from '@/lib/supabase';

// Fetch all data in parallel at build time
const [
  articulos,
  destacados,
  ligaMex,
  mlb,
  seleccion,
  softbol,
  juvenil,
  opinion,
  eventosActivos,
  quickHits,
] = await Promise.all([
  getArticulos(12),
  getArticulosDestacados(3),
  getArticulosByCategoria('liga-mexicana', 4),
  getArticulosByCategoria('mlb', 4),
  getArticulosByCategoria('seleccion', 4),
  getArticulosByCategoria('softbol', 4),
  getArticulosByCategoria('juvenil', 4),
  getArticulosByCategoria('opinion', 4),
  getEventosActivos(),
  getQuickHitsActivos(3),
]);

const eventoActivo = eventosActivos[0] || null;
const featured = destacados.length > 0 ? destacados : articulos.slice(0, 3);
const hero = featured[0];
const secondary = featured.slice(1, 3);
// hero_layout enum: 'default' | 'split' | 'overlay'. Phase 1: only 'split' deviates;
// 'overlay' falls back to HeroDefault until HeroAmbitious is wired (Bible Part 4 §2.3).
const heroVariant = hero?.hero_layout === 'split' ? 'split' : 'default';
const heroId = hero?.id ?? -1;

// MixedFeed data (DESIGN-04b). Joined select returns categorias/autores as
// nested objects; we flatten to the StoryCard / ListCard prop shape below.
const FEED_SELECT =
  'id, slug, titulo, extracto, imagen_url, imagen_portada_alt, fecha, categorias!inner(slug, nombre), autores(nombre)';

const thirtyDaysAgo = new Date(Date.now() - 30 * 24 * 60 * 60 * 1000)
  .toISOString()
  .split('T')[0];

const [latestRes, masLeidosWindowRes, videosRes] = await Promise.all([
  supabaseServer
    .from('articulos')
    .select(FEED_SELECT)
    .eq('publicado', true)
    .neq('id', heroId)
    .order('fecha', { ascending: false })
    .limit(4),
  supabaseServer
    .from('articulos')
    .select(FEED_SELECT)
    .eq('publicado', true)
    .gte('fecha', thirtyDaysAgo)
    .order('vistas', { ascending: false })
    .limit(4),
  supabaseServer
    .from('videos')
    .select('id, slug, titulo, thumbnail_url, youtube_id')
    .eq('publicado', true)
    .order('fecha', { ascending: false })
    .limit(4),
]);

let masLeidosRaw = masLeidosWindowRes.data ?? [];
if (masLeidosRaw.length < 4) {
  const { data: fallback } = await supabaseServer
    .from('articulos')
    .select(FEED_SELECT)
    .eq('publicado', true)
    .order('vistas', { ascending: false })
    .limit(4);
  masLeidosRaw = fallback ?? [];
}

type FeedRow = {
  id: number;
  slug: string;
  titulo: string;
  extracto: string | null;
  imagen_url: string | null;
  imagen_portada_alt: string | null;
  fecha: string;
  categorias: { slug: string; nombre: string } | { slug: string; nombre: string }[] | null;
  autores: { nombre: string } | { nombre: string }[] | null;
};

function flatten(rows: FeedRow[] | null) {
  return (rows ?? []).map((r) => {
    const cat = Array.isArray(r.categorias) ? r.categorias[0] : r.categorias;
    const aut = Array.isArray(r.autores) ? r.autores[0] : r.autores;
    return {
      id: r.id,
      slug: r.slug,
      titulo: r.titulo,
      extracto: r.extracto,
      imagen_url: r.imagen_url,
      imagen_portada_alt: r.imagen_portada_alt,
      fecha: r.fecha,
      categoria_slug: cat?.slug ?? '',
      categoria_nombre: cat?.nombre ?? '',
      autor_nombre: aut?.nombre ?? null,
    };
  });
}

const latest = flatten(latestRes.data as FeedRow[] | null);
const masLeidos = flatten(masLeidosRaw as FeedRow[]);
const videos = videosRes.data ?? [];

// DESIGN-04c: Juvenil rail — 3 most-recent juvenil articles for the
// "Nuestra obsesión" navy module. Separate from the per-category rail
// (which DESIGN-04e will remove); shape is autor flattened, category
// is implicit in the module.
type JuvenilRow = {
  id: number;
  slug: string;
  titulo: string;
  extracto: string | null;
  imagen_url: string | null;
  imagen_portada_alt: string | null;
  fecha: string;
  autores: { nombre: string } | { nombre: string }[] | null;
};

const { data: juvenilRailRaw } = await supabaseServer
  .from('articulos')
  .select(
    'id, slug, titulo, extracto, imagen_url, imagen_portada_alt, fecha, categorias!inner(slug), autores(nombre)'
  )
  .eq('categorias.slug', 'juvenil')
  .eq('publicado', true)
  .order('fecha', { ascending: false })
  .limit(3);

const juvenilRail = ((juvenilRailRaw ?? []) as JuvenilRow[]).map((row) => {
  const aut = Array.isArray(row.autores) ? row.autores[0] : row.autores;
  return {
    slug: row.slug,
    titulo: row.titulo,
    extracto: row.extracto,
    imagen_url: row.imagen_url,
    imagen_portada_alt: row.imagen_portada_alt,
    fecha: row.fecha,
    autor_nombre: aut?.nombre ?? 'Redacción Beisjoven',
  };
});

// Category sections config for alternating backgrounds
const categorySections = [
  { data: ligaMex, title: 'Ligas Mexicanas', href: '/categoria/liga-mexicana', color: '#dc2626', bg: 'bg-white' },
  { data: mlb, title: 'MLB', href: '/categoria/mlb', color: '#1e40af', bg: 'bg-gris-bg' },
  { data: seleccion, title: 'Selección', href: '/categoria/seleccion', color: '#15803d', bg: 'bg-white' },
  { data: softbol, title: 'Softbol', href: '/categoria/softbol', color: '#7c3aed', bg: 'bg-gris-bg' },
  { data: juvenil, title: 'Juvenil', href: '/categoria/juvenil', color: '#ea580c', bg: 'bg-white' },
  { data: opinion, title: 'Opinión', href: '/categoria/opinion', color: '#92400e', bg: 'bg-gris-bg' },
];
---

<BaseLayout>
  <QuickHitsBar hits={quickHits} />

  {/* Active Event Banner */}
  {eventoActivo && (
    <a href={`/evento/${eventoActivo.slug}`} class="block bg-rojo hover:bg-rojo-dark transition-colors">
      <div class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between gap-4">
        <div class="flex items-center gap-3 min-w-0">
          <span class="bg-white/20 text-white text-[10px] font-bold uppercase px-2 py-1 rounded-sm tracking-wider flex-shrink-0">
            Evento
          </span>
          <span class="text-white font-bold text-sm truncate">
            {eventoActivo.nombre}
          </span>
          {eventoActivo.ciudad && (
            <span class="text-white/70 text-xs hidden sm:inline flex-shrink-0">
              {eventoActivo.ciudad}
            </span>
          )}
        </div>
        <span class="text-white/90 text-xs font-semibold flex-shrink-0 whitespace-nowrap">
          Ver cobertura &rarr;
        </span>
      </div>
    </a>
  )}

  <!-- Hero Section -->
  <div class="max-w-7xl mx-auto px-4 py-8">
    <section class="mb-12">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-5 lg:grid-rows-1">
        <!-- Main Hero (60%) -->
        <div class="lg:col-span-3 h-full">
          {hero && (heroVariant === 'split'
            ? <HeroSplit story={hero} />
            : <HeroDefault story={hero} />
          )}
        </div>
        <!-- Secondary (40%) -->
        <div class="lg:col-span-2 flex flex-col gap-5">
          {secondary.map((a) => (
            <article class="group relative rounded-xl overflow-hidden flex-1 min-h-[200px] shadow-sm hover:shadow-lg transition-all duration-300">
              <a href={`/articulo/${a.slug}`} class="block h-full">
                <img src={a.imagen_url} alt={a.titulo} loading="eager" class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-500" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/30 to-transparent"></div>
                <div class="absolute bottom-0 left-0 right-0 p-5">
                  {a.categoria && (
                    <span class="inline-block text-[10px] font-bold uppercase tracking-wider text-white/90 mb-1.5">{a.categoria.nombre}</span>
                  )}
                  <h3 class="text-white text-sm md:text-base font-bold line-clamp-2 leading-snug group-hover:text-white/90 transition-colors">
                    {a.titulo}
                  </h3>
                </div>
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>
  </div>

  <!-- DESIGN-04b: Sponsor reservation + Mixed Feed -->
  <SponsorReservation />
  <MixedFeed latest={latest} masLeidos={masLeidos} videos={videos} />

  {juvenilRail.length > 0 && <JuvenilRail stories={juvenilRail} />}

  <!-- DESIGN-04d: Gallery — "La semana, en imágenes" -->
  <Gallery />

  <!-- Category Sections -->
  <div class="max-w-7xl mx-auto px-4">
    {categorySections.map((section) => (
      section.data.length > 0 && (
        <section class:list={[section.bg, 'py-12 -mx-4 px-4']}>
          <SectionTitle title={section.title} href={section.href} color={section.color} />
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {section.data.map((a, i) => (
              <ArticleCard article={a} eager={i < 2} />
            ))}
          </div>
        </section>
      )
    ))}
  </div>
</BaseLayout>
