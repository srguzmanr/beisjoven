---
import BaseLayout from '@/layouts/BaseLayout.astro';
import HeroDefault from '@/components/HeroDefault.astro';
import QuickHitsBar from '@/components/QuickHitsBar.astro';
import SponsorReservation from '@/components/SponsorReservation.astro';
import MixedFeed from '@/components/MixedFeed.astro';
import JuvenilRail from '@/components/JuvenilRail.astro';
import Gallery from '@/components/Gallery.astro';
import CategorySection from '@/components/CategorySection.astro';
import NewsletterBlock from '@/components/NewsletterBlock.astro';
import AdSlot from '@/components/AdSlot.astro';
import StandingsWidget from '@/components/StandingsWidget.astro';
import MostReadWidget from '@/components/MostReadWidget.astro';
import {
  supabaseServer,
  getArticulos,
  getArticulosDestacados,
  getEventosActivos,
  getQuickHitsActivos,
} from '@/lib/supabase';

// Fetch all data in parallel at build time
const [
  articulos,
  destacados,
  eventosActivos,
  quickHits,
] = await Promise.all([
  getArticulos(12),
  getArticulosDestacados(3),
  getEventosActivos(),
  getQuickHitsActivos(3),
]);

const eventoActivo = eventosActivos[0] || null;
const featured = destacados.length > 0 ? destacados : articulos.slice(0, 3);
const hero = featured[0];
const heroId = hero?.id ?? -1;

// MixedFeed data (DESIGN-04b). Joined select returns categorias/autores as
// nested objects; we flatten to the StoryCard / ListCard prop shape below.
const FEED_SELECT =
  'id, slug, titulo, extracto, imagen_url, imagen_portada_alt, fecha, read_time_minutes, categorias!inner(slug, nombre), autores(nombre)';

const thirtyDaysAgo = new Date(Date.now() - 30 * 24 * 60 * 60 * 1000)
  .toISOString()
  .split('T')[0];

const [latestRes, masLeidosWindowRes, videosRes, masLeidosWidgetRes] = await Promise.all([
  supabaseServer
    .from('articulos')
    .select(FEED_SELECT)
    .eq('publicado', true)
    .neq('id', heroId)
    .order('fecha', { ascending: false })
    .limit(4),
  supabaseServer
    .from('articulos')
    .select(FEED_SELECT)
    .eq('publicado', true)
    .gte('fecha', thirtyDaysAgo)
    .order('vistas', { ascending: false })
    .limit(4),
  supabaseServer
    .from('videos')
    .select('id, slug, titulo, thumbnail_url, youtube_id')
    .eq('publicado', true)
    .order('fecha', { ascending: false })
    .limit(4),
  // MostReadWidget needs full Articulo-shape rows (titulo, slug, categoria)
  supabaseServer
    .from('articulos')
    .select('id, titulo, slug, vistas, categorias(slug, nombre)')
    .eq('publicado', true)
    .order('vistas', { ascending: false })
    .limit(5),
]);

let masLeidosRaw = masLeidosWindowRes.data ?? [];
if (masLeidosRaw.length < 4) {
  const { data: fallback } = await supabaseServer
    .from('articulos')
    .select(FEED_SELECT)
    .eq('publicado', true)
    .order('vistas', { ascending: false })
    .limit(4);
  masLeidosRaw = fallback ?? [];
}

if (masLeidosWidgetRes.error) {
  console.error('[index] MostReadWidget query failed:', masLeidosWidgetRes.error);
}

type FeedRow = {
  id: number;
  slug: string;
  titulo: string;
  extracto: string | null;
  imagen_url: string | null;
  imagen_portada_alt: string | null;
  fecha: string;
  read_time_minutes: number;
  categorias: { slug: string; nombre: string } | { slug: string; nombre: string }[] | null;
  autores: { nombre: string } | { nombre: string }[] | null;
};

function flatten(rows: FeedRow[] | null) {
  return (rows ?? []).map((r) => {
    const cat = Array.isArray(r.categorias) ? r.categorias[0] : r.categorias;
    const aut = Array.isArray(r.autores) ? r.autores[0] : r.autores;
    return {
      id: r.id,
      slug: r.slug,
      titulo: r.titulo,
      extracto: r.extracto,
      imagen_url: r.imagen_url,
      imagen_portada_alt: r.imagen_portada_alt,
      fecha: r.fecha,
      read_time_minutes: r.read_time_minutes ?? 1,
      categoria_slug: cat?.slug ?? '',
      categoria_nombre: cat?.nombre ?? '',
      autor_nombre: aut?.nombre ?? null,
    };
  });
}

const latest = flatten(latestRes.data as FeedRow[] | null);
const masLeidos = flatten(masLeidosRaw as FeedRow[]);
const videos = videosRes.data ?? [];

// Shape for MostReadWidget: needs Articulo-shaped rows (titulo, slug, categoria)
type WidgetRow = {
  id: number;
  titulo: string;
  slug: string;
  vistas: number;
  categorias: { slug: string; nombre: string } | { slug: string; nombre: string }[] | null;
};

const masLeidosWidget = ((masLeidosWidgetRes.data ?? []) as WidgetRow[]).map((r) => {
  const cat = Array.isArray(r.categorias) ? r.categorias[0] : r.categorias;
  // MostReadWidget only reads titulo and slug from articles, so casting is safe
  return {
    id: r.id,
    titulo: r.titulo,
    slug: r.slug,
    vistas: r.vistas,
    categoria: cat ? { slug: cat.slug, nombre: cat.nombre, id: 0, color: '' } : null,
  } as any;
});

// DESIGN-04c: Juvenil rail — 3 most-recent juvenil articles for the
// "Nuestra obsesión" navy module. Separate from the per-category rail
// (which DESIGN-04e will remove); shape is autor flattened, category
// is implicit in the module.
type JuvenilRow = {
  id: number;
  slug: string;
  titulo: string;
  extracto: string | null;
  imagen_url: string | null;
  imagen_portada_alt: string | null;
  fecha: string;
  read_time_minutes: number | null;
  autores: { nombre: string } | { nombre: string }[] | null;
};

const { data: juvenilRailRaw } = await supabaseServer
  .from('articulos')
  .select(
    'id, slug, titulo, extracto, imagen_url, imagen_portada_alt, fecha, read_time_minutes, categorias!inner(slug), autores(nombre)'
  )
  .eq('categorias.slug', 'juvenil')
  .eq('publicado', true)
  .order('fecha', { ascending: false })
  .limit(3);

const juvenilRail = ((juvenilRailRaw ?? []) as JuvenilRow[]).map((row) => {
  const aut = Array.isArray(row.autores) ? row.autores[0] : row.autores;
  return {
    slug: row.slug,
    titulo: row.titulo,
    extracto: row.extracto,
    imagen_url: row.imagen_url,
    imagen_portada_alt: row.imagen_portada_alt,
    fecha: row.fecha,
    read_time_minutes: row.read_time_minutes ?? 1,
    autor_nombre: aut?.nombre ?? 'Redacción Beisjoven',
  };
});

---

<BaseLayout>
  <!-- Breaking news ticker -->
  <QuickHitsBar hits={quickHits} />

  <!-- Active Event Banner -->
  {eventoActivo && (
    <a href={`/evento/${eventoActivo.slug}`} class="bj-event-banner">
      <div class="bj-container">
        <div class="bj-event-banner__inner">
          <div class="bj-event-banner__left">
            <span class="bj-event-banner__badge">Evento</span>
            <span class="bj-event-banner__name">{eventoActivo.nombre}</span>
            {eventoActivo.ciudad && (
              <span class="bj-event-banner__city">{eventoActivo.ciudad}</span>
            )}
          </div>
          <span class="bj-event-banner__cta">Ver cobertura &rarr;</span>
        </div>
      </div>
    </a>
  )}

  <!-- =====================================================
       HERO — full-bleed container row
       ===================================================== -->
  <div class="bj-hero-section">
    <div class="bj-container">
      {hero && <HeroDefault story={hero} />}
    </div>
  </div>

  <!-- =====================================================
       FULL-BLEED MIDDLE SECTIONS
       (MixedFeed, JuvenilRail, Gallery own their backgrounds)
       ===================================================== -->
  <SponsorReservation />
  <MixedFeed latest={latest} masLeidos={masLeidos} videos={videos} />
  {juvenilRail.length > 0 && <JuvenilRail stories={juvenilRail} />}
  <Gallery />

  <!-- =====================================================
       CATEGORIES + RIGHT RAIL two-column grid
       ===================================================== -->
  <div class="bj-below-fold">
    <div class="bj-container">
      <div class="bj-below-fold__grid">

        <!-- Main: stacked category sections -->
        <div class="bj-cat-main">
          <CategorySection slug="mlb" displayName="MLB" />
          <CategorySection slug="liga-mexicana" displayName="Ligas Mexicanas" />
          <CategorySection slug="seleccion" displayName="Selección" />
          <CategorySection slug="softbol" displayName="Softbol" />
          <CategorySection slug="opinion" displayName="Opinión" />
        </div>

        <!-- Right rail: Standings → Ad → MostRead (lg+ only) -->
        <aside class="bj-right-rail" aria-label="Lateral">
          <StandingsWidget />
          <div class="bj-right-rail__ad">
            <AdSlot slotId="slot-b" variant="sidebar" />
          </div>
          {masLeidosWidget.length > 0 && (
            <MostReadWidget articles={masLeidosWidget} scope={{ type: 'global' }} />
          )}
        </aside>

      </div>
    </div>
  </div>

  <!-- Rail content for mobile (below category stack) -->
  <div class="bj-mobile-rail">
    <div class="bj-container">
      <div class="bj-mobile-rail__grid">
        <StandingsWidget />
        {masLeidosWidget.length > 0 && (
          <MostReadWidget articles={masLeidosWidget} scope={{ type: 'global' }} />
        )}
      </div>
    </div>
  </div>

  <!-- Newsletter — navy/gold, full bleed -->
  <NewsletterBlock />

</BaseLayout>

<style>
  /* ====================================================
     Event Banner
     ==================================================== */
  .bj-event-banner {
    display: block;
    background: var(--red, #C8102E);
    text-decoration: none;
    transition: background 0.15s;
  }

  .bj-event-banner:hover {
    background: var(--red-dark, #9A0C23);
  }

  .bj-event-banner__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 10px 0;
    min-height: 44px;
  }

  .bj-event-banner__left {
    display: flex;
    align-items: center;
    gap: 10px;
    min-width: 0;
    flex: 1;
  }

  .bj-event-banner__badge {
    background: rgba(255, 255, 255, 0.2);
    color: #fff;
    font-family: var(--font-heading);
    font-size: 9px;
    font-weight: 900;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 3px 8px;
    border-radius: 3px;
    flex-shrink: 0;
    line-height: 1;
  }

  .bj-event-banner__name {
    color: #fff;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 13px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .bj-event-banner__city {
    color: rgba(255, 255, 255, 0.65);
    font-family: var(--font-body);
    font-size: 12px;
    flex-shrink: 0;
    display: none;
  }

  @media (min-width: 640px) {
    .bj-event-banner__city {
      display: inline;
    }
  }

  .bj-event-banner__cta {
    color: rgba(255, 255, 255, 0.9);
    font-family: var(--font-heading);
    font-size: 12px;
    font-weight: 700;
    flex-shrink: 0;
    white-space: nowrap;
  }

  /* ====================================================
     Hero section
     ==================================================== */
  .bj-hero-section {
    background: #fff;
    padding: 32px 0 40px;
  }

  @media (min-width: 768px) {
    .bj-hero-section {
      padding: 40px 0 48px;
    }
  }

  /* ====================================================
     Below-fold: categories + rail
     ==================================================== */
  .bj-below-fold {
    background: #fff;
    padding: 40px 0 0;
  }

  @media (min-width: 768px) {
    .bj-below-fold {
      padding: 48px 0 0;
    }
  }

  .bj-below-fold__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }

  @media (min-width: 1024px) {
    .bj-below-fold__grid {
      grid-template-columns: 1fr 300px;
      gap: 48px;
      align-items: start;
    }
  }

  /* Category stack — main column */
  .bj-cat-main {
    display: flex;
    flex-direction: column;
    gap: 48px;
    padding-bottom: 56px;
  }

  @media (min-width: 768px) {
    .bj-cat-main {
      gap: 56px;
      padding-bottom: 72px;
    }
  }

  /* Right rail — hidden mobile, sticky desktop */
  .bj-right-rail {
    display: none;
  }

  @media (min-width: 1024px) {
    .bj-right-rail {
      display: flex;
      flex-direction: column;
      gap: 24px;
      position: sticky;
      top: 24px;
      max-height: calc(100vh - 48px);
      overflow-y: auto;
      scrollbar-width: none;
      padding-bottom: 56px;
    }

    .bj-right-rail::-webkit-scrollbar {
      display: none;
    }
  }

  .bj-right-rail__ad {
    display: flex;
    justify-content: center;
  }

  /* ====================================================
     Mobile rail (below categories on small screens)
     ==================================================== */
  .bj-mobile-rail {
    background: var(--surface-2, #F6F5F1);
    padding: 32px 0 40px;
    border-top: 1px solid var(--rule, rgba(27, 42, 74, 0.10));
  }

  @media (min-width: 1024px) {
    .bj-mobile-rail {
      display: none;
    }
  }

  .bj-mobile-rail__grid {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  @media (min-width: 640px) {
    .bj-mobile-rail__grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 24px;
      align-items: start;
    }
  }
</style>
