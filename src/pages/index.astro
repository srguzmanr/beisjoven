---
import BaseLayout from '@/layouts/BaseLayout.astro';
import HeroArticle from '@/components/HeroArticle.astro';
import ArticleCard from '@/components/ArticleCard.astro';
import SectionTitle from '@/components/SectionTitle.astro';
import MostReadWidget from '@/components/MostReadWidget.astro';
import QuickHitsBar from '@/components/QuickHitsBar.astro';
import {
  getArticulos,
  getArticulosDestacados,
  getMasLeidos,
  getArticulosByCategoria,
  getVideosDestacados,
  getEventosActivos,
  getQuickHitsActivos,
} from '@/lib/supabase';

// Fetch all data in parallel at build time
const [
  articulos,
  destacados,
  masLeidos,
  ligaMex,
  mlb,
  seleccion,
  softbol,
  juvenil,
  opinion,
  videos,
  eventosActivos,
  quickHits,
] = await Promise.all([
  getArticulos(12),
  getArticulosDestacados(3),
  getMasLeidos(5),
  getArticulosByCategoria('liga-mexicana', 4),
  getArticulosByCategoria('mlb', 4),
  getArticulosByCategoria('seleccion', 4),
  getArticulosByCategoria('softbol', 4),
  getArticulosByCategoria('juvenil', 4),
  getArticulosByCategoria('opinion', 4),
  getVideosDestacados(4),
  getEventosActivos(),
  getQuickHitsActivos(3),
]);

const eventoActivo = eventosActivos[0] || null;
const featured = destacados.length > 0 ? destacados : articulos.slice(0, 3);
const hero = featured[0];
const secondary = featured.slice(1, 3);

// Category sections config for alternating backgrounds
const categorySections = [
  { data: ligaMex, title: 'Ligas Mexicanas', href: '/categoria/liga-mexicana', color: '#dc2626', bg: 'bg-white' },
  { data: mlb, title: 'MLB', href: '/categoria/mlb', color: '#1e40af', bg: 'bg-gris-bg' },
  { data: seleccion, title: 'Selección', href: '/categoria/seleccion', color: '#15803d', bg: 'bg-white' },
  { data: softbol, title: 'Softbol', href: '/categoria/softbol', color: '#7c3aed', bg: 'bg-gris-bg' },
  { data: juvenil, title: 'Juvenil', href: '/categoria/juvenil', color: '#ea580c', bg: 'bg-white' },
  { data: opinion, title: 'Opinión', href: '/categoria/opinion', color: '#92400e', bg: 'bg-gris-bg' },
];
---

<BaseLayout>
  <QuickHitsBar hits={quickHits} />

  {/* Active Event Banner */}
  {eventoActivo && (
    <a href={`/evento/${eventoActivo.slug}`} class="block bg-rojo hover:bg-rojo-dark transition-colors">
      <div class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between gap-4">
        <div class="flex items-center gap-3 min-w-0">
          <span class="bg-white/20 text-white text-[10px] font-bold uppercase px-2 py-1 rounded-sm tracking-wider flex-shrink-0">
            Evento
          </span>
          <span class="text-white font-bold text-sm truncate">
            {eventoActivo.nombre}
          </span>
          {eventoActivo.ciudad && (
            <span class="text-white/70 text-xs hidden sm:inline flex-shrink-0">
              {eventoActivo.ciudad}
            </span>
          )}
        </div>
        <span class="text-white/90 text-xs font-semibold flex-shrink-0 whitespace-nowrap">
          Ver cobertura &rarr;
        </span>
      </div>
    </a>
  )}

  <!-- Hero Section -->
  <div class="max-w-7xl mx-auto px-4 py-8">
    <section class="mb-12">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-5 lg:grid-rows-1">
        <!-- Main Hero (60%) -->
        <div class="lg:col-span-3 h-full">
          {hero && <HeroArticle article={hero} />}
        </div>
        <!-- Secondary (40%) -->
        <div class="lg:col-span-2 flex flex-col gap-5">
          {secondary.map((a) => (
            <article class="group relative rounded-xl overflow-hidden flex-1 min-h-[200px] shadow-sm hover:shadow-lg transition-all duration-300">
              <a href={`/articulo/${a.slug}`} class="block h-full">
                <img src={a.imagen_url} alt={a.titulo} loading="eager" class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-500" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/30 to-transparent"></div>
                <div class="absolute bottom-0 left-0 right-0 p-5">
                  {a.categoria && (
                    <span class="inline-block text-[10px] font-bold uppercase tracking-wider text-white/90 mb-1.5">{a.categoria.nombre}</span>
                  )}
                  <h3 class="text-white text-sm md:text-base font-bold line-clamp-2 leading-snug group-hover:text-white/90 transition-colors">
                    {a.titulo}
                  </h3>
                </div>
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>
  </div>

  <!-- Category Sections + Sticky Sidebar -->
  <div class="max-w-7xl mx-auto px-4">
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_350px] gap-8">
      <!-- Left column: ALL category sections -->
      <div>
        {categorySections.map((section) => (
          section.data.length > 0 && (
            <section class:list={[section.bg, 'py-12 -mx-4 px-4']}>
              <SectionTitle title={section.title} href={section.href} color={section.color} />
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                {section.data.map((a, i) => (
                  <ArticleCard article={a} eager={i < 2} />
                ))}
              </div>
            </section>
          )
        ))}
      </div>

      <!-- Right column: ONE sticky sidebar (desktop only) -->
      <aside class="hidden lg:block">
        <div class="sticky top-20 space-y-6 py-12">
          <MostReadWidget articles={masLeidos} />
          {videos.length > 0 && (
            <div class="bg-gris-bg rounded-lg p-4">
              <h3 class="text-sm font-bold uppercase tracking-wider text-navy mb-3 pb-2 border-b border-gris-border">
                Videos
              </h3>
              <div class="space-y-3">
                {videos.map((v) => (
                  <a href={`/video/${v.slug}`} class="flex gap-3 group">
                    <img
                      src={v.thumbnail_url || `https://img.youtube.com/vi/${v.youtube_id}/mqdefault.jpg`}
                      alt={v.titulo}
                      loading="lazy"
                      class="w-24 h-16 object-cover rounded flex-shrink-0"
                    />
                    <div class="flex-1 min-w-0">
                      <h4 class="text-sm font-medium text-navy line-clamp-2 group-hover:text-steel-blue transition-colors">
                        {v.titulo}
                      </h4>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          )}
        </div>
      </aside>
    </div>
  </div>

  <!-- Mobile Sidebar — only on mobile, after all sections -->
  <div class="lg:hidden max-w-7xl mx-auto px-4 py-8 space-y-6">
    <MostReadWidget articles={masLeidos} />
    {videos.length > 0 && (
      <div class="bg-gris-bg rounded-lg p-4">
        <h3 class="text-sm font-bold uppercase tracking-wider text-navy mb-3 pb-2 border-b border-gris-border">
          Videos
        </h3>
        <div class="space-y-3">
          {videos.map((v) => (
            <a href={`/video/${v.slug}`} class="flex gap-3 group">
              <img
                src={v.thumbnail_url || `https://img.youtube.com/vi/${v.youtube_id}/mqdefault.jpg`}
                alt={v.titulo}
                loading="lazy"
                class="w-24 h-16 object-cover rounded flex-shrink-0"
              />
              <div class="flex-1 min-w-0">
                <h4 class="text-sm font-medium text-navy line-clamp-2 group-hover:text-steel-blue transition-colors">
                  {v.titulo}
                </h4>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}
  </div>
</BaseLayout>
