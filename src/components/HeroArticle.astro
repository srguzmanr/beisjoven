---
import { timeAgo } from '@/lib/content';
import type { Articulo } from '@/lib/supabase';

interface Props {
  article: Articulo;
}

const { article } = Astro.props;
const href = `/articulo/${article.slug}`;
const date = article.fecha ? timeAgo(article.fecha) : '';

const KNOWN_SLUGS = new Set(['mlb', 'liga-mexicana', 'seleccion', 'softbol', 'juvenil', 'opinion']);
const catSlug = article.categoria?.slug ?? '';
const catBg = KNOWN_SLUGS.has(catSlug) ? `var(--cat-${catSlug})` : 'var(--navy)';
// Juvenil gold fails WCAG AA against white text — carve out to navy text.
const catFg = catSlug === 'juvenil' ? 'var(--navy)' : '#fff';
---

<article class="group relative rounded-xl overflow-hidden shadow-sm hover:shadow-lg transition-shadow duration-300 h-full lg:min-h-[420px]">
  <a href={href} class="block relative h-full">
    <div class="aspect-[4/3] lg:aspect-auto lg:absolute lg:inset-0">
      <img
        src={article.imagen_url}
        alt={article.titulo}
        loading="eager"
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
      />
    </div>
    <!-- Gradient overlay — concentrated at bottom 60% for legibility -->
    <div class="absolute inset-0 pointer-events-none" style="background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.6) 35%, rgba(0,0,0,0.15) 60%, transparent 100%);"></div>

    <!-- Content overlay -->
    <div class="absolute bottom-0 left-0 right-0 p-5 md:p-8 pointer-events-none">
      {article.categoria && (
        <span class="inline-block text-[11px] font-bold uppercase tracking-widest rounded-sm px-2.5 py-1" style={`letter-spacing: 0.05em; background: ${catBg}; color: ${catFg};`}>
          {article.categoria.nombre}
        </span>
      )}
      <h2 class="text-white text-xl md:text-3xl lg:text-4xl font-extrabold mt-2 mb-2 line-clamp-3 leading-tight" style="letter-spacing: -0.02em; text-shadow: 0 2px 8px rgba(0,0,0,0.6);">
        {article.titulo}
      </h2>
      {article.extracto && (
        <p class="text-white/80 text-sm md:text-base line-clamp-2 mb-3 max-w-2xl">
          {article.extracto}
        </p>
      )}
      <div class="flex items-center gap-2 text-xs md:text-sm text-white/60">
        {article.autor && <span class="font-medium text-white/80">{article.autor.nombre}</span>}
        <span>&middot;</span>
        <span>{date}</span>
      </div>
    </div>
  </a>
</article>
