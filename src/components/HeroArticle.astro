---
import { timeAgo } from '@/lib/content';
import type { Articulo } from '@/lib/supabase';
import { getCategoryAccent } from '@/lib/categoryAccents.js';

interface Props {
  article: Articulo;
  secondaries?: Articulo[];
}

const { article, secondaries = [] } = Astro.props;
const href = `/articulo/${article.slug}`;
const date = article.fecha ? timeAgo(article.fecha) : '';
const accent = getCategoryAccent(article.categoria?.slug);
const catSlug = article.categoria?.slug ?? '';
// Juvenil gold fails WCAG AA on white — use navy text for the pill only
const pillFg = catSlug === 'juvenil' ? 'var(--navy)' : '#fff';
---

<div class="bj-hero-wrap">
  <!-- Lead story -->
  <article class="bj-hero-lead group" style={`--accent:${accent};`}>
    <a href={href} class="block relative h-full overflow-hidden" aria-label={article.titulo}>
      <div class="bj-hero-lead__media">
        {article.imagen_url ? (
          <img
            src={article.imagen_url}
            alt={article.imagen_portada_alt || article.titulo}
            loading="eager"
            fetchpriority="high"
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
          />
        ) : (
          <div class="w-full h-full ph"></div>
        )}
      </div>
      <!-- Gradient overlay -->
      <div class="bj-hero-lead__gradient" aria-hidden="true"></div>
      <!-- Content overlay -->
      <div class="bj-hero-lead__content">
        {article.categoria && (
          <span class="bj-hero-lead__pill" style={`background:${accent};color:${pillFg};`}>
            {article.categoria.nombre}
          </span>
        )}
        <h1 class="bj-hero-lead__title">{article.titulo}</h1>
        {article.extracto && (
          <p class="bj-hero-lead__deck">{article.extracto}</p>
        )}
        <div class="bj-hero-lead__meta">
          {article.autor && (
            <span class="font-semibold text-white/90">{article.autor.nombre}</span>
          )}
          {article.autor && <span class="text-white/50" aria-hidden="true">&middot;</span>}
          <span class="text-white/60">{date}</span>
          {article.read_time_minutes && (
            <>
              <span class="text-white/50" aria-hidden="true">&middot;</span>
              <span class="text-white/60">{article.read_time_minutes} min</span>
            </>
          )}
        </div>
      </div>
      {article.photo_credit && (
        <span class="bj-hero-lead__credit">Foto: {article.photo_credit}</span>
      )}
    </a>
    <!-- Category accent bar at top -->
    <span class="absolute inset-x-0 top-0 h-1 z-10" style={`background:${accent};`}></span>
  </article>

  <!-- Secondary stories grid (optional) -->
  {secondaries.length > 0 && (
    <div class="bj-hero-secondaries">
      {secondaries.map((s) => {
        const sAccent = getCategoryAccent(s.categoria?.slug);
        const sCatSlug = s.categoria?.slug ?? '';
        const sPillFg = sCatSlug === 'juvenil' ? 'var(--navy)' : '#fff';
        return (
          <article class="bj-hero-sec group" style={`--accent:${sAccent};`}>
            <a href={`/articulo/${s.slug}`} class="block relative overflow-hidden h-full" aria-label={s.titulo}>
              <div class="bj-hero-sec__media">
                {s.imagen_url ? (
                  <img
                    src={s.imagen_url}
                    alt={s.imagen_portada_alt || s.titulo}
                    loading="eager"
                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                  />
                ) : (
                  <div class="w-full h-full ph"></div>
                )}
              </div>
              <div class="bj-hero-sec__gradient" aria-hidden="true"></div>
              <div class="bj-hero-sec__content">
                {s.categoria && (
                  <span class="bj-hero-sec__pill" style={`background:${sAccent};color:${sPillFg};`}>
                    {s.categoria.nombre}
                  </span>
                )}
                <h2 class="bj-hero-sec__title">{s.titulo}</h2>
              </div>
              <span class="absolute inset-x-0 top-0 h-0.5 z-10" style={`background:${sAccent};`}></span>
            </a>
          </article>
        );
      })}
    </div>
  )}
</div>

<style>
  .bj-hero-wrap {
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
  }

  @media (min-width: 1024px) {
    .bj-hero-wrap {
      grid-template-columns: 1.65fr 1fr;
      gap: 20px;
    }
  }

  /* Lead */
  .bj-hero-lead {
    position: relative;
    border-radius: var(--radius-lg, 16px);
    overflow: hidden;
    box-shadow: var(--shadow-md);
  }

  .bj-hero-lead__media {
    aspect-ratio: 4 / 5;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .bj-hero-lead__media {
      aspect-ratio: 16 / 9;
    }
  }

  @media (min-width: 1024px) {
    .bj-hero-lead__media {
      aspect-ratio: auto;
      position: absolute;
      inset: 0;
      min-height: 520px;
    }
    .bj-hero-lead {
      min-height: 520px;
    }
  }

  .bj-hero-lead__gradient {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background: linear-gradient(
      to top,
      rgba(10, 20, 45, 0.92) 0%,
      rgba(10, 20, 45, 0.55) 30%,
      rgba(10, 20, 45, 0.1) 60%,
      transparent 100%
    );
  }

  .bj-hero-lead__content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 2;
    padding: 24px 20px;
    pointer-events: none;
  }

  @media (min-width: 768px) {
    .bj-hero-lead__content {
      padding: 36px 36px;
    }
  }

  .bj-hero-lead__pill {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 3px;
    line-height: 1;
    margin-bottom: 12px;
  }

  .bj-hero-lead__title {
    font-family: var(--font-heading);
    font-weight: 800;
    letter-spacing: -0.025em;
    color: #fff;
    text-wrap: balance;
    margin: 0 0 10px;
    line-height: 1.12;
    font-size: clamp(1.625rem, 1.3rem + 1.6vw, 2.625rem);
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.4);
  }

  .bj-hero-lead__deck {
    font-family: var(--font-body);
    font-size: clamp(0.875rem, 0.85rem + 0.12vw, 1rem);
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.78);
    margin: 0 0 12px;
    max-width: 52ch;
  }

  .bj-hero-lead__meta {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
    font-family: var(--font-body);
    font-size: 12px;
  }

  .bj-hero-lead__credit {
    position: absolute;
    right: 10px;
    bottom: 10px;
    z-index: 3;
    color: rgba(255, 255, 255, 0.7);
    background: rgba(0, 0, 0, 0.5);
    font-family: var(--font-body);
    font-size: 10px;
    padding: 3px 7px;
    border-radius: 3px;
  }

  /* Secondaries */
  .bj-hero-secondaries {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  @media (min-width: 1024px) {
    .bj-hero-secondaries {
      grid-template-columns: 1fr;
      gap: 16px;
    }
  }

  .bj-hero-sec {
    position: relative;
    border-radius: var(--radius, 10px);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
  }

  .bj-hero-sec__media {
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }

  @media (min-width: 1024px) {
    .bj-hero-sec__media {
      aspect-ratio: auto;
      position: absolute;
      inset: 0;
      min-height: 140px;
    }
    .bj-hero-sec {
      min-height: 140px;
    }
  }

  .bj-hero-sec__gradient {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background: linear-gradient(
      to top,
      rgba(10, 20, 45, 0.88) 0%,
      rgba(10, 20, 45, 0.4) 50%,
      transparent 100%
    );
  }

  .bj-hero-sec__content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 2;
    padding: 12px 14px;
    pointer-events: none;
  }

  .bj-hero-sec__pill {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 9px;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 3px 8px;
    border-radius: 2px;
    line-height: 1;
    margin-bottom: 7px;
  }

  .bj-hero-sec__title {
    font-family: var(--font-heading);
    font-weight: 700;
    letter-spacing: -0.015em;
    color: #fff;
    text-wrap: balance;
    margin: 0;
    line-height: 1.2;
    font-size: clamp(0.875rem, 0.82rem + 0.28vw, 1.0625rem);
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.4);
  }
</style>
