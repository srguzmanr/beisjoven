---
import { getCategorias, getArticuloBySlug } from '@/lib/supabase';
import SearchOverlay from '@/components/SearchOverlay.astro';
import Logo from '@/components/Logo.astro';

const currentPath = Astro.url.pathname;

// Hardcoded chip order (not DB-driven). Names/slugs come from categorias rows.
const CHIP_ORDER = ['mlb', 'liga-mexicana', 'seleccion', 'juvenil', 'softbol', 'opinion'];
// Pills that collapse into the "Más" dropdown below 1100px.
const COLLAPSE_SLUGS = new Set(['softbol', 'opinion']);
// Short labels for the mobile chip rail (per HEADER-FIX-01 spec).
const MOBILE_SHORT_LABELS: Record<string, string> = {
  'mlb': 'MLB',
  'liga-mexicana': 'Ligas MX',
  'seleccion': 'Selección',
  'juvenil': 'Juvenil',
  'softbol': 'Softbol',
  'opinion': 'Opinión',
};

const categorias = await getCategorias();
const bySlug = new Map(categorias.map((c) => [c.slug, c]));
const chips = CHIP_ORDER
  .map((slug) => bySlug.get(slug))
  .filter((c): c is NonNullable<typeof c> => Boolean(c));

const isHomeActive = currentPath === '/' || currentPath === '';

let activeCategorySlug: string | null = null;
const categoriaMatch = currentPath.match(/^\/categoria\/([^/]+)/);
if (categoriaMatch) {
  activeCategorySlug = categoriaMatch[1];
} else if (currentPath.startsWith('/articulo/')) {
  const articleSlug = currentPath.replace(/^\/articulo\//, '').replace(/\/$/, '');
  if (articleSlug) {
    try {
      const articulo = await getArticuloBySlug(articleSlug);
      if (articulo?.categoria?.slug) {
        activeCategorySlug = articulo.categoria.slug;
      }
    } catch (err) {
      console.error('[Header] failed to resolve active category for article:', err);
    }
  }
}

const collapsedItems = chips.filter((c) => COLLAPSE_SLUGS.has(c.slug));
const moreHasActive = activeCategorySlug !== null && COLLAPSE_SLUGS.has(activeCategorySlug);
const isCategoryActive = (slug: string) => activeCategorySlug === slug;
---

<header id="site-header" class="site-header">
  <div class="site-header__bar">
    <a href="/" class="site-header__logo" aria-label="Beisjoven — Inicio">
      <Logo class="site-header__logo--mobile" format="mark" height={40} width={40} />
      <Logo class="site-header__logo--desktop" format="lockup" height={40} />
    </a>

    <nav class="site-header__nav-desktop" aria-label="Navegación principal">
      <a
        href="/"
        class="nav-pill"
        data-nav="inicio"
        aria-current={isHomeActive ? 'page' : undefined}
      >
        Inicio
      </a>
      {chips.map((c) => (
        <a
          href={`/categoria/${c.slug}`}
          class="nav-pill"
          data-category={c.slug}
          data-collapse={COLLAPSE_SLUGS.has(c.slug) ? 'true' : undefined}
          aria-current={isCategoryActive(c.slug) ? 'page' : undefined}
        >
          {c.nombre}
        </a>
      ))}

      <div class="nav-more" data-has-active={moreHasActive ? 'true' : undefined}>
        <button
          id="nav-more-trigger"
          class="nav-pill nav-pill--more"
          type="button"
          aria-haspopup="menu"
          aria-expanded="false"
          aria-controls="nav-more-panel"
        >
          Más <span class="nav-more__caret" aria-hidden="true">▾</span>
        </button>
        <div
          id="nav-more-panel"
          class="nav-more__panel"
          role="menu"
          aria-labelledby="nav-more-trigger"
          hidden
        >
          {collapsedItems.map((c) => (
            <a
              href={`/categoria/${c.slug}`}
              class="nav-more__item"
              role="menuitem"
              data-category={c.slug}
              aria-current={isCategoryActive(c.slug) ? 'page' : undefined}
            >
              {c.nombre}
            </a>
          ))}
        </div>
      </div>
    </nav>

    <div class="site-header__actions">
      <a class="header-cta" href="/tu-historia" aria-label="Comparte tu historia con Beisjoven">
        <svg class="header-cta__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 20h9" />
          <path d="M16.5 3.5a2.121 2.121 0 1 1 3 3L7 19l-4 1 1-4 12.5-12.5z" />
        </svg>
        <span class="header-cta__label">Cuéntanos</span>
      </a>
      <button
        id="search-trigger"
        class="site-header__search"
        type="button"
        aria-label="Buscar"
        aria-expanded="false"
        aria-controls="search-overlay"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="11" cy="11" r="7" />
          <path d="M21 21l-4.35-4.35" stroke-linecap="round" />
        </svg>
      </button>
    </div>
  </div>

  <nav class="site-header__chips-mobile" aria-label="Categorías">
    <div class="site-header__chips-scroll">
      <ul class="site-header__chips-list">
        <li class="chip-item">
          <a
            href="/"
            class="chip-link"
            data-active={isHomeActive ? 'true' : 'false'}
            aria-current={isHomeActive ? 'page' : undefined}
          >Inicio</a>
        </li>
        {chips.map((c) => (
          <li class="chip-item">
            <a
              href={`/categoria/${c.slug}`}
              class="chip-link"
              data-category={c.slug}
              data-active={isCategoryActive(c.slug) ? 'true' : 'false'}
              aria-current={isCategoryActive(c.slug) ? 'page' : undefined}
            >{MOBILE_SHORT_LABELS[c.slug] ?? c.nombre}</a>
          </li>
        ))}
      </ul>
    </div>
  </nav>
</header>

<SearchOverlay categorias={chips} />

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: #ffffff;
    border-bottom: 1px solid #F1F1F3;
    transition: transform 200ms ease-out;
    will-change: transform;
  }
  .site-header.is-hidden { transform: translateY(-100%); }

  .site-header__bar {
    display: flex;
    align-items: center;
    gap: 8px;
    height: 52px;
    padding: 0 8px 0 16px;
    max-width: var(--max-width-container, 75rem);
    margin: 0 auto;
  }

  .site-header__logo {
    display: flex;
    align-items: center;
    margin-right: auto;
    text-decoration: none;
  }
  .site-header__logo img { width: auto; }
  .site-header__logo--mobile { display: block; height: 40px; max-height: 40px; }
  .site-header__logo--desktop { display: none; }

  .site-header__nav-desktop { display: none; }

  .site-header__actions {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 8px;
  }

  .header-cta {
    display: none;
    align-items: center;
    gap: 6px;
    padding: 7px 14px;
    border: 1px solid var(--red, #C8102E);
    border-radius: 999px;
    font-family: var(--font-body, "Inter"), system-ui, sans-serif;
    font-size: 13px;
    font-weight: 600;
    line-height: 1;
    letter-spacing: 0.02em;
    color: var(--red, #C8102E);
    text-decoration: none;
    transition: background-color 120ms ease, color 120ms ease;
    white-space: nowrap;
  }
  .header-cta:hover {
    background: var(--red, #C8102E);
    color: #ffffff;
  }
  .header-cta:focus-visible {
    outline: none;
    box-shadow: 0 0 0 3px rgba(212, 168, 67, 0.35);
  }
  .header-cta__icon {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
  }

  .site-header__search {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    margin: 0;
    padding: 0;
    background: transparent;
    border: 0;
    border-radius: 8px;
    color: var(--navy, #1B2A4A);
    cursor: pointer;
    transition: background-color 120ms ease-out;
  }
  .site-header__search:hover,
  .site-header__search:focus-visible {
    background-color: rgba(27, 42, 74, 0.06);
    outline: none;
  }
  .site-header__search svg { width: 20px; height: 20px; }

  /* Mobile chips row — flat nav-text with 2px underline indicator (HEADER-FIX-01) */
  .site-header__chips-mobile {
    position: relative;
    background: #ffffff;
    border-bottom: 1px solid var(--rule, #F1F1F3);
  }
  .site-header__chips-scroll {
    overflow-x: auto;
    overflow-y: hidden;
    scrollbar-width: none;
    -ms-overflow-style: none;
    -webkit-overflow-scrolling: touch;
  }
  .site-header__chips-scroll::-webkit-scrollbar { display: none; }
  .site-header__chips-list {
    list-style: none;
    margin: 0;
    padding: 10px 28px 10px 16px;
    display: flex;
    gap: 20px;
    white-space: nowrap;
  }
  .chip-item {
    flex: 0 0 auto;
    position: relative;
  }
  .chip-link {
    display: inline-block;
    padding-bottom: 5px;
    color: var(--ink-2, #3A4660);
    font-family: var(--font-body, "Inter"), system-ui, sans-serif;
    font-size: 0.875rem;
    line-height: 1.4;
    font-weight: 500;
    letter-spacing: 0.01em;
    text-transform: uppercase;
    text-decoration: none;
    transition: color 120ms ease-out;
  }
  .chip-link:focus-visible {
    outline: 2px solid var(--navy, #1B2A4A);
    outline-offset: 2px;
  }
  .chip-link[data-active="true"] {
    color: var(--navy, #1B2A4A);
    font-weight: 700;
  }
  .chip-link[data-active="true"]::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 2px;
    background: var(--cat-color, var(--red, #C8102E));
  }
  .chip-link[data-category="mlb"][data-active="true"]           { --cat-color: var(--cat-mlb); }
  .chip-link[data-category="liga-mexicana"][data-active="true"] { --cat-color: var(--cat-liga-mexicana); }
  .chip-link[data-category="seleccion"][data-active="true"]     { --cat-color: var(--cat-seleccion); }
  .chip-link[data-category="juvenil"][data-active="true"]       { --cat-color: var(--cat-juvenil); }
  .chip-link[data-category="softbol"][data-active="true"]       { --cat-color: var(--cat-softbol); }
  .chip-link[data-category="opinion"][data-active="true"]       { --cat-color: var(--cat-opinion); }
  .site-header__chips-mobile::after {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    width: 32px;
    height: 100%;
    pointer-events: none;
    background: linear-gradient(to right, transparent, #ffffff);
  }

  /* Desktop (>= 1024px): nav row + scroll border. Below this, mobile pattern (logo mark + underline chips) applies. */
  @media (min-width: 1024px) {
    .site-header {
      border-bottom: 2px solid transparent;
      transition: border-color 150ms ease-out, transform 200ms ease-out;
    }
    .site-header[data-scrolled="true"] {
      border-bottom-color: var(--navy, #1B2A4A);
    }

    .site-header__bar {
      height: 64px;
      padding: 0 24px;
      gap: 24px;
      transition: height 200ms ease-out;
    }
    .site-header.is-compact .site-header__bar { height: 48px; }

    .site-header__logo { margin-right: 0; }
    .site-header__logo--mobile { display: none; }
    .site-header__logo--desktop {
      display: block;
      max-height: 40px;
      transition: max-height 200ms ease-out;
    }
    .site-header.is-compact .site-header__logo--desktop { max-height: 28px; }

    .site-header__nav-desktop {
      display: flex;
      flex: 1;
      gap: 6px;
      justify-content: center;
      align-items: center;
      flex-wrap: nowrap;
    }

    .site-header__chips-mobile { display: none; }

    .site-header__actions {
      min-width: 72px;
    }

    .header-cta { display: inline-flex; }

    /* Nav pill — desktop primary nav */
    .nav-pill {
      display: inline-flex;
      align-items: center;
      flex-shrink: 0;
      padding: 7px 16px;
      border: 1px solid var(--rule-strong, rgba(27, 42, 74, 0.28));
      border-radius: 999px;
      background: transparent;
      color: var(--ink, var(--navy, #1B2A4A));
      font-family: var(--font-body, "Inter"), system-ui, sans-serif;
      font-size: 13px;
      font-weight: 600;
      line-height: 1;
      letter-spacing: 0.02em;
      text-transform: none;
      text-decoration: none;
      white-space: nowrap;
      cursor: pointer;
      transition:
        background-color 120ms ease-out,
        color 120ms ease-out,
        border-color 120ms ease-out;
    }
    .nav-pill:hover {
      border-color: var(--navy, #1B2A4A);
      color: var(--navy, #1B2A4A);
    }
    .nav-pill:focus-visible {
      outline: 2px solid var(--navy, #1B2A4A);
      outline-offset: 2px;
    }
    .nav-pill[aria-current="page"] {
      background: var(--cat-color, var(--navy, #1B2A4A));
      color: #ffffff;
      border-color: transparent;
    }
    .nav-pill[aria-current="page"][data-category="mlb"]           { --cat-color: var(--cat-mlb); }
    .nav-pill[aria-current="page"][data-category="liga-mexicana"] { --cat-color: var(--cat-liga-mexicana); }
    .nav-pill[aria-current="page"][data-category="seleccion"]     { --cat-color: var(--cat-seleccion); }
    .nav-pill[aria-current="page"][data-category="juvenil"]       { --cat-color: var(--cat-juvenil); }
    .nav-pill[aria-current="page"][data-category="softbol"]       { --cat-color: var(--cat-softbol); }
    .nav-pill[aria-current="page"][data-category="opinion"]       { --cat-color: var(--cat-opinion); }

    /* "Más" dropdown */
    .nav-more {
      position: relative;
      display: none;
    }
    .nav-more[data-has-active="true"] .nav-pill--more {
      border-color: var(--navy, #1B2A4A);
      color: var(--navy, #1B2A4A);
    }
    .nav-more__caret {
      margin-left: 4px;
      font-size: 0.75em;
    }
    .nav-more__panel {
      position: absolute;
      top: calc(100% + 4px);
      right: 0;
      min-width: 180px;
      padding: 8px 0;
      background: #ffffff;
      border: 1px solid var(--rule-strong, rgba(27, 42, 74, 0.28));
      border-radius: 10px;
      box-shadow: 0 8px 24px rgba(15, 23, 42, 0.10);
      z-index: 60;
    }
    .nav-more__panel[hidden] { display: none; }
    .nav-more__item {
      display: block;
      padding: 10px 14px;
      color: var(--ink, var(--navy, #1B2A4A));
      font-family: var(--font-body, "Inter"), system-ui, sans-serif;
      font-size: 14px;
      font-weight: 600;
      line-height: 1.3;
      text-decoration: none;
      transition: background-color 120ms ease-out;
    }
    .nav-more__item:hover,
    .nav-more__item:focus-visible {
      background: var(--surface-tinted, #F6F5F1);
      outline: none;
    }
    .nav-more__item[aria-current="page"] {
      color: var(--navy, #1B2A4A);
      background: var(--surface-tinted, #F6F5F1);
    }
  }

  /* Narrow desktop (1024–1099): collapse Softbol + Opinión into "Más" */
  @media (min-width: 1024px) and (max-width: 1099px) {
    .site-header__nav-desktop .nav-pill[data-collapse="true"] { display: none; }
    .nav-more { display: block; }
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>

<script is:inline>
  (() => {
    const header = document.getElementById('site-header');
    const moreTrigger = document.getElementById('nav-more-trigger');
    const morePanel = document.getElementById('nav-more-panel');

    if (header) {
      const COMPACT_THRESHOLD = 80;
      const SCROLL_BORDER_THRESHOLD = 40;
      const desktopMql = window.matchMedia('(min-width: 1024px)');
      let lastY = window.scrollY;
      let ticking = false;

      function onScroll() {
        const y = window.scrollY;
        const isDesktop = desktopMql.matches;

        if (y > SCROLL_BORDER_THRESHOLD) {
          header.setAttribute('data-scrolled', 'true');
        } else {
          header.removeAttribute('data-scrolled');
        }

        if (y <= COMPACT_THRESHOLD) {
          header.classList.remove('is-hidden');
          header.classList.remove('is-compact');
        } else if (isDesktop) {
          header.classList.add('is-compact');
          header.classList.remove('is-hidden');
        } else {
          header.classList.remove('is-compact');
          if (y > lastY) {
            header.classList.add('is-hidden');
          } else {
            header.classList.remove('is-hidden');
          }
        }
        lastY = y;
        ticking = false;
      }

      window.addEventListener('scroll', () => {
        if (!ticking) {
          window.requestAnimationFrame(onScroll);
          ticking = true;
        }
      }, { passive: true });

      onScroll();
    }

    if (moreTrigger && morePanel) {
      let isOpen = false;

      const openMenu = () => {
        isOpen = true;
        morePanel.hidden = false;
        moreTrigger.setAttribute('aria-expanded', 'true');
      };
      const closeMenu = () => {
        isOpen = false;
        morePanel.hidden = true;
        moreTrigger.setAttribute('aria-expanded', 'false');
      };

      try {
        moreTrigger.addEventListener('click', (e) => {
          e.stopPropagation();
          if (isOpen) closeMenu(); else openMenu();
        });

        document.addEventListener('click', (e) => {
          if (!isOpen) return;
          const target = e.target;
          if (!(target instanceof Node)) return;
          if (morePanel.contains(target) || moreTrigger.contains(target)) return;
          closeMenu();
        });

        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && isOpen) {
            closeMenu();
            moreTrigger.focus();
          }
        });

        morePanel.addEventListener('click', (e) => {
          const target = e.target;
          if (target instanceof Element && target.closest('a[role="menuitem"]')) {
            closeMenu();
          }
        });
      } catch (err) {
        console.error('[Header] more-menu init failed:', err);
      }
    }
  })();
</script>
