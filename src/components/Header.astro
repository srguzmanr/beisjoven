---
import { getCategorias, getArticuloBySlug } from '@/lib/supabase';
import SearchOverlay from '@/components/SearchOverlay.astro';
import Logo from '@/components/Logo.astro';

const currentPath = Astro.url.pathname;

// Hardcoded nav order (not DB-driven). Names/slugs come from categorias rows.
const NAV_ORDER = ['mlb', 'liga-mexicana', 'seleccion', 'juvenil', 'softbol', 'opinion'];
// Short labels for the mobile tab rail.
const MOBILE_SHORT_LABELS: Record<string, string> = {
  'mlb': 'MLB',
  'liga-mexicana': 'Ligas MX',
  'seleccion': 'Selección',
  'juvenil': 'Juvenil',
  'softbol': 'Softbol',
  'opinion': 'Opinión',
};

const categorias = await getCategorias();
const bySlug = new Map(categorias.map((c) => [c.slug, c]));
const navItems = NAV_ORDER
  .map((slug) => bySlug.get(slug))
  .filter((c): c is NonNullable<typeof c> => Boolean(c));

const isHomeActive = currentPath === '/' || currentPath === '';

let activeCategorySlug: string | null = null;
const categoriaMatch = currentPath.match(/^\/categoria\/([^/]+)/);
if (categoriaMatch) {
  activeCategorySlug = categoriaMatch[1];
} else if (currentPath.startsWith('/articulo/')) {
  const articleSlug = currentPath.replace(/^\/articulo\//, '').replace(/\/$/, '');
  if (articleSlug) {
    try {
      const articulo = await getArticuloBySlug(articleSlug);
      if (articulo?.categoria?.slug) {
        activeCategorySlug = articulo.categoria.slug;
      }
    } catch (err) {
      console.error('[Header] failed to resolve active category for article:', err);
    }
  }
}

const isCategoryActive = (slug: string) => activeCategorySlug === slug;
---

<header id="site-header" class="site-header">
  <div class="site-header__frame">
    <div class="site-header__surface">
      <div class="site-header__bar">
        <a href="/" class="site-header__logo" aria-label="Beisjoven — Inicio">
          <span class="site-header__logo-mobile">
            <Logo format="lockup" height={46} width={98} class="logo-lockup-mobile-img" />
          </span>
          <span class="site-header__logo-desktop">
            <Logo format="lockup" height={50} width={106} class="logo-lockup-img" />
          </span>
        </a>

        <span class="site-header__divider" aria-hidden="true"></span>

        <nav class="site-header__nav" aria-label="Navegación principal">
          <ul class="site-header__nav-list">
            <li class="nav-item">
              <a
                href="/"
                class="nav-link"
                data-nav="inicio"
                aria-current={isHomeActive ? 'page' : undefined}
              >Inicio</a>
            </li>
            {navItems.map((c) => (
              <li class="nav-item">
                <a
                  href={`/categoria/${c.slug}`}
                  class="nav-link"
                  data-category={c.slug}
                  aria-current={isCategoryActive(c.slug) ? 'page' : undefined}
                >{c.nombre}</a>
              </li>
            ))}
          </ul>
        </nav>

        <div class="site-header__actions">
          <a class="header-cta" href="/tu-historia" aria-label="Comparte tu historia con Beisjoven">
            <svg class="header-cta__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M12 20h9" />
              <path d="M16.5 3.5a2.121 2.121 0 1 1 3 3L7 19l-4 1 1-4 12.5-12.5z" />
            </svg>
            <span>Cuéntanos</span>
          </a>
          <button
            id="search-trigger"
            class="site-header__search"
            type="button"
            aria-label="Buscar"
            aria-expanded="false"
            aria-controls="search-overlay"
          >
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <circle cx="11" cy="11" r="7" />
              <path d="M21 21l-4.35-4.35" stroke-linecap="round" />
            </svg>
          </button>
        </div>
      </div>
    </div>
  </div>

  <nav class="site-header__tabs" aria-label="Categorías">
    <div class="site-header__tabs-scroll">
      <ul class="site-header__tabs-list">
        <li class="tab-item">
          <a
            href="/"
            class="tab"
            data-nav="inicio"
            aria-current={isHomeActive ? 'page' : undefined}
          >Inicio</a>
        </li>
        {navItems.map((c) => (
          <li class="tab-item">
            <a
              href={`/categoria/${c.slug}`}
              class="tab"
              data-category={c.slug}
              aria-current={isCategoryActive(c.slug) ? 'page' : undefined}
            >{MOBILE_SHORT_LABELS[c.slug] ?? c.nombre}</a>
          </li>
        ))}
        <li class="tab-item">
          <a href="/tu-historia" class="tab tab--cta">Cuéntanos</a>
        </li>
      </ul>
    </div>
    <span class="site-header__tabs-chevron" aria-hidden="true">›</span>
  </nav>

  <!--
    Punto de inserción Quick Hits / LIVE strip (bloqueado por SEC-03, RLS de quick_hits):
    cuando se habiliten, ambos van AQUÍ, inmediatamente después del nav de tabs y dentro
    del <header> para heredar el sticky/auto-hide. Orden vertical: LIVE strip arriba,
    Quick Hits debajo (Bible §3.0).
  -->
</header>

<SearchOverlay categorias={navItems} />

<style>
  /* ============================================================
     Header — HeaderDefault (DESIGN-HF-01 → HF-02)
     Móvil (<1024): barra 52px con lockup + tabs de texto
     scrolleables con underline activo (mismo lenguaje que el
     nav desktop). HF-02 supersede el "mark-only mobile" del
     Bible §3.0 (regla anterior al asset lockup limpio).
     Desktop (≥1024): barra única 64px — logo · divisor · nav
     inline con underline activo · Cuéntanos · búsqueda.
     ============================================================ */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    transition: transform 0.25s ease;
    will-change: transform;
  }
  .site-header.is-hidden { transform: translateY(-100%); }
  @media (prefers-reduced-motion: reduce) {
    .site-header { transition: none; }
  }

  /* El frame reserva la altura de layout de la barra; nunca cambia,
     así el shrink de sticky no produce CLS. */
  .site-header__frame {
    position: relative;
    height: 52px;
  }
  .site-header__surface {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 52px;
    background: #ffffff;
    border-bottom: 1px solid var(--rule);
  }
  .site-header__bar {
    display: flex;
    align-items: center;
    height: 100%;
    gap: 8px;
    padding: 0 8px 0 16px;
    max-width: var(--w-page);
    margin: 0 auto;
  }

  .site-header__logo {
    display: inline-flex;
    align-items: center;
    align-self: stretch; /* área táctil = alto completo de la barra (52px) */
    text-decoration: none;
  }
  .site-header__logo:focus-visible {
    outline: 2px solid var(--gold);
    outline-offset: 2px;
  }
  .site-header__logo-mobile { display: inline-flex; align-items: center; }
  .site-header__logo-desktop { display: none; }
  /* Lockup 1224×576 con aire transparente: el arte ocupa ~70% de la
     altura del PNG, así que 46px de imagen ≈ 32px de arte visual
     (mismo criterio que el desktop: 50px ≈ 35px visuales). */
  :global(.logo-lockup-mobile-img) { height: 46px; width: auto; }

  .site-header__divider { display: none; }
  .site-header__nav { display: none; }

  .site-header__actions {
    display: flex;
    align-items: center;
    margin-left: auto;
    flex-shrink: 0;
  }
  .header-cta { display: none; }

  .site-header__search {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    padding: 0;
    background: transparent;
    border: 0;
    border-radius: 2px;
    color: var(--navy);
    cursor: pointer;
    transition: background-color 120ms ease-out;
  }
  @media (hover: hover) and (pointer: fine) {
    .site-header__search:hover { background-color: rgba(27, 42, 74, 0.06); }
  }
  .site-header__search:active { background-color: rgba(27, 42, 74, 0.06); }
  .site-header__search:focus-visible {
    outline: 2px solid var(--gold);
    outline-offset: 2px;
  }
  .site-header__search svg { width: 22px; height: 22px; }

  /* --- Tabs móviles: texto + underline activo, scroll horizontal
     con snap, fade derecho y chevron de descubribilidad --- */
  .site-header__tabs {
    position: relative;
    background: #ffffff;
    border-bottom: 1px solid var(--rule);
  }
  .site-header__tabs-scroll {
    overflow-x: auto;
    overflow-y: hidden;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    scroll-snap-type: x proximity;
    scroll-padding-left: 4px;
  }
  .site-header__tabs-scroll::-webkit-scrollbar { display: none; }
  .site-header__tabs-list {
    list-style: none;
    margin: 0;
    /* Peek garantizado 40–60% (§6.4 → FIX): padding de tabs + gap
       calibrados con métricas reales de Inter para que "Juvenil" quede
       cortado ~50% a 375 y a 412 (medido en Playwright; el gap sube en
       la media query de abajo porque 37px más de viewport no bastan
       para mantener el corte con un layout único). */
    padding: 0 40px 0 4px;
    display: flex;
    gap: 4px;
    height: 44px;
    white-space: nowrap;
  }
  .tab-item {
    flex: 0 0 auto;
    position: relative;
    display: flex;
    align-items: center;
    scroll-snap-align: start;
  }
  .tab {
    display: flex;
    align-items: center;
    height: 100%;
    padding: 0 13px;
    color: var(--navy);
    font-family: var(--font-body);
    font-size: 13px;
    line-height: var(--lh-nav);
    font-weight: 600;
    letter-spacing: var(--tracking-nav);
    text-transform: uppercase;
    text-decoration: none;
  }
  .tab:focus-visible {
    outline: 2px solid var(--gold);
    outline-offset: -2px;
  }
  .tab:active { color: var(--red); }
  .tab[aria-current="page"] { font-weight: 700; }
  /* Underline activo: 2px en el acento de categoría, anclado al borde
     inferior de la fila (mismo patrón que el nav desktop). */
  .tab[aria-current="page"]::after {
    content: '';
    position: absolute;
    left: 13px;
    right: 13px;
    bottom: 0;
    height: 2px;
    background: var(--cat-color, var(--navy));
  }
  .tab[data-category="mlb"]           { --cat-color: var(--cat-mlb); }
  .tab[data-category="liga-mexicana"] { --cat-color: var(--cat-liga-mexicana); }
  .tab[data-category="seleccion"]     { --cat-color: var(--cat-seleccion); }
  .tab[data-category="juvenil"]       { --cat-color: var(--cat-juvenil); }
  .tab[data-category="softbol"]       { --cat-color: var(--cat-softbol); }
  .tab[data-category="opinion"]       { --cat-color: var(--cat-opinion); }
  .tab--cta {
    height: 32px;
    margin: 0 4px 0 8px;
    padding: 0 12px;
    border: 1px solid var(--red);
    border-radius: 2px;
    color: var(--red);
    font-weight: 600;
  }
  .tab--cta:active {
    background: var(--red);
    color: #ffffff;
  }
  @media (min-width: 400px) {
    .site-header__tabs-list { gap: 13px; }
  }
  .site-header__tabs::after {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    width: 32px;
    height: 100%;
    pointer-events: none;
    background: linear-gradient(to right, transparent, #ffffff 75%);
  }
  .site-header__tabs-chevron {
    position: absolute;
    top: 50%;
    right: 6px;
    transform: translateY(-50%);
    z-index: 1;
    color: var(--muted);
    font-size: 16px;
    line-height: 1;
    pointer-events: none;
    opacity: 1;
  }
  .site-header__tabs-chevron.is-faded { opacity: 0; }
  @media (prefers-reduced-motion: no-preference) {
    .site-header__tabs-chevron { transition: opacity 0.2s ease-out; }
    .tab { transition: color 0.15s ease-out; }
    .tab--cta { transition: color 0.15s ease-out, background-color 0.15s ease-out; }
  }

  /* --- Desktop ≥1024 --- */
  @media (min-width: 1024px) {
    .site-header__frame { height: 64px; }
    .site-header__surface {
      height: 64px;
      /* Shrink-on-sticky: la superficie es absoluta dentro del frame de
         altura fija, así que animar su height no mueve nada fuera del
         header (cero CLS). El contenido se re-centra solo por flex. */
      transition: height 0.25s ease;
    }
    .site-header.is-compact .site-header__surface { height: 48px; }
    @media (prefers-reduced-motion: reduce) {
      .site-header__surface { transition: none; }
    }

    .site-header__bar {
      gap: 28px;
      padding: 0 32px;
    }

    .site-header__logo-mobile { display: none; }
    .site-header__logo-desktop { display: inline-flex; align-items: center; }
    /* Lockup 1224×576 con aire transparente: el arte ocupa ~70% de la
       altura del PNG, así que 50px de imagen ≈ 35px de altura visual. */
    :global(.logo-lockup-img) {
      height: 50px;
      width: auto;
      transition: height 0.25s ease;
    }
    .site-header.is-compact :global(.logo-lockup-img) { height: 40px; }

    .site-header__divider {
      display: block;
      width: 1px;
      height: 24px;
      background: var(--rule);
      flex-shrink: 0;
    }

    .site-header__nav {
      display: flex;
      flex: 1;
      min-width: 0;
      align-self: stretch;
    }
    .site-header__nav-list {
      list-style: none;
      margin: 0;
      padding: 0;
      display: flex;
      gap: 20px; /* spec: 20–24px; 20 en desktop angosto para no invadir el CTA */
      align-items: stretch;
      flex-wrap: nowrap;
    }
    @media (min-width: 1200px) {
      .site-header__nav-list { gap: 24px; }
    }
    .nav-item {
      position: relative;
      display: flex;
      align-items: center;
    }
    .nav-link {
      display: flex;
      align-items: center;
      height: 100%;
      color: var(--navy);
      font-family: var(--font-body);
      font-size: var(--text-nav);
      line-height: var(--lh-nav);
      font-weight: 500;
      letter-spacing: var(--tracking-nav);
      text-transform: uppercase;
      text-decoration: none;
      white-space: nowrap;
      transition: color 120ms ease-out;
    }
    @media (hover: hover) and (pointer: fine) {
      .nav-link:hover { color: var(--red); }
    }
    .nav-link:active { color: var(--red); }
    .nav-link:focus-visible {
      outline: 2px solid var(--gold);
      outline-offset: 2px;
    }
    .nav-link[aria-current="page"] { font-weight: 700; }
    /* Underline activo: 2px en el acento de la categoría, anclado al
       borde inferior de la barra (el item se estira a toda la altura). */
    .nav-link[aria-current="page"]::after {
      content: '';
      position: absolute;
      left: 0;
      right: 0;
      bottom: 0;
      height: 2px;
      background: var(--cat-color, var(--navy));
    }
    .nav-link[data-category="mlb"]           { --cat-color: var(--cat-mlb); }
    .nav-link[data-category="liga-mexicana"] { --cat-color: var(--cat-liga-mexicana); }
    .nav-link[data-category="seleccion"]     { --cat-color: var(--cat-seleccion); }
    .nav-link[data-category="juvenil"]       { --cat-color: var(--cat-juvenil); }
    .nav-link[data-category="softbol"]       { --cat-color: var(--cat-softbol); }
    .nav-link[data-category="opinion"]       { --cat-color: var(--cat-opinion); }

    .site-header__actions { gap: 12px; margin-left: 0; }

    .header-cta {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      height: 40px;
      padding: 0 16px;
      border: 1px solid var(--red);
      border-radius: 2px;
      color: var(--red);
      font-family: var(--font-body);
      font-size: var(--text-button);
      line-height: var(--lh-button);
      font-weight: 600;
      letter-spacing: var(--tracking-button);
      text-decoration: none;
      white-space: nowrap;
      transition: background-color 120ms ease-out, color 120ms ease-out;
    }
    @media (hover: hover) and (pointer: fine) {
      .header-cta:hover {
        background: var(--red);
        color: #ffffff;
      }
    }
    .header-cta:active {
      background: var(--red);
      color: #ffffff;
    }
    .header-cta:focus-visible {
      outline: 2px solid var(--gold);
      outline-offset: 2px;
    }
    .header-cta__icon {
      /* Ícono opcional del spec: oculto en desktop angosto para dar aire al nav. */
      display: none;
      width: 16px;
      height: 16px;
      flex-shrink: 0;
    }
    @media (min-width: 1200px) {
      .header-cta__icon { display: block; }
    }

    .site-header__tabs { display: none; }
  }
</style>

<script is:inline>
  (() => {
    // --- Descubribilidad del nav móvil (DESIGN-HF-02) ---
    const scroller = document.querySelector('.site-header__tabs-scroll');
    if (scroller) {
      // Auto-scroll del tab activo: en páginas de categoría cuyo tab quede
      // fuera del viewport inicial, centrarlo ANTES de registrar el listener
      // del chevron (scroll programático ≠ scroll del usuario). Instantáneo,
      // sin smooth. En Inicio no aplica (ya visible).
      const active = scroller.querySelector('.tab[data-category][aria-current="page"]');
      if (active) {
        const sr = scroller.getBoundingClientRect();
        const ar = active.getBoundingClientRect();
        if (ar.right > sr.right || ar.left < sr.left) {
          scroller.scrollLeft += (ar.left - sr.left) - (sr.width - ar.width) / 2;
        }
      }
      // Chevron: se desvanece al primer scroll horizontal del usuario y no
      // reaparece en esa vista. Listener pasivo; el scroll programático de
      // arriba no lo dispara porque comparamos contra la posición base.
      const chevron = document.querySelector('.site-header__tabs-chevron');
      if (chevron) {
        const maxScroll = scroller.scrollWidth - scroller.clientWidth;
        if (scroller.scrollLeft >= maxScroll - 4) {
          // Ya no hay contenido a la derecha (p. ej. tras el auto-scroll):
          // el chevron no debe prometer más nav.
          chevron.classList.add('is-faded');
        } else {
          const base = scroller.scrollLeft;
          const onTabsScroll = () => {
            if (Math.abs(scroller.scrollLeft - base) < 4) return;
            chevron.classList.add('is-faded');
            scroller.removeEventListener('scroll', onTabsScroll);
          };
          scroller.addEventListener('scroll', onTabsScroll, { passive: true });
        }
      }
    }

    const header = document.getElementById('site-header');
    if (!header) return;

    const THRESHOLD = 80;
    const desktopMql = window.matchMedia('(min-width: 1024px)');
    let lastY = window.scrollY;
    let ticking = false;

    function onScroll() {
      const y = window.scrollY;

      if (y <= THRESHOLD) {
        header.classList.remove('is-hidden', 'is-compact');
      } else if (desktopMql.matches) {
        // Desktop: shrink a barra compacta, nunca se oculta.
        header.classList.add('is-compact');
        header.classList.remove('is-hidden');
      } else {
        // Móvil: auto-hide al bajar, reaparece al subir.
        header.classList.remove('is-compact');
        if (y > lastY) {
          header.classList.add('is-hidden');
        } else {
          header.classList.remove('is-hidden');
        }
      }
      lastY = y;
      ticking = false;
    }

    window.addEventListener('scroll', () => {
      if (!ticking) {
        window.requestAnimationFrame(onScroll);
        ticking = true;
      }
    }, { passive: true });

    onScroll();
  })();
</script>
