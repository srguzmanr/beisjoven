---
import { getCategorias, getArticuloBySlug } from '@/lib/supabase';

const currentPath = Astro.url.pathname;

// Hardcoded chip order (not DB-driven). Names/slugs come from categorias rows.
const CHIP_ORDER = ['mlb', 'liga-mexicana', 'seleccion', 'juvenil', 'softbol', 'opinion'];
// Pills that collapse into the "Más" dropdown below 1100px.
const COLLAPSE_SLUGS = new Set(['softbol', 'opinion']);

const categorias = await getCategorias();
const bySlug = new Map(categorias.map((c) => [c.slug, c]));
const chips = CHIP_ORDER
  .map((slug) => bySlug.get(slug))
  .filter((c): c is NonNullable<typeof c> => Boolean(c));

const isHomeActive = currentPath === '/' || currentPath === '';

let activeCategorySlug: string | null = null;
const categoriaMatch = currentPath.match(/^\/categoria\/([^/]+)/);
if (categoriaMatch) {
  activeCategorySlug = categoriaMatch[1];
} else if (currentPath.startsWith('/articulo/')) {
  const articleSlug = currentPath.replace(/^\/articulo\//, '').replace(/\/$/, '');
  if (articleSlug) {
    try {
      const articulo = await getArticuloBySlug(articleSlug);
      if (articulo?.categoria?.slug) {
        activeCategorySlug = articulo.categoria.slug;
      }
    } catch (err) {
      console.error('[Header] failed to resolve active category for article:', err);
    }
  }
}

const collapsedItems = chips.filter((c) => COLLAPSE_SLUGS.has(c.slug));
const moreHasActive = activeCategorySlug !== null && COLLAPSE_SLUGS.has(activeCategorySlug);
const isCategoryActive = (slug: string) => activeCategorySlug === slug;
---

<header id="site-header" class="site-header">
  <div class="site-header__bar">
    <a href="/" class="site-header__logo" aria-label="Beisjoven — Inicio">
      <img class="site-header__logo--mobile" src="/brand/logo-mark.png" alt="Beisjoven" width="32" height="32" />
      <img class="site-header__logo--desktop" src="/brand/logo-lockup.png" alt="Beisjoven" height="40" />
    </a>

    <nav class="site-header__nav-desktop" aria-label="Navegación principal">
      <a
        href="/"
        class="nav-pill"
        data-nav="inicio"
        aria-current={isHomeActive ? 'page' : undefined}
      >
        Inicio
      </a>
      {chips.map((c) => (
        <a
          href={`/categoria/${c.slug}`}
          class="nav-pill"
          data-category={c.slug}
          data-collapse={COLLAPSE_SLUGS.has(c.slug) ? 'true' : undefined}
          aria-current={isCategoryActive(c.slug) ? 'page' : undefined}
        >
          {c.nombre}
        </a>
      ))}

      <div class="nav-more" data-has-active={moreHasActive ? 'true' : undefined}>
        <button
          id="nav-more-trigger"
          class="nav-pill nav-pill--more"
          type="button"
          aria-haspopup="menu"
          aria-expanded="false"
          aria-controls="nav-more-panel"
        >
          Más <span class="nav-more__caret" aria-hidden="true">▾</span>
        </button>
        <div
          id="nav-more-panel"
          class="nav-more__panel"
          role="menu"
          aria-labelledby="nav-more-trigger"
          hidden
        >
          {collapsedItems.map((c) => (
            <a
              href={`/categoria/${c.slug}`}
              class="nav-more__item"
              role="menuitem"
              data-category={c.slug}
              aria-current={isCategoryActive(c.slug) ? 'page' : undefined}
            >
              {c.nombre}
            </a>
          ))}
        </div>
      </div>
    </nav>

    <div class="site-header__actions">
      <button
        id="search-trigger"
        class="site-header__search"
        type="button"
        aria-label="Buscar"
        aria-expanded="false"
        aria-controls="search-overlay"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="11" cy="11" r="7" />
          <path d="M21 21l-4.35-4.35" stroke-linecap="round" />
        </svg>
      </button>
    </div>
  </div>

  <div class="site-header__chips-mobile">
    <div class="site-header__chips-scroll" role="navigation" aria-label="Categorías">
      {chips.map((c) => (
        <a
          href={`/categoria/${c.slug}`}
          class="chip"
          data-category={c.slug}
          data-active={isCategoryActive(c.slug) ? 'true' : 'false'}
          aria-current={isCategoryActive(c.slug) ? 'page' : undefined}
        >
          {c.nombre}
        </a>
      ))}
    </div>
  </div>
</header>

<div id="search-overlay" class="search-overlay" hidden>
  <form class="search-overlay__form" action="/buscar" method="get" role="search">
    <label for="search-overlay-input" class="sr-only">Buscar</label>
    <input
      id="search-overlay-input"
      type="search"
      name="q"
      autocomplete="off"
      placeholder="Buscar noticias, equipos, jugadores…"
      required
    />
    <button id="search-close" type="button" aria-label="Cerrar búsqueda">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M6 6l12 12M6 18L18 6" stroke-linecap="round" />
      </svg>
    </button>
  </form>
</div>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: #ffffff;
    border-bottom: 1px solid #F1F1F3;
    transition: transform 200ms ease-out;
    will-change: transform;
  }
  .site-header.is-hidden { transform: translateY(-100%); }

  .site-header__bar {
    display: flex;
    align-items: center;
    gap: 12px;
    height: 56px;
    padding: 0 16px;
    max-width: var(--max-width-container, 75rem);
    margin: 0 auto;
  }

  .site-header__logo {
    display: flex;
    align-items: center;
    margin-right: auto;
    text-decoration: none;
  }
  .site-header__logo img { width: auto; }
  .site-header__logo--mobile { display: block; max-height: 32px; }
  .site-header__logo--desktop { display: none; }

  .site-header__nav-desktop { display: none; }

  .site-header__actions {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 4px;
  }

  .site-header__search {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    margin: 0;
    padding: 0;
    background: transparent;
    border: 0;
    border-radius: 8px;
    color: var(--navy, #1B2A4A);
    cursor: pointer;
    transition: background-color 120ms ease-out;
  }
  .site-header__search:hover,
  .site-header__search:focus-visible {
    background-color: rgba(27, 42, 74, 0.06);
    outline: none;
  }
  .site-header__search svg { width: 20px; height: 20px; }

  /* Mobile chips row — UNCHANGED */
  .site-header__chips-mobile {
    position: relative;
    height: 40px;
    border-bottom: 1px solid #F1F1F3;
    background: #ffffff;
  }
  .site-header__chips-scroll {
    display: flex;
    gap: 8px;
    height: 100%;
    padding: 4px 16px;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x proximity;
    scrollbar-width: none;
    -ms-overflow-style: none;
    -webkit-overflow-scrolling: touch;
  }
  .site-header__chips-scroll::-webkit-scrollbar { display: none; }
  .site-header__chips-scroll > .chip { scroll-snap-align: start; }
  .site-header__chips-mobile::after {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    width: 24px;
    height: 100%;
    pointer-events: none;
    background: linear-gradient(to right, rgba(255, 255, 255, 0), #ffffff);
  }

  /* Mobile chip — UNCHANGED */
  .chip {
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
    height: 32px;
    padding: 0 12px;
    border: 1px solid rgba(27, 42, 74, 0.14);
    border-radius: 999px;
    background: transparent;
    color: var(--navy, #1B2A4A);
    font-family: var(--font-heading, "Plus Jakarta Sans"), system-ui, sans-serif;
    font-size: 0.8125rem;
    font-weight: 600;
    line-height: 1;
    letter-spacing: 0.01em;
    text-decoration: none;
    white-space: nowrap;
    transition:
      background-color 120ms ease-out,
      color 120ms ease-out,
      border-color 120ms ease-out;
  }
  .chip:hover { border-color: rgba(27, 42, 74, 0.28); }
  .chip:focus-visible { outline: 2px solid var(--navy, #1B2A4A); outline-offset: 2px; }

  .chip[data-active="true"] { color: #ffffff; border-color: transparent; }
  .chip[data-active="true"][data-category="mlb"]            { background: var(--cat-mlb); }
  .chip[data-active="true"][data-category="liga-mexicana"]  { background: var(--cat-liga-mexicana); }
  .chip[data-active="true"][data-category="seleccion"]      { background: var(--cat-seleccion); }
  .chip[data-active="true"][data-category="juvenil"]        { background: var(--cat-juvenil); }
  .chip[data-active="true"][data-category="softbol"]        { background: var(--cat-softbol); }
  .chip[data-active="true"][data-category="opinion"]        { background: var(--cat-opinion); }

  /* Desktop / tablet (>= 768px): nav row + scroll border */
  @media (min-width: 768px) {
    .site-header {
      border-bottom: 2px solid transparent;
      transition: border-color 150ms ease-out, transform 200ms ease-out;
    }
    .site-header[data-scrolled="true"] {
      border-bottom-color: var(--navy, #1B2A4A);
    }

    .site-header__bar {
      height: 64px;
      padding: 0 24px;
      gap: 24px;
      transition: height 200ms ease-out;
    }
    .site-header.is-compact .site-header__bar { height: 48px; }

    .site-header__logo { margin-right: 0; }
    .site-header__logo--mobile { display: none; }
    .site-header__logo--desktop {
      display: block;
      max-height: 40px;
      transition: max-height 200ms ease-out;
    }
    .site-header.is-compact .site-header__logo--desktop { max-height: 28px; }

    .site-header__nav-desktop {
      display: flex;
      flex: 1;
      gap: 6px;
      justify-content: center;
      align-items: center;
      flex-wrap: nowrap;
    }

    .site-header__chips-mobile { display: none; }

    .site-header__actions {
      min-width: 72px;
    }

    /* Nav pill — desktop primary nav */
    .nav-pill {
      display: inline-flex;
      align-items: center;
      flex-shrink: 0;
      padding: 7px 16px;
      border: 1px solid var(--rule-strong, rgba(27, 42, 74, 0.28));
      border-radius: 999px;
      background: transparent;
      color: var(--ink, var(--navy, #1B2A4A));
      font-family: var(--font-body, "Inter"), system-ui, sans-serif;
      font-size: 13px;
      font-weight: 600;
      line-height: 1;
      letter-spacing: 0.02em;
      text-transform: none;
      text-decoration: none;
      white-space: nowrap;
      cursor: pointer;
      transition:
        background-color 120ms ease-out,
        color 120ms ease-out,
        border-color 120ms ease-out;
    }
    .nav-pill:hover {
      border-color: var(--navy, #1B2A4A);
      color: var(--navy, #1B2A4A);
    }
    .nav-pill:focus-visible {
      outline: 2px solid var(--navy, #1B2A4A);
      outline-offset: 2px;
    }
    .nav-pill[aria-current="page"] {
      background: var(--cat-color, var(--navy, #1B2A4A));
      color: #ffffff;
      border-color: transparent;
    }
    .nav-pill[aria-current="page"][data-category="mlb"]           { --cat-color: var(--cat-mlb); }
    .nav-pill[aria-current="page"][data-category="liga-mexicana"] { --cat-color: var(--cat-liga-mexicana); }
    .nav-pill[aria-current="page"][data-category="seleccion"]     { --cat-color: var(--cat-seleccion); }
    .nav-pill[aria-current="page"][data-category="juvenil"]       { --cat-color: var(--cat-juvenil); }
    .nav-pill[aria-current="page"][data-category="softbol"]       { --cat-color: var(--cat-softbol); }
    .nav-pill[aria-current="page"][data-category="opinion"]       { --cat-color: var(--cat-opinion); }

    /* "Más" dropdown */
    .nav-more {
      position: relative;
      display: none;
    }
    .nav-more[data-has-active="true"] .nav-pill--more {
      border-color: var(--navy, #1B2A4A);
      color: var(--navy, #1B2A4A);
    }
    .nav-more__caret {
      margin-left: 4px;
      font-size: 0.75em;
    }
    .nav-more__panel {
      position: absolute;
      top: calc(100% + 4px);
      right: 0;
      min-width: 180px;
      padding: 8px 0;
      background: #ffffff;
      border: 1px solid var(--rule-strong, rgba(27, 42, 74, 0.28));
      border-radius: 10px;
      box-shadow: 0 8px 24px rgba(15, 23, 42, 0.10);
      z-index: 60;
    }
    .nav-more__panel[hidden] { display: none; }
    .nav-more__item {
      display: block;
      padding: 10px 14px;
      color: var(--ink, var(--navy, #1B2A4A));
      font-family: var(--font-body, "Inter"), system-ui, sans-serif;
      font-size: 14px;
      font-weight: 600;
      line-height: 1.3;
      text-decoration: none;
      transition: background-color 120ms ease-out;
    }
    .nav-more__item:hover,
    .nav-more__item:focus-visible {
      background: var(--surface-tinted, #F6F5F1);
      outline: none;
    }
    .nav-more__item[aria-current="page"] {
      color: var(--navy, #1B2A4A);
      background: var(--surface-tinted, #F6F5F1);
    }
  }

  /* Tablet narrow (768–1099): collapse Softbol + Opinión into "Más" */
  @media (min-width: 768px) and (max-width: 1099px) {
    .site-header__nav-desktop .nav-pill[data-collapse="true"] { display: none; }
    .nav-more { display: block; }
  }

  /* Search overlay */
  .search-overlay {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 60;
    background: #ffffff;
    border-bottom: 1px solid #E7E7EA;
    box-shadow: 0 2px 8px rgba(15, 23, 42, 0.06);
    padding: 10px 12px;
  }
  .search-overlay[hidden] { display: none; }
  .search-overlay__form {
    display: flex;
    align-items: center;
    gap: 8px;
    max-width: var(--max-width-container, 75rem);
    margin: 0 auto;
    height: 48px;
  }
  .search-overlay__form input {
    flex: 1;
    height: 44px;
    padding: 0 14px;
    border: 1px solid rgba(27, 42, 74, 0.18);
    border-radius: 10px;
    background: #ffffff;
    color: var(--navy, #1B2A4A);
    font-family: var(--font-body, "Inter"), system-ui, sans-serif;
    font-size: 1rem;
    outline: none;
    transition: border-color 120ms ease-out, box-shadow 120ms ease-out;
  }
  .search-overlay__form input:focus {
    border-color: var(--navy, #1B2A4A);
    box-shadow: 0 0 0 3px rgba(27, 42, 74, 0.12);
  }
  .search-overlay__form button {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    background: transparent;
    border: 0;
    border-radius: 8px;
    color: var(--navy, #1B2A4A);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .search-overlay__form button svg { width: 22px; height: 22px; }
  .search-overlay__form button:hover,
  .search-overlay__form button:focus-visible {
    background: rgba(27, 42, 74, 0.06);
    outline: none;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>

<script is:inline>
  (() => {
    const header = document.getElementById('site-header');
    const trigger = document.getElementById('search-trigger');
    const overlay = document.getElementById('search-overlay');
    const closeBtn = document.getElementById('search-close');
    const moreTrigger = document.getElementById('nav-more-trigger');
    const morePanel = document.getElementById('nav-more-panel');

    if (header) {
      const COMPACT_THRESHOLD = 80;
      const SCROLL_BORDER_THRESHOLD = 40;
      const desktopMql = window.matchMedia('(min-width: 768px)');
      let lastY = window.scrollY;
      let ticking = false;

      function onScroll() {
        const y = window.scrollY;
        const isDesktop = desktopMql.matches;

        if (y > SCROLL_BORDER_THRESHOLD) {
          header.setAttribute('data-scrolled', 'true');
        } else {
          header.removeAttribute('data-scrolled');
        }

        if (y <= COMPACT_THRESHOLD) {
          header.classList.remove('is-hidden');
          header.classList.remove('is-compact');
        } else if (isDesktop) {
          header.classList.add('is-compact');
          header.classList.remove('is-hidden');
        } else {
          header.classList.remove('is-compact');
          if (y > lastY) {
            header.classList.add('is-hidden');
          } else {
            header.classList.remove('is-hidden');
          }
        }
        lastY = y;
        ticking = false;
      }

      window.addEventListener('scroll', () => {
        if (!ticking) {
          window.requestAnimationFrame(onScroll);
          ticking = true;
        }
      }, { passive: true });

      onScroll();
    }

    if (trigger && overlay && closeBtn) {
      const input = overlay.querySelector('input[name="q"]');

      function open() {
        overlay.hidden = false;
        trigger.setAttribute('aria-expanded', 'true');
        setTimeout(() => { if (input) input.focus(); }, 30);
      }
      function close() {
        overlay.hidden = true;
        trigger.setAttribute('aria-expanded', 'false');
      }

      trigger.addEventListener('click', open);
      closeBtn.addEventListener('click', close);
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !overlay.hidden) {
          close();
          trigger.focus();
        }
      });
    }

    if (moreTrigger && morePanel) {
      let isOpen = false;

      const openMenu = () => {
        isOpen = true;
        morePanel.hidden = false;
        moreTrigger.setAttribute('aria-expanded', 'true');
      };
      const closeMenu = () => {
        isOpen = false;
        morePanel.hidden = true;
        moreTrigger.setAttribute('aria-expanded', 'false');
      };

      try {
        moreTrigger.addEventListener('click', (e) => {
          e.stopPropagation();
          if (isOpen) closeMenu(); else openMenu();
        });

        document.addEventListener('click', (e) => {
          if (!isOpen) return;
          const target = e.target;
          if (!(target instanceof Node)) return;
          if (morePanel.contains(target) || moreTrigger.contains(target)) return;
          closeMenu();
        });

        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && isOpen) {
            closeMenu();
            moreTrigger.focus();
          }
        });

        morePanel.addEventListener('click', (e) => {
          const target = e.target;
          if (target instanceof Element && target.closest('a[role="menuitem"]')) {
            closeMenu();
          }
        });
      } catch (err) {
        console.error('[Header] more-menu init failed:', err);
      }
    }
  })();
</script>
