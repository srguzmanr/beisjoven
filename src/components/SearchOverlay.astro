---
interface Categoria {
  slug: string;
  nombre: string;
}

interface Props {
  categorias: Categoria[];
}

const { categorias } = Astro.props;
---

<aside
  id="search-overlay"
  class="search-overlay"
  hidden
  role="dialog"
  aria-label="Buscar"
  aria-modal="true"
>
  <div class="search-overlay__backdrop" data-search-close></div>
  <div class="search-overlay__panel" role="document">
    <form
      class="search-overlay__form"
      action="/buscar"
      method="get"
      role="search"
    >
      <label for="search-overlay-input" class="sr-only">Término de búsqueda</label>
      <input
        id="search-overlay-input"
        type="search"
        name="q"
        autocomplete="off"
        placeholder="Buscar en Beisjoven…"
        aria-label="Término de búsqueda"
        required
      />
      <input type="hidden" name="cat" id="search-overlay-cat" disabled />
      <button type="submit" class="search-overlay__submit" aria-label="Buscar">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </button>
      <button
        type="button"
        class="search-overlay__close"
        data-search-close
        aria-label="Cerrar búsqueda"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M6 6l12 12M6 18L18 6" stroke-linecap="round" />
        </svg>
      </button>
    </form>

    <div
      class="search-overlay__scope"
      role="radiogroup"
      aria-label="Filtrar por sección"
    >
      <button
        type="button"
        class="search-overlay__chip"
        role="radio"
        aria-checked="true"
        data-scope="all"
      >Todo</button>
      {categorias.map((c) => (
        <button
          type="button"
          class="search-overlay__chip"
          role="radio"
          aria-checked="false"
          data-scope={c.slug}
        >{c.nombre}</button>
      ))}
    </div>

    <div class="search-overlay__recent" data-recent-block hidden>
      <div class="search-overlay__recent-head">
        <h3>Búsquedas recientes</h3>
        <button type="button" class="search-overlay__recent-clear" data-recent-clear>
          Limpiar
        </button>
      </div>
      <ul class="search-overlay__recent-list" data-recent-list></ul>
    </div>
  </div>
</aside>

<style>
  .search-overlay {
    position: fixed;
    inset: 0;
    z-index: 70;
  }
  .search-overlay[hidden] { display: none; }

  .search-overlay__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(15, 27, 51, 0.4);
    animation: bj-search-fade 160ms ease-out;
  }

  .search-overlay__panel {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    max-height: 100vh;
    overflow-y: auto;
    background: #ffffff;
    border-bottom: 1px solid #E7E7EA;
    box-shadow: 0 8px 24px rgba(15, 23, 42, 0.10);
    padding: 12px 16px 16px;
    animation: bj-search-slide 180ms ease-out;
  }

  @keyframes bj-search-fade {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  @keyframes bj-search-slide {
    from { transform: translateY(-8px); opacity: 0.6; }
    to { transform: translateY(0); opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .search-overlay__backdrop,
    .search-overlay__panel { animation: none; }
  }

  .search-overlay__form {
    display: flex;
    align-items: center;
    gap: 8px;
    max-width: var(--max-width-container, 75rem);
    margin: 0 auto;
  }

  .search-overlay__form input[type="search"] {
    flex: 1;
    height: 44px;
    padding: 0 14px;
    border: 1px solid rgba(27, 42, 74, 0.18);
    border-radius: 10px;
    background: #ffffff;
    color: var(--navy, #1B2A4A);
    font-family: var(--font-body, "Inter"), system-ui, sans-serif;
    font-size: 1rem;
    outline: none;
    transition: border-color 120ms ease-out, box-shadow 120ms ease-out;
  }
  .search-overlay__form input[type="search"]:focus {
    border-color: var(--navy, #1B2A4A);
    box-shadow: 0 0 0 3px rgba(27, 42, 74, 0.12);
  }

  .search-overlay__submit,
  .search-overlay__close {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    background: transparent;
    border: 0;
    border-radius: 8px;
    color: var(--navy, #1B2A4A);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: background-color 120ms ease-out;
  }
  .search-overlay__submit svg { width: 22px; height: 22px; }
  .search-overlay__close svg { width: 20px; height: 20px; }
  .search-overlay__submit:hover,
  .search-overlay__submit:focus-visible,
  .search-overlay__close:hover,
  .search-overlay__close:focus-visible {
    background: rgba(27, 42, 74, 0.06);
    outline: none;
  }
  .search-overlay__submit:focus-visible,
  .search-overlay__close:focus-visible {
    box-shadow: 0 0 0 2px var(--navy, #1B2A4A);
  }

  .search-overlay__scope {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    max-width: var(--max-width-container, 75rem);
    margin: 12px auto 0;
  }

  .search-overlay__chip {
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
    height: 28px;
    padding: 5px 12px;
    border: 1px solid rgba(27, 42, 74, 0.18);
    border-radius: 999px;
    background: transparent;
    color: var(--navy, #1B2A4A);
    font-family: var(--font-body, "Inter"), system-ui, sans-serif;
    font-size: 12px;
    font-weight: 600;
    line-height: 1;
    letter-spacing: 0.02em;
    cursor: pointer;
    white-space: nowrap;
    transition:
      background-color 120ms ease-out,
      color 120ms ease-out,
      border-color 120ms ease-out;
  }
  .search-overlay__chip:hover {
    border-color: var(--navy, #1B2A4A);
  }
  .search-overlay__chip:focus-visible {
    outline: 2px solid var(--navy, #1B2A4A);
    outline-offset: 2px;
  }
  .search-overlay__chip[aria-checked="true"] {
    background: var(--navy, #1B2A4A);
    color: #ffffff;
    border-color: transparent;
  }

  .search-overlay__recent {
    max-width: var(--max-width-container, 75rem);
    margin: 16px auto 0;
  }
  .search-overlay__recent[hidden] { display: none; }

  .search-overlay__recent-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    margin-bottom: 6px;
  }
  .search-overlay__recent h3 {
    margin: 0;
    color: var(--gris-muted, #6B7280);
    font-family: var(--font-body, "Inter"), system-ui, sans-serif;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .search-overlay__recent-clear {
    background: transparent;
    border: 0;
    padding: 4px 8px;
    color: var(--gris-muted, #6B7280);
    font-family: var(--font-body, "Inter"), system-ui, sans-serif;
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    border-radius: 6px;
    transition: background-color 120ms ease-out, color 120ms ease-out;
  }
  .search-overlay__recent-clear:hover,
  .search-overlay__recent-clear:focus-visible {
    background: rgba(27, 42, 74, 0.06);
    color: var(--navy, #1B2A4A);
    outline: none;
  }

  .search-overlay__recent-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .search-overlay__recent-list button {
    display: flex;
    align-items: center;
    gap: 10px;
    width: 100%;
    padding: 10px 12px;
    background: transparent;
    border: 0;
    border-radius: 8px;
    color: var(--navy, #1B2A4A);
    font-family: var(--font-body, "Inter"), system-ui, sans-serif;
    font-size: 14px;
    text-align: left;
    cursor: pointer;
    transition: background-color 120ms ease-out;
  }
  .search-overlay__recent-list button:hover,
  .search-overlay__recent-list button:focus-visible {
    background: var(--surface-tinted, #F6F5F1);
    outline: none;
  }
  .search-overlay__recent-list svg {
    flex-shrink: 0;
    width: 14px;
    height: 14px;
    color: var(--gris-muted, #6B7280);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* Desktop ≥768px: panel sits BELOW header (non-destructive). */
  @media (min-width: 768px) {
    .search-overlay__panel {
      top: var(--bj-header-offset, 64px);
      max-height: calc(100vh - var(--bj-header-offset, 64px));
    }
  }
</style>

<script is:inline>
  (() => {
    try {
      const STORAGE_KEY = 'bj_recent_searches';
      const MAX_RECENT = 5;

      const overlay = document.getElementById('search-overlay');
      const trigger = document.getElementById('search-trigger');
      if (!overlay || !trigger) return;

      const panel = overlay.querySelector('.search-overlay__panel');
      const form = overlay.querySelector('.search-overlay__form');
      const input = overlay.querySelector('#search-overlay-input');
      const catInput = overlay.querySelector('#search-overlay-cat');
      const scopeGroup = overlay.querySelector('.search-overlay__scope');
      const recentBlock = overlay.querySelector('[data-recent-block]');
      const recentList = overlay.querySelector('[data-recent-list]');
      const recentClearBtn = overlay.querySelector('[data-recent-clear]');
      const closeEls = overlay.querySelectorAll('[data-search-close]');
      const desktopMql = window.matchMedia('(min-width: 768px)');

      let isOpen = false;
      let activeScope = 'all';
      let lastFocused = null;

      function storageAvailable() {
        try {
          const k = '__bj_test__';
          window.localStorage.setItem(k, '1');
          window.localStorage.removeItem(k);
          return true;
        } catch (_) {
          return false;
        }
      }

      function readRecent() {
        if (!storageAvailable()) return null;
        try {
          const raw = window.localStorage.getItem(STORAGE_KEY);
          if (!raw) return [];
          const arr = JSON.parse(raw);
          if (!Array.isArray(arr)) return [];
          return arr.filter((s) => typeof s === 'string' && s.trim().length > 0).slice(0, MAX_RECENT);
        } catch (err) {
          console.error('[SearchOverlay] readRecent failed:', err);
          return [];
        }
      }

      function writeRecent(arr) {
        if (!storageAvailable()) return;
        try {
          window.localStorage.setItem(STORAGE_KEY, JSON.stringify(arr.slice(0, MAX_RECENT)));
        } catch (err) {
          console.error('[SearchOverlay] writeRecent failed:', err);
        }
      }

      function pushRecent(query) {
        const q = query.trim();
        if (!q) return;
        const current = readRecent() || [];
        const deduped = [q, ...current.filter((s) => s.toLowerCase() !== q.toLowerCase())];
        writeRecent(deduped);
      }

      function renderRecent() {
        if (!recentBlock || !recentList) return;
        const items = readRecent();
        if (items === null || items.length === 0) {
          recentBlock.hidden = true;
          recentList.innerHTML = '';
          return;
        }
        recentBlock.hidden = false;
        recentList.innerHTML = items
          .map((q) => {
            const safe = q.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
            return `<li><button type="button" data-recent-item="${safe}">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <circle cx="12" cy="12" r="9" />
                <path d="M12 7v5l3 2" stroke-linecap="round" />
              </svg>
              <span>${safe}</span>
            </button></li>`;
          })
          .join('');
      }

      function updateHeaderOffset() {
        const header = document.getElementById('site-header');
        if (!header) return;
        const h = header.offsetHeight || 64;
        document.documentElement.style.setProperty('--bj-header-offset', h + 'px');
      }

      function getFocusable() {
        if (!panel) return [];
        const sel = 'button:not([disabled]):not([hidden]), [href], input:not([disabled]):not([type="hidden"]), [tabindex]:not([tabindex="-1"])';
        return Array.from(panel.querySelectorAll(sel)).filter((el) => {
          if (el.hasAttribute('hidden')) return false;
          let p = el.parentElement;
          while (p && p !== panel) {
            if (p.hasAttribute('hidden')) return false;
            p = p.parentElement;
          }
          const r = el.getBoundingClientRect();
          return r.width > 0 || r.height > 0 || el === document.activeElement;
        });
      }

      function open() {
        if (isOpen) return;
        isOpen = true;
        lastFocused = document.activeElement instanceof HTMLElement ? document.activeElement : null;
        if (desktopMql.matches) updateHeaderOffset();
        renderRecent();
        overlay.hidden = false;
        trigger.setAttribute('aria-expanded', 'true');
        setTimeout(() => { if (input) input.focus(); }, 20);
      }

      function close() {
        if (!isOpen) return;
        isOpen = false;
        overlay.hidden = true;
        trigger.setAttribute('aria-expanded', 'false');
        const target = lastFocused || trigger;
        if (target && typeof target.focus === 'function') target.focus();
      }

      function setScope(slug) {
        activeScope = slug;
        if (!scopeGroup) return;
        const chips = scopeGroup.querySelectorAll('[data-scope]');
        chips.forEach((c) => {
          const isMatch = c.getAttribute('data-scope') === slug;
          c.setAttribute('aria-checked', isMatch ? 'true' : 'false');
        });
      }

      function submitWithQuery(q) {
        const query = q.trim();
        if (!query) {
          if (input) input.focus();
          return;
        }
        pushRecent(query);
        const params = new URLSearchParams();
        params.set('q', query);
        if (activeScope && activeScope !== 'all') params.set('cat', activeScope);
        window.location.href = '/buscar?' + params.toString();
      }

      trigger.addEventListener('click', (e) => {
        e.preventDefault();
        if (isOpen) close(); else open();
      });

      closeEls.forEach((el) => {
        el.addEventListener('click', (e) => {
          e.preventDefault();
          close();
        });
      });

      if (form) {
        form.addEventListener('submit', (e) => {
          e.preventDefault();
          if (!input) return;
          submitWithQuery(input.value || '');
        });
      }

      if (scopeGroup) {
        scopeGroup.addEventListener('click', (e) => {
          const target = e.target;
          if (!(target instanceof Element)) return;
          const chip = target.closest('[data-scope]');
          if (!chip) return;
          const slug = chip.getAttribute('data-scope') || 'all';
          setScope(slug);
        });
      }

      if (recentList) {
        recentList.addEventListener('click', (e) => {
          const target = e.target;
          if (!(target instanceof Element)) return;
          const btn = target.closest('[data-recent-item]');
          if (!btn) return;
          const q = btn.getAttribute('data-recent-item') || '';
          if (input) input.value = q;
          submitWithQuery(q);
        });
      }

      if (recentClearBtn) {
        recentClearBtn.addEventListener('click', (e) => {
          e.preventDefault();
          writeRecent([]);
          renderRecent();
          if (input) input.focus();
        });
      }

      document.addEventListener('keydown', (e) => {
        if (e.key === '/' && !isOpen) {
          const ae = document.activeElement;
          const isEditable =
            ae instanceof HTMLElement &&
            (ae.tagName === 'INPUT' ||
              ae.tagName === 'TEXTAREA' ||
              ae.tagName === 'SELECT' ||
              ae.isContentEditable);
          if (isEditable) return;
          e.preventDefault();
          open();
          return;
        }

        if (!isOpen) return;

        if (e.key === 'Escape') {
          e.preventDefault();
          close();
          return;
        }

        if (e.key === 'Tab') {
          const focusables = getFocusable();
          if (focusables.length === 0) {
            e.preventDefault();
            return;
          }
          const first = focusables[0];
          const last = focusables[focusables.length - 1];
          const active = document.activeElement;
          if (e.shiftKey) {
            if (active === first || !panel.contains(active)) {
              e.preventDefault();
              last.focus();
            }
          } else {
            if (active === last || !panel.contains(active)) {
              e.preventDefault();
              first.focus();
            }
          }
        }
      });

      window.addEventListener('resize', () => {
        if (isOpen && desktopMql.matches) updateHeaderOffset();
      });
    } catch (err) {
      console.error('[SearchOverlay] init failed:', err);
    }
  })();
</script>
