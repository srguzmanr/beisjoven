---
import type { Articulo } from '@/lib/supabase';
import { getCategoryAccent } from '@/lib/categoryAccents.js';

type MostReadScope =
  | { type: 'global' }
  | { type: 'category'; slug: string; displayName: string }
  | {
      type: 'article-context';
      articleId: number;
      categorySlug: string;
      categoryDisplayName: string;
    };

interface Props {
  articles: Articulo[];
  scope?: MostReadScope;
}

const { articles, scope = { type: 'global' } } = Astro.props;

const headline =
  scope.type === 'global'
    ? 'Más leídos'
    : scope.type === 'category'
      ? `Lo más leído en ${scope.displayName}`
      : `Lo más leído en ${scope.categoryDisplayName}`;

const categorySlug =
  scope.type === 'category'
    ? scope.slug
    : scope.type === 'article-context'
      ? scope.categorySlug
      : null;

// Global scope → red kicker accent; category scope → category accent
const rankColor = !categorySlug ? 'var(--red, #C8102E)' : getCategoryAccent(categorySlug);
---

{articles.length > 0 && (
  <aside class="bj-most-read bj-card" style={`--rank-color: ${rankColor};`}>
    <div class="bj-most-read__header">
      <span class="bj-kicker" style="--kicker: var(--rank-color);">{headline}</span>
    </div>
    <ol class="bj-most-read__list">
      {articles.map((a, i) => (
        <li class="bj-most-read__item">
          <span class="bj-most-read__rank" aria-hidden="true">{i + 1}</span>
          <a href={`/articulo/${a.slug}`} class="bj-most-read__link">
            {a.titulo}
          </a>
        </li>
      ))}
    </ol>
  </aside>
)}

<style>
  .bj-most-read {
    padding: 0;
    overflow: hidden;
  }

  .bj-most-read__header {
    padding: 14px 16px 12px;
    border-bottom: 1px solid var(--rule, rgba(27, 42, 74, 0.10));
    position: relative;
  }

  /* Accent rule under the kicker */
  .bj-most-read__header::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 16px;
    width: 36px;
    height: 2px;
    background: var(--rank-color);
    border-radius: 2px;
  }

  .bj-most-read__list {
    list-style: none;
    margin: 0;
    padding: 8px 0;
  }

  .bj-most-read__item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 10px 16px;
    border-bottom: 1px solid var(--rule, rgba(27, 42, 74, 0.10));
    transition: background 0.15s;
  }

  .bj-most-read__item:last-child {
    border-bottom: none;
  }

  .bj-most-read__item:hover {
    background: var(--surface-2, #F6F5F1);
  }

  .bj-most-read__rank {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 900;
    line-height: 1;
    color: var(--rank-color);
    flex-shrink: 0;
    width: 1.5ch;
    tabular-nums: true;
    margin-top: 2px;
  }

  .bj-most-read__link {
    font-family: var(--font-heading);
    font-size: 0.8125rem;
    font-weight: 600;
    line-height: 1.4;
    color: var(--navy, #1B2A4A);
    text-decoration: none;
    transition: color 0.15s;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .bj-most-read__link:hover {
    color: var(--red, #C8102E);
  }
</style>
