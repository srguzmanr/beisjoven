---
// HOUSE-ADS-01 — AdSlot: position-agnostic, reusable ad container.
// Creatives are served from the `anuncios` table (CMS-managed). The slot
// reserves a 300×250 box (aspect-ratio) so it NEVER collapses and CLS = 0.
//
// Disclosure labels are CLOSED by Legal (HOUSE-ADS-LEGAL-01) — hardcoded in
// labelFor() below. The label is clear-and-conspicuous: rendered at the same
// time as the creative (never behind hover/click), AA contrast, all devices.
import { getAnunciosBySlot, type Anuncio, type AnuncioTipo } from '@/lib/supabase';
import { buildAdHref } from '@/lib/ad-utm.js';

interface Props {
  /** Frozen nomenclature (ADS-GOLIVE-PREP-01):
      'home-top' (homepage leaderboard) | 'home-mid' (homepage in-feed MPU)
      | 'article-body' (in-article MPU) | 'article-footer' (end-of-note). */
  slotId: string;
  /** Layout footprint: 'prose' (article-body) or 'card' (home-mid). Cosmetic only.
      mpu-only. */
  variant?: 'prose' | 'card';
  /** Ad format: 'mpu' 300×250 (default) | 'leaderboard' responsive
      970×90 desktop / 320×50 mobile (home-top, LEADER-01). */
  format?: 'mpu' | 'leaderboard';
}

const { slotId, variant = 'card', format = 'mpu' } = Astro.props;

// --- Disclosure labels — CLOSED by Legal. Do NOT add cases. ---
// ADS-GOLIVE-PREP-01: full bilingual text in a single string (no doctrine
// change — same casa vs. everything-else split as HOUSE-ADS-LEGAL-01).
// casa → "De Beisjoven / By Beisjoven"
// everything else (propia | aliado | placeholder) → "Publicidad / Advertisement"
function labelFor(tipo: AnuncioTipo): string {
  if (tipo === 'casa') return 'De Beisjoven / By Beisjoven';
  return 'Publicidad / Advertisement';
}

// ADS-STD-01 — placeholder pattern (LEADER-01): non-promotional,
// dimensions-only copy. Same string in ES and EN, like the leaderboard.
const MPU_PH_TEXT = 'Espacio publicitario · 300 × 250';

// --- Select the creative to serve -------------------------------------------
// ADS-STD-01 waterfall: paid (propia/aliado) > casa > placeholder. Only
// servable creatives (image + destination) compete; the highest non-empty
// tier wins. MPU rotates randomly ONLY within the winning tier; leaderboard
// stays deterministic — lowest prioridad in the tier (pool keeps the
// prioridad-asc order from getAnunciosBySlot).
let chosen: Anuncio | null = null;
const anuncios = await getAnunciosBySlot(slotId);
const servable = anuncios.filter((a) => a.imagen_url && a.target_url);
const tiers: AnuncioTipo[][] = [['propia', 'aliado'], ['casa'], ['placeholder']];
const pool = tiers
  .map((tier) => servable.filter((a) => tier.includes(a.tipo)))
  .find((p) => p.length > 0);
if (pool) {
  chosen = format === 'leaderboard'
    ? pool[0]
    : pool[Math.floor(Math.random() * pool.length)];
}

const hasCreative = chosen !== null;
const tipo: AnuncioTipo = hasCreative ? chosen!.tipo : 'placeholder';
const label = labelFor(tipo);
const anunciante = hasCreative ? chosen!.marca ?? chosen!.tipo : 'placeholder';
// ADS-GOLIVE-PREP-01 — outbound UTMs, built server-side so the cached HTML is
// already tagged. Paid tipos only (propia/aliado); casa/placeholder stay
// clean. utm_* already present in target_url is never duplicated (DB wins).
const href = hasCreative
  ? buildAdHref(chosen!.target_url!, tipo, chosen!.campana ?? null, slotId)
  : '';
const isExternal = href.startsWith('http');
// Leaderboard art direction: mobile creative falls back to the desktop asset
// (letterboxed via object-fit: contain) until imagen_url_mobile is set.
const mobileSrc = chosen?.imagen_url_mobile ?? chosen?.imagen_url ?? null;
---

{format === 'leaderboard' ? (
  /* LEADER-01 — responsive leaderboard: 970×90 ≥768px / 320×50 <768px.
     Always active; height reserved in CSS (aspect-ratio) so CLS = 0. */
  <aside
    class="bj-adslot bj-adslot--leaderboard"
    aria-label={label}
    data-ad-slot={slotId}
    data-ad-active="true"
    data-ad-tipo={tipo}
    data-ad-anunciante={anunciante}
    data-ad-id={chosen?.id}
  >
    <span class="bj-adslot__label bj-adslot__label--lb">{label}</span>
    {hasCreative ? (
      <a
        class="bj-lb__frame"
        href={href}
        data-ad-cta
        target="_blank"
        rel="sponsored noopener"
      >
        <picture class="bj-lb__picture">
          <source media="(min-width: 768px)" srcset={chosen!.imagen_url!} width="970" height="90" />
          <img
            class="bj-lb__img"
            src={mobileSrc}
            alt={chosen!.alt_text}
            width="320"
            height="50"
            loading="eager"
            decoding="async"
          />
        </picture>
      </a>
    ) : (
      <div class="bj-lb__frame bj-lb__frame--ph">
        <span class="bj-lb__ph bj-lb__ph--mobile">Espacio publicitario · 320 × 50</span>
        <span class="bj-lb__ph bj-lb__ph--desktop">Espacio publicitario · 970 × 90</span>
      </div>
    )}
  </aside>
) : (
  <aside
    class:list={['bj-adslot', `bj-adslot--${variant}`]}
    aria-label={label}
    data-ad-slot={slotId}
    data-ad-active="true"
    data-ad-tipo={tipo}
    data-ad-anunciante={anunciante}
    data-ad-id={chosen?.id}
  >
    <span class="bj-adslot__label">{label}</span>
    {hasCreative ? (
      <a
        class="bj-adslot__frame"
        href={href}
        data-ad-cta
        {...isExternal ? { target: '_blank', rel: 'noopener sponsored' } : {}}
      >
        <img
          class="bj-adslot__img"
          src={chosen!.imagen_url!}
          alt={chosen!.alt_text}
          width="300"
          height="250"
          loading="lazy"
          decoding="async"
        />
      </a>
    ) : (
      <div class="bj-adslot__frame bj-adslot__frame--ph">
        <span class="bj-adslot__ph">{MPU_PH_TEXT}</span>
      </div>
    )}
  </aside>
)}

<style>
  /* Neutral / navy frame — NEVER a category color. */
  .bj-adslot {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    margin: 0 auto;
    width: 100%;
  }

  .bj-adslot--prose {
    max-width: var(--max-width-prose, 42rem);
  }

  /* ADS-STD-01 — label sits directly above the unit, flush with the unit's
     left edge: same 300px cap as the frame, centered together in the column
     (align-items: center), text left-aligned. */
  .bj-adslot__label {
    text-align: left;
    font-family: var(--font-body, system-ui, sans-serif);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    /* AA contrast on white: #4B5563 ≈ 7:1 */
    color: #4B5563;
    max-width: 300px;
    width: 100%;
  }

  .bj-adslot__frame {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 300px;
    max-width: 100%;
    /* Reserve the box → CLS = 0 even before the lazy image loads. */
    aspect-ratio: 300 / 250;
    border: 1px solid var(--rule-strong, rgba(27, 42, 74, 0.28));
    background: var(--bg-2, #F6F5F1);
    overflow: hidden;
    text-decoration: none;
  }

  .bj-adslot__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ADS-STD-01 — MPU placeholder, LEADER-01 pattern: neutral box, 1px
     var(--rule) border, centered dimensions-only copy in navy @ 60%. */
  .bj-adslot__frame--ph {
    border-color: var(--rule, rgba(27, 42, 74, 0.10));
  }

  .bj-adslot__ph {
    font-family: var(--font-body, system-ui, sans-serif);
    font-size: 12px;
    line-height: 1.2;
    text-align: center;
    padding: 12px;
    /* navy @ 60% */
    color: rgba(27, 42, 74, 0.6);
  }

  /* --- LEADER-01 — leaderboard format (970×90 / 320×50) ------------------- */
  /* The frame reserves its box via width + aspect-ratio per breakpoint, so
     height is CSS-determined before any image byte arrives → CLS = 0. */
  .bj-adslot__label--lb {
    max-width: 320px;
  }

  .bj-lb__frame {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 320px;
    max-width: 100%;
    aspect-ratio: 320 / 50;
    border: 1px solid var(--rule, rgba(27, 42, 74, 0.10));
    background: var(--bg-2, #F6F5F1);
    overflow: hidden;
    text-decoration: none;
  }

  .bj-lb__picture {
    width: 100%;
    height: 100%;
    display: block;
  }

  .bj-lb__img {
    width: 100%;
    height: 100%;
    /* contain, not cover: a 970×90 asset serving as mobile fallback would
       lose ~40% of its width to cropping; letterboxing keeps it legible. */
    object-fit: contain;
    display: block;
  }

  .bj-lb__ph {
    font-family: var(--font-body, system-ui, sans-serif);
    font-size: 12px;
    line-height: 1.2;
    text-align: center;
    /* navy @ 60% */
    color: rgba(27, 42, 74, 0.6);
  }

  .bj-lb__ph--desktop {
    display: none;
  }

  @media (min-width: 768px) {
    .bj-adslot__label--lb {
      max-width: 970px;
    }

    /* 768–1010px viewports: max-width:100% shrinks the box, aspect-ratio
       scales the height proportionally — still zero shift. */
    .bj-lb__frame {
      width: 970px;
      aspect-ratio: 970 / 90;
    }

    .bj-lb__ph--mobile {
      display: none;
    }

    .bj-lb__ph--desktop {
      display: inline;
    }
  }
</style>

<script is:inline>
  // HOUSE-ADS-01 — GA4 instrumentation for live ad slots.
  // ad_impression fires once when the slot enters the viewport; ad_click on
  // click. Payload: slot_id, tipo, anunciante.
  //
  // ADS-TRACK-01 — first-party beacons to POST /api/ad-event, IN ADDITION to
  // (and without touching) the GA4 events above:
  //   impression : once per slot+path per tab session (sessionStorage flag,
  //                so a reload does NOT double-count) — fired on render.
  //   viewable   : IAB display standard — >=50% of the unit visible
  //                continuously for >=1s; same sessionStorage dedupe as
  //                impression so viewable_rate can never exceed 100%.
  //   click      : every click on the creative CTA.
  // Transport: sendBeacon (survives the click navigation) with
  // fetch-keepalive fallback. Tracking must never break the page: every
  // entry point is try/caught and failures are silent.
  (function () {
    if (window.__bjAdSlotInit) return;
    window.__bjAdSlotInit = true;

    var VIEWABLE_MS = 1000;

    function emit(name, el) {
      if (typeof window.gtag !== 'function') return;
      window.gtag('event', name, {
        slot_id: el.getAttribute('data-ad-slot'),
        tipo: el.getAttribute('data-ad-tipo'),
        anunciante: el.getAttribute('data-ad-anunciante'),
      });
    }

    function beacon(el, evento) {
      try {
        var payload = JSON.stringify({
          slot_id: el.getAttribute('data-ad-slot'),
          anuncio_id: el.getAttribute('data-ad-id') || null,
          evento: evento,
          path: location.pathname,
        });
        var sent = false;
        if (navigator.sendBeacon) {
          sent = navigator.sendBeacon(
            '/api/ad-event',
            new Blob([payload], { type: 'application/json' })
          );
        }
        if (!sent) {
          fetch('/api/ad-event', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: payload,
            keepalive: true,
          }).catch(function () {});
        }
      } catch (e) { /* never let tracking break the page */ }
    }

    // sessionStorage dedupe per evento+slot+path. If storage is unavailable
    // (private mode quotas), count rather than drop.
    function once(el, evento) {
      try {
        var key = 'bj_ad:' + evento + ':' + el.getAttribute('data-ad-slot') + ':' + location.pathname;
        if (sessionStorage.getItem(key)) return false;
        sessionStorage.setItem(key, '1');
        return true;
      } catch (e) {
        return true;
      }
    }

    function alreadySent(el, evento) {
      try {
        return !!sessionStorage.getItem(
          'bj_ad:' + evento + ':' + el.getAttribute('data-ad-slot') + ':' + location.pathname
        );
      } catch (e) {
        return false;
      }
    }

    function init() {
      var slots = document.querySelectorAll('.bj-adslot[data-ad-active="true"]');
      if (!slots.length) return;

      var io = 'IntersectionObserver' in window
        ? new IntersectionObserver(function (entries, obs) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                emit('ad_impression', entry.target);
                obs.unobserve(entry.target);
              }
            });
          }, { threshold: 0.5 })
        : null;

      // ADS-TRACK-01 — viewability: a second observer (the GA4 one above
      // unobserves on first intersect, so it cannot measure a 1s dwell).
      var pending = [];
      var vio = 'IntersectionObserver' in window
        ? new IntersectionObserver(function (entries, obs) {
            entries.forEach(function (entry) {
              var el = entry.target;
              // 1e-3 epsilon: crossing the 0.5 threshold can report a ratio a
              // hair under it.
              var inView = entry.intersectionRatio >= 0.5 - 1e-3;
              el.__bjInView = inView;
              if (inView && !el.__bjViewTimer && !document.hidden) {
                el.__bjViewTimer = setTimeout(function () {
                  el.__bjViewTimer = null;
                  if (once(el, 'viewable')) beacon(el, 'viewable');
                  obs.unobserve(el);
                }, VIEWABLE_MS);
                pending.push(el);
              } else if (!inView && el.__bjViewTimer) {
                clearTimeout(el.__bjViewTimer);
                el.__bjViewTimer = null;
              }
            });
          }, { threshold: 0.5 })
        : null;

      // A hidden tab is not viewable (IO does not fire on tab switches):
      // cancel dwell timers on hide, restart them for still-in-view slots on
      // return.
      document.addEventListener('visibilitychange', function () {
        pending.forEach(function (el) {
          if (document.hidden && el.__bjViewTimer) {
            clearTimeout(el.__bjViewTimer);
            el.__bjViewTimer = null;
          } else if (!document.hidden && el.__bjInView && !el.__bjViewTimer && !alreadySent(el, 'viewable')) {
            el.__bjViewTimer = setTimeout(function () {
              el.__bjViewTimer = null;
              if (once(el, 'viewable')) beacon(el, 'viewable');
              if (vio) vio.unobserve(el);
            }, VIEWABLE_MS);
          }
        });
      });

      slots.forEach(function (el) {
        if (el.__bjAdBound) return;
        el.__bjAdBound = true;
        if (io) io.observe(el);
        else emit('ad_impression', el); // no IO support → count on render

        // ADS-TRACK-01 — impression on render, deduped across reloads.
        if (once(el, 'impression')) beacon(el, 'impression');
        // Viewability needs IO; without support we deliberately record no
        // viewable (never overstate the metric the advertiser pays against).
        if (vio && !alreadySent(el, 'viewable')) vio.observe(el);

        var cta = el.querySelector('[data-ad-cta]');
        if (cta) {
          cta.addEventListener('click', function () {
            emit('ad_click', el);
            beacon(el, 'click');
          });
        }
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>
