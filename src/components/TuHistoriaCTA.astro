---
// Call-to-action block driving readers to /tu-historia.
// CTA-01 (22-jul-2026): rescaled to the conversion-module tier — H3 ceiling,
// prose width (42rem), NewsletterCTA pattern (DESIGN-01b precedent).
// Semantic level stays <h2> in the outline; visual scale is H3.
// `placement` is reported on the GA4 click event so the same block can be
// reused on other surfaces (homepage, etc.) without renaming the event.
interface Props {
  placement?: string;
}
const { placement = 'article-footer' } = Astro.props;
---
{/* Sin mx-auto (desvío del artefacto, criterio 2): la columna real del
    artículo es max-w-none (~821px a 1280), así que centrar la card dejaba
    su borde izquierdo a ~75px de la prosa. Anclada a la izquierda queda
    flush con la prosa (delta 0) — coda editorial; el AdSlot de abajo sigue
    centrado — objeto comercial. */}
<aside class="max-w-[42rem] mt-10 md:mt-12 mb-8" aria-label="Tu Historia">
  <div class="p-6 md:p-8 bg-[var(--bg-cream)] border border-[var(--rule)]">
    <p class="text-[length:var(--text-overline)] leading-[var(--lh-overline)] font-bold tracking-[0.1em] uppercase text-[var(--red)] mb-2">Tu Historia</p>
    <h2 class="font-heading font-semibold text-[length:var(--text-h3)] leading-[var(--lh-h3)] tracking-[-0.01em] text-[var(--navy)] text-balance mb-2">
      ¿Tienes una historia del beis? La redacción quiere leerla.
    </h2>
    <p class="text-[length:var(--text-body-sm)] leading-[var(--lh-body-sm)] text-[var(--ink-2)] mb-5">
      Si eres entrenador, jugador, madre, padre o directivo de liga, queremos escucharte. Cualquier persona con una historia del beis puede enviarla: la redacción la revisa y, si la elegimos, la publicamos en Beisjoven.
    </p>
    <a
      href="/tu-historia"
      data-tuhistoria-cta
      data-placement={placement}
      class="inline-flex w-full sm:w-auto min-h-[44px] items-center justify-center px-5 bg-[var(--red)] text-white text-[length:var(--text-button)] leading-[var(--lh-button)] tracking-[0.02em] font-semibold transition-colors motion-reduce:transition-none hover:bg-[var(--red-dark)] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--gold)]"
    >
      Cuéntanos tu historia →
    </a>
    <p class="mt-3 text-[length:var(--text-metadata)] leading-[var(--lh-metadata)] text-[var(--muted-strong)]">
      Es gratis y toma menos de 5 minutos.
    </p>
  </div>
</aside>
<script is:inline>
  (function () {
    document.querySelectorAll('[data-tuhistoria-cta]').forEach(function (el) {
      if (el.__bjTuHistoriaBound) return;
      el.__bjTuHistoriaBound = true;
      el.addEventListener('click', function () {
        if (typeof gtag !== 'function') return;
        gtag('event', 'tuhistoria_cta_click', { placement: el.getAttribute('data-placement') });
      });
    });
  })();
</script>
