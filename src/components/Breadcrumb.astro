---
interface BreadcrumbItem {
  text: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="bj-container pt-3 pb-1">
  <ol class="flex flex-wrap items-center gap-1" style="font-family:var(--font-body);font-size:0.75rem;color:var(--ink-3);">
    {items.map((item, i) => (
      <li class="flex items-center gap-1">
        {i > 0 && <span aria-hidden="true" style="color:var(--ink-3);opacity:0.5;">›</span>}
        {item.href && i < items.length - 1 ? (
          <a
            href={item.href}
            class="transition-colors duration-150 hover:text-navy"
            style="color:var(--ink-3);text-decoration:none;"
          >{item.text}</a>
        ) : (
          <span style="color:var(--ink-2);font-weight:500;">{item.text}</span>
        )}
      </li>
    ))}
  </ol>
</nav>
