---
interface Props {
  name: string;
  slug: string;
  size?: 'sm' | 'md';
}

const { name, slug, size = 'sm' } = Astro.props;

const KNOWN_SLUGS = new Set(['mlb', 'liga-mexicana', 'seleccion', 'softbol', 'juvenil', 'opinion']);
const bg = KNOWN_SLUGS.has(slug) ? `var(--cat-${slug})` : 'var(--navy)';
// Juvenil gold fails WCAG AA against white text — carve out to navy text.
const fg = slug === 'juvenil' ? 'var(--navy)' : '#fff';

const sizeClasses = size === 'sm'
  ? 'text-[10px] px-1.5 py-0.5 tracking-widest'
  : 'text-[11px] px-2.5 py-1 tracking-widest';
---

<a
  href={`/categoria/${slug}`}
  class:list={['inline-block font-bold uppercase rounded-sm transition-opacity hover:opacity-80', sizeClasses]}
  style={`letter-spacing: 0.05em; background: ${bg}; color: ${fg};`}
>
  {name}
</a>
