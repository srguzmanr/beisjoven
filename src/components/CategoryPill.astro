---
interface Props {
  name: string;
  slug: string;
  size?: 'sm' | 'md';
}

const { name, slug, size = 'sm' } = Astro.props;

const colorMap: Record<string, string> = {
  'mlb': 'bg-[#1e40af] text-white',
  'liga-mexicana': 'bg-[#dc2626] text-white',
  'seleccion': 'bg-[#15803d] text-white',
  'softbol': 'bg-[#7c3aed] text-white',
  'juvenil': 'bg-[#ea580c] text-white',
  'opinion': 'bg-[#374151] text-white',
};

const colors = colorMap[slug] || 'bg-navy text-white';
const sizeClasses = size === 'sm'
  ? 'text-[10px] px-1.5 py-0.5 tracking-widest'
  : 'text-[11px] px-2.5 py-1 tracking-widest';
---

<a
  href={`/categoria/${slug}`}
  class:list={['inline-block font-bold uppercase rounded-sm transition-opacity hover:opacity-80', colors, sizeClasses]}
  style="letter-spacing: 0.05em;"
>
  {name}
</a>
