---
import { getCategoryAccent, getCategoryLabel } from '@/lib/categoryAccents.js';

interface Story {
  id: number;
  slug: string;
  titulo: string;
  extracto: string | null;
  imagen_url: string | null;
  imagen_portada_alt: string | null;
  fecha: string;
  categoria_slug: string;
  categoria_nombre: string;
  autor_nombre: string | null;
}

interface Props {
  story: Story;
  size?: 'md' | 'sm';
}

const { story, size = 'md' } = Astro.props;

const accent = getCategoryAccent(story.categoria_slug);
const label = getCategoryLabel(story.categoria_slug);
const pillFg = story.categoria_slug === 'juvenil' ? 'var(--navy)' : '#fff';
const href = `/articulo/${story.slug}`;
const ratio = size === 'sm' ? '1 / 1' : '16 / 10';
const padLeft = size === 'sm' ? '12px' : '14px';
const headingSize = size === 'sm' ? 'var(--text-h4)' : 'var(--text-h3)';
const headingLh = size === 'sm' ? '1.3' : '1.25';

const dateLabel = story.fecha
  ? new Intl.DateTimeFormat('es-MX', {
      day: 'numeric',
      month: 'short',
      year: 'numeric',
    }).format(new Date(story.fecha))
  : '';

const byline = story.autor_nombre || 'Redacción Beisjoven';
const imgAlt = story.imagen_portada_alt || story.titulo;
---

<a href={href} class="bj-story-card" style={`--bj-accent: ${accent};`}>
  {story.imagen_url ? (
    <img
      src={story.imagen_url}
      alt={imgAlt}
      loading="lazy"
      style={`aspect-ratio: ${ratio};`}
      class="bj-story-card__img"
    />
  ) : (
    <div class="bj-story-card__img ph" style={`aspect-ratio: ${ratio};`} aria-hidden="true"></div>
  )}
  <div class="bj-story-card__body" style={`padding-left: ${padLeft};`}>
    <span class="bj-story-card__pill" style={`color: ${pillFg};`}>{label}</span>
    <h3
      class="bj-story-card__title"
      style={`font-size: ${headingSize}; line-height: ${headingLh};`}
    >
      {story.titulo}
    </h3>
    {size === 'md' && story.extracto && (
      <p class="bj-story-card__deck">{story.extracto}</p>
    )}
    <div class="bj-story-card__meta">
      <span>{byline}</span>
      <span aria-hidden="true">·</span>
      <span>{dateLabel}</span>
    </div>
  </div>
</a>

<style>
  .bj-story-card {
    display: block;
    color: inherit;
    text-decoration: none;
  }

  .bj-story-card__img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  .bj-story-card__body {
    margin-top: 12px;
    border-left: 4px solid var(--bj-accent);
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .bj-story-card__pill {
    align-self: flex-start;
    background: var(--bj-accent);
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 2px;
    line-height: 1;
  }

  .bj-story-card__title {
    font-family: var(--font-heading);
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--navy);
    text-wrap: balance;
    margin: 0;
  }

  .bj-story-card__deck {
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    line-height: var(--lh-body-sm);
    color: var(--gray-medium);
    margin: 0;
  }

  .bj-story-card__meta {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-body);
    font-size: var(--text-metadata);
    line-height: var(--lh-metadata);
    color: var(--gray-medium);
    font-weight: 500;
  }
</style>
