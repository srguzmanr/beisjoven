---
interface Props {
  title: string;
  href?: string;
  moreLabel?: string;
  accent?: string;
  inverse?: boolean;
}

const {
  title,
  href,
  moreLabel = 'Ver todo',
  accent = 'var(--navy)',
  inverse = false,
} = Astro.props;
---

<div
  class:list={['bj-section-head', { 'bj-section-head--inverse': inverse }]}
  style={`--bj-section-accent: ${accent};`}
>
  <h2 class="bj-section-head__title">{title}</h2>
  <span class="bj-section-head__spacer" aria-hidden="true"></span>
  {href && (
    <a class="bj-section-head__more" href={href}>
      {moreLabel}
      <svg
        class="bj-section-head__arrow"
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <line x1="5" y1="12" x2="19" y2="12" />
        <polyline points="12 5 19 12 12 19" />
      </svg>
    </a>
  )}
</div>

<style>
  .bj-section-head {
    display: flex;
    align-items: baseline;
    gap: 12px;
    border-bottom: 2px solid var(--bj-section-accent);
    padding-bottom: 10px;
    margin-bottom: 20px;
  }

  .bj-section-head__title {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: clamp(1.25rem, 1.05rem + 0.6vw, 1.75rem);
    line-height: var(--lh-h2);
    letter-spacing: -0.015em;
    color: var(--navy);
    margin: 0;
  }

  .bj-section-head--inverse .bj-section-head__title {
    color: #fff;
  }

  .bj-section-head__spacer {
    flex: 1;
  }

  .bj-section-head__more {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--navy);
    text-decoration: none;
  }

  .bj-section-head--inverse .bj-section-head__more {
    color: #fff;
  }

  .bj-section-head__arrow {
    flex-shrink: 0;
  }
</style>
