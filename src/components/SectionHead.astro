---
interface Props {
  title: string;
  href?: string;
  moreLabel?: string;
  accent?: string;
  inverse?: boolean;
}

const {
  title,
  href,
  moreLabel = 'Ver todo',
  accent = 'var(--red)',
  inverse = false,
} = Astro.props;
---

<div
  class:list={['bj-section-head', { 'bj-section-head--inverse': inverse }]}
  style={`--bj-section-accent: ${accent};`}
>
  <div class="bj-section-head__left">
    <span class="bj-kicker" style="--kicker: var(--bj-section-accent);">{title}</span>
  </div>
  <span class="bj-section-head__spacer" aria-hidden="true"></span>
  {href && (
    <a class="bj-section-head__more" href={href}>
      {moreLabel}
      <svg
        class="bj-section-head__arrow"
        width="13"
        height="13"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <line x1="5" y1="12" x2="19" y2="12" />
        <polyline points="12 5 19 12 12 19" />
      </svg>
    </a>
  )}
</div>

<style>
  .bj-section-head {
    display: flex;
    align-items: center;
    gap: 12px;
    padding-bottom: 12px;
    margin-bottom: 20px;
    border-bottom: 1px solid var(--rule, rgba(27, 42, 74, 0.10));
    position: relative;
  }

  /* Accent rule under kicker text */
  .bj-section-head::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 40px;
    height: 3px;
    background: var(--bj-section-accent);
    border-radius: 3px;
  }

  .bj-section-head__left {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .bj-section-head--inverse .bj-kicker {
    color: #fff;
  }

  .bj-section-head--inverse .bj-kicker::before {
    background: currentColor;
  }

  .bj-section-head__spacer {
    flex: 1;
  }

  .bj-section-head__more {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--bj-section-accent);
    text-decoration: none;
    transition: opacity 0.15s;
    flex-shrink: 0;
  }

  .bj-section-head--inverse .bj-section-head__more {
    color: rgba(255, 255, 255, 0.72);
  }

  .bj-section-head__more:hover {
    opacity: 0.75;
  }

  .bj-section-head__arrow {
    flex-shrink: 0;
    transition: transform 0.15s;
  }

  .bj-section-head__more:hover .bj-section-head__arrow {
    transform: translateX(2px);
  }
</style>
