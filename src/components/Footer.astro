---
import Logo from '@/components/Logo.astro';

const year = new Date().getFullYear();

// Mismo orden que el nav del header. Slugs intactos.
const categories = [
  { name: 'MLB', href: '/categoria/mlb' },
  { name: 'Ligas Mexicanas', href: '/categoria/liga-mexicana' },
  { name: 'Selección', href: '/categoria/seleccion' },
  { name: 'Juvenil', href: '/categoria/juvenil' },
  { name: 'Softbol', href: '/categoria/softbol' },
  { name: 'Opinión', href: '/categoria/opinion' },
];

const editorial = [
  { name: 'Tu Historia', href: '/tu-historia' },
  { name: 'Newsletter', href: '/#newsletter-form' },
  { name: 'Nuestra Política Editorial', href: '/nosotros' },
];

// Dedupe legal (DESIGN-HF-01): Privacidad y Términos viven SOLO en la
// barra inferior; esta columna queda Nosotros · Contacto.
const site = [
  { name: 'Nosotros', href: '/nosotros' },
  { name: 'Contacto', href: '/contacto' },
];

const legal = [
  { name: 'Política de Privacidad', href: '/privacidad' },
  { name: 'Términos', href: '/terminos' },
  { name: 'Preferencias de cookies', href: '/avisos-cookies' },
  { name: 'Contacto', href: '/contacto' },
];
---

<footer class="site-footer">
  <div class="site-footer__container">
    <div class="site-footer__grid">

      <div class="site-footer__brand">
        <a href="/" aria-label="Beisjoven — inicio" class="site-footer__logo">
          <Logo format="lockup" height={72} width={153} class="footer-logo-img" />
        </a>
        <p class="site-footer__mission">Somos el futuro del beis</p>
        <p class="site-footer__description">
          Beisjoven · Cobertura editorial del béisbol y softbol en español. Desde 2012.
        </p>
        <div class="site-footer__social">
          <a href="https://facebook.com/beisjoven" target="_blank" rel="noopener" aria-label="Facebook" class="social-link">
            <svg fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href="https://instagram.com/beisjoven" target="_blank" rel="noopener" aria-label="Instagram" class="social-link">
            <svg fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
          <a href="https://x.com/beisjoven" target="_blank" rel="noopener" aria-label="X (Twitter)" class="social-link">
            <svg fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
        </div>
      </div>

      <nav class="site-footer__col" aria-label="Categorías editoriales">
        <h4 class="site-footer__heading">Categorías</h4>
        <ul class="site-footer__links">
          {categories.map((item) => (
            <li><a href={item.href} class="footer-link">{item.name}</a></li>
          ))}
        </ul>
      </nav>

      <nav class="site-footer__col" aria-label="Recursos editoriales">
        <h4 class="site-footer__heading">Editorial</h4>
        <ul class="site-footer__links">
          {editorial.map((item) => (
            <li><a href={item.href} class="footer-link">{item.name}</a></li>
          ))}
        </ul>
      </nav>

      <nav class="site-footer__col" aria-label="Información del sitio">
        <h4 class="site-footer__heading">Sitio</h4>
        <ul class="site-footer__links">
          {site.map((item) => (
            <li><a href={item.href} class="footer-link">{item.name}</a></li>
          ))}
        </ul>
      </nav>

    </div>

    <div class="site-footer__bottom">
      <p class="site-footer__copyright">
        &copy; {year} Noboru LLC, operando como Beisjoven. Todos los derechos reservados.
      </p>
      <ul class="site-footer__legal">
        {legal.map((item, i) => (
          <>
            {i > 0 && <li aria-hidden="true" class="site-footer__dot">·</li>}
            <li><a href={item.href} class="legal-link">{item.name}</a></li>
          </>
        ))}
      </ul>
    </div>
  </div>
</footer>

<style>
  /* ============================================================
     Footer (DESIGN-HF-01, Spec v1.1)
     Desktop ≥1024: grid 1.4fr 1fr 1fr 1fr, gap 48px.
     768–1023: marca en fila completa + 3 columnas de links.
     <768: una sola columna apilada, alineada a la izquierda.
     ============================================================ */
  .site-footer {
    background: var(--navy);
    color: #ffffff;
    margin-top: auto;
  }
  .site-footer__container {
    max-width: var(--w-page);
    margin: 0 auto;
    padding: 48px 16px 24px;
  }

  .site-footer__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
  }

  /* --- Marca --- */
  .site-footer__logo {
    display: inline-block;
    margin-bottom: 16px;
  }
  .site-footer__logo:focus-visible {
    outline: 2px solid var(--gold);
    outline-offset: 2px;
  }
  :global(.footer-logo-img) {
    height: 72px; /* arte ≈ 70% del PNG → ~50px visuales */
    width: auto;
    display: block;
  }
  .site-footer__mission {
    font-family: var(--font-heading);
    font-size: var(--text-h4);
    line-height: var(--lh-h4);
    font-weight: 600;
    color: #ffffff;
    margin: 0 0 8px;
  }
  .site-footer__description {
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    line-height: var(--lh-body-sm);
    color: rgba(255, 255, 255, 0.7);
    margin: 0;
    max-width: 36ch;
  }
  .site-footer__social {
    display: flex;
    margin-top: 12px;
    /* compensa el aire interno del área táctil 44×44 del primer ícono */
    margin-left: -11px;
  }
  .social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    color: rgba(255, 255, 255, 0.7);
    transition: color 120ms ease-out;
  }
  .social-link:hover { color: var(--gold); }
  .social-link:focus-visible {
    outline: 2px solid var(--gold);
    outline-offset: 2px;
  }
  .social-link svg { width: 22px; height: 22px; }

  /* --- Columnas de links --- */
  .site-footer__heading {
    font-family: var(--font-body);
    font-size: var(--text-overline);
    line-height: var(--lh-overline);
    font-weight: 600;
    letter-spacing: var(--tracking-overline);
    text-transform: uppercase;
    color: var(--gold);
    margin: 0 0 16px;
  }
  .site-footer__links {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .footer-link {
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    line-height: var(--lh-body-sm);
    color: rgba(255, 255, 255, 0.85);
    text-decoration: none;
    transition: color 120ms ease-out;
    /* Área táctil ≥44px en móvil: padding en el link, no solo texto. */
    display: flex;
    align-items: center;
    min-height: 44px;
  }
  .footer-link:hover {
    color: var(--gold);
  }
  .footer-link:focus-visible {
    outline: 2px solid var(--gold);
    outline-offset: 2px;
  }

  /* --- Barra inferior --- */
  .site-footer__bottom {
    margin-top: 40px;
    padding-top: 24px;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
  }
  .site-footer__copyright {
    font-family: var(--font-body);
    font-size: var(--text-caption);
    line-height: var(--lh-caption);
    letter-spacing: var(--tracking-caption);
    /* 60% sobre navy = 6.1:1, pasa AA para caption (verificado DESIGN-HF-01). */
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
  }
  .site-footer__legal {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    column-gap: 8px;
    row-gap: 4px;
  }
  .legal-link {
    font-family: var(--font-body);
    font-size: var(--text-caption);
    line-height: var(--lh-caption);
    letter-spacing: var(--tracking-caption);
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    transition: color 120ms ease-out;
    display: inline-flex;
    align-items: center;
    min-height: 44px;
  }
  .legal-link:hover { color: var(--gold); }
  .legal-link:focus-visible {
    outline: 2px solid var(--gold);
    outline-offset: 2px;
  }
  .site-footer__dot { color: rgba(255, 255, 255, 0.35); }

  /* --- 768–1023: marca arriba, 3 columnas de links --- */
  @media (min-width: 768px) {
    .site-footer__container { padding: 56px 32px 28px; }
    .site-footer__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 32px;
    }
    .site-footer__brand { grid-column: 1 / -1; }
    .site-footer__bottom {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
    /* Desktop/tablet: filas de links a 12px (spec); el área táctil de
       44px aplica solo en móvil. */
    .footer-link { min-height: 0; }
    .site-footer__links li + li { margin-top: 12px; }
    .legal-link { min-height: 0; }
  }

  /* --- ≥1024: grid completo de 4 columnas --- */
  @media (min-width: 1024px) {
    .site-footer__container { padding: 64px 32px 32px; }
    .site-footer__grid {
      grid-template-columns: 1.4fr 1fr 1fr 1fr;
      gap: 48px;
    }
    .site-footer__brand { grid-column: auto; }
    .site-footer__bottom { margin-top: 48px; }
  }
</style>
