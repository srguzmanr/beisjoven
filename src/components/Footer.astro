---
const year = new Date().getFullYear();

const categories = [
  { name: 'MLB', href: '/categoria/mlb' },
  { name: 'Ligas Mexicanas', href: '/categoria/liga-mexicana' },
  { name: 'Selección', href: '/categoria/seleccion' },
  { name: 'Juvenil', href: '/categoria/juvenil' },
  { name: 'Softbol', href: '/categoria/softbol' },
  { name: 'Opinión', href: '/categoria/opinion' },
];

const editorial = [
  { name: 'Tu Historia', href: '/tu-historia' },
  { name: 'Newsletter', href: '/#newsletter-form' },
  { name: 'Nuestra Política Editorial', href: '/nosotros' },
];

const site = [
  { name: 'Nosotros', href: '/nosotros' },
  { name: 'Contacto', href: '/contacto' },
  { name: 'Política de Privacidad', href: '/privacidad' },
  { name: 'Términos de Uso', href: '/terminos' },
];
---

<footer class="bg-navy text-white mt-auto">
  <div class="max-w-[1200px] mx-auto px-6 py-16">

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">

      <!-- Columna 1: Marca -->
      <div class="md:col-span-2 lg:col-span-1 flex flex-col items-center md:items-start text-center md:text-left">
        <a href="/" aria-label="Beisjoven — inicio" class="inline-block mb-4">
          <img
            src="/brand/logo-lockup.png"
            alt="Beisjoven"
            class="h-10"
            style="filter: brightness(0) invert(1);"
          />
        </a>
        <p class="footer-tagline mb-3">Somos el futuro del beis</p>
        <p class="footer-signature">
          Beisjoven · Cobertura editorial del béisbol y softbol en español. Desde 2012.
        </p>
        <div class="flex gap-4 mt-5 justify-center md:justify-start">
          <a href="https://facebook.com/beisjoven" target="_blank" rel="noopener" aria-label="Facebook" class="footer-social">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href="https://instagram.com/beisjoven" target="_blank" rel="noopener" aria-label="Instagram" class="footer-social">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
          <a href="https://x.com/beisjoven" target="_blank" rel="noopener" aria-label="X (Twitter)" class="footer-social">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
        </div>
      </div>

      <!-- Columna 2: Categorías -->
      <nav aria-label="Categorías editoriales">
        <h4 class="footer-col-heading">Categorías</h4>
        <ul class="space-y-3">
          {categories.map((item) => (
            <li>
              <a href={item.href} class="footer-link">{item.name}</a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Columna 3: Editorial -->
      <nav aria-label="Recursos editoriales">
        <h4 class="footer-col-heading">Editorial</h4>
        <ul class="space-y-3">
          {editorial.map((item) => (
            <li>
              <a href={item.href} class="footer-link">{item.name}</a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Columna 4: Sitio -->
      <nav aria-label="Información del sitio">
        <h4 class="footer-col-heading">Sitio</h4>
        <ul class="space-y-3">
          {site.map((item) => (
            <li>
              <a href={item.href} class="footer-link">{item.name}</a>
            </li>
          ))}
        </ul>
      </nav>

    </div>

    <!-- Bottom bar -->
    <div class="footer-bottom mt-12 pt-6 flex flex-col sm:flex-row sm:justify-between sm:items-center gap-3 text-center sm:text-left">
      <p class="footer-copyright">&copy; {year} Beisjoven. Todos los derechos reservados.</p>
      <ul class="footer-legal-links flex flex-wrap justify-center sm:justify-end items-center gap-x-3 gap-y-1">
        <li><a href="/privacidad" class="footer-legal-link">Política de Privacidad</a></li>
        <li aria-hidden="true" class="footer-separator">·</li>
        <li><a href="/terminos" class="footer-legal-link">Términos</a></li>
        <li aria-hidden="true" class="footer-separator">·</li>
        <li><a href="/contacto" class="footer-legal-link">Contacto</a></li>
      </ul>
    </div>

  </div>
</footer>

<style>
  .footer-tagline {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 15px;
    color: #ffffff;
    line-height: 1.4;
  }

  .footer-signature {
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.7);
  }

  .footer-social {
    color: rgba(255, 255, 255, 0.55);
    transition: color 0.15s ease;
    /* 44px touch target */
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 44px;
    min-height: 44px;
  }
  .footer-social:hover {
    color: rgba(255, 255, 255, 1);
  }

  .footer-col-heading {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1rem;
    line-height: 1.4;
  }

  .footer-link {
    font-family: var(--font-body);
    font-size: 15px;
    color: rgba(255, 255, 255, 0.85);
    text-decoration: none;
    transition: color 0.15s ease;
    /* 44px touch target */
    display: inline-block;
    padding: 4px 0;
    min-height: 44px;
    line-height: 36px;
  }
  .footer-link:hover {
    color: rgba(255, 255, 255, 1);
    text-decoration: underline;
  }

  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .footer-copyright {
    font-family: var(--font-body);
    font-size: 14px;
    color: rgba(255, 255, 255, 0.6);
  }

  .footer-legal-link {
    font-family: var(--font-body);
    font-size: 12px;
    color: rgba(255, 255, 255, 0.5);
    text-decoration: none;
    transition: color 0.15s ease;
    padding: 4px 0;
  }
  .footer-legal-link:hover {
    color: rgba(255, 255, 255, 0.85);
  }

  .footer-separator {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.3);
  }

  /* Mobile: stack, gap, marca centrada */
  @media (max-width: 767px) {
    .footer-link {
      /* reduce height slightly on small screens, but keep ≥44px */
      line-height: 26px;
      min-height: 44px;
    }
  }
</style>
