---
const currentPath = Astro.url.pathname;

const categories = [
  { name: 'MLB', slug: 'mlb' },
  { name: 'Ligas MX', slug: 'liga-mexicana' },
  { name: 'Selección', slug: 'seleccion' },
  { name: 'Softbol', slug: 'softbol' },
  { name: 'Juvenil', slug: 'juvenil' },
];

function isActive(slug: string) {
  return currentPath.startsWith(`/categoria/${slug}`);
}
---

<!-- Top Bar -->
<div class="bg-navy text-white text-xs py-1.5 hidden md:block">
  <div class="max-w-7xl mx-auto px-4 flex justify-between items-center">
    <span id="current-date" class="text-gray-300"></span>
    <div class="flex gap-4">
      <a href="/contacto" class="hover:text-white/80 transition-colors">Contacto</a>
    </div>
  </div>
</div>

<!-- Header -->
<header class="bg-white border-b border-gray-100 sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4">
    <!-- Logo + Search Row -->
    <div class="flex items-center justify-between h-16">
      <a href="/" class="flex items-center gap-2">
        <img src="/BJ-Logo-H2-WEB.png" alt="Beisjoven" class="h-10" />
      </a>

      <!-- Desktop Search -->
      <form action="/buscar" method="get" class="hidden md:flex items-center">
        <input
          type="text"
          name="q"
          placeholder="Buscar noticias..."
          class="w-64 px-3 py-1.5 text-sm border border-gray-200 rounded-l-lg focus:outline-none focus:border-steel-blue"
        />
        <button type="submit" class="px-3 py-1.5 bg-navy text-white text-sm rounded-r-lg hover:bg-navy-dark transition-colors">
          Buscar
        </button>
      </form>

      <!-- Mobile Hamburger -->
      <button id="mobile-menu-btn" class="md:hidden p-2 text-navy" aria-label="Abrir menú">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Desktop Nav -->
    <nav class="hidden md:block border-t border-gray-50 -mx-4 px-4">
      <ul class="flex items-center gap-1 -mb-px">
        <li>
          <a
            href="/"
            class:list={[
              'inline-block px-3 py-2.5 text-sm font-semibold uppercase tracking-wide transition-colors border-b-2',
              currentPath === '/'
                ? 'border-rojo text-navy'
                : 'border-transparent text-gray-600 hover:text-navy hover:border-gray-300'
            ]}
          >
            Inicio
          </a>
        </li>
        {categories.map((cat) => (
          <li>
            <a
              href={`/categoria/${cat.slug}`}
              class:list={[
                'inline-block px-3 py-2.5 text-sm font-semibold uppercase tracking-wide transition-colors border-b-2',
                isActive(cat.slug)
                  ? 'border-rojo text-navy'
                  : 'border-transparent text-gray-600 hover:text-navy hover:border-gray-300'
              ]}
            >
              {cat.name}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-gray-100">
    <div class="px-4 py-3">
      <form action="/buscar" method="get" class="flex mb-3">
        <input
          type="text"
          name="q"
          placeholder="Buscar noticias..."
          class="flex-1 px-3 py-2 text-sm border border-gray-200 rounded-l-lg focus:outline-none"
        />
        <button type="submit" class="px-4 py-2 bg-navy text-white text-sm rounded-r-lg">
          Buscar
        </button>
      </form>
      <ul class="space-y-1">
        <li>
          <a href="/" class:list={['block px-3 py-2 rounded-lg text-sm font-semibold', currentPath === '/' ? 'bg-gris-bg text-navy' : 'text-gray-600']}>
            Inicio
          </a>
        </li>
        {categories.map((cat) => (
          <li>
            <a
              href={`/categoria/${cat.slug}`}
              class:list={['block px-3 py-2 rounded-lg text-sm font-semibold', isActive(cat.slug) ? 'bg-gris-bg text-navy' : 'text-gray-600']}
            >
              {cat.name}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</header>

<script is:inline>
  // Mobile menu toggle
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  if (btn && menu) {
    btn.addEventListener('click', () => menu.classList.toggle('hidden'));
  }
  // Date display
  const dateEl = document.getElementById('current-date');
  if (dateEl) {
    const opts = { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' };
    const today = new Date().toLocaleDateString('es-MX', opts);
    dateEl.textContent = today.charAt(0).toUpperCase() + today.slice(1);
  }
</script>
