---
import StoryCard from '@/components/StoryCard.astro';
import ListCard from '@/components/ListCard.astro';
import SectionHead from '@/components/SectionHead.astro';
import VideoTile from '@/components/VideoTile.astro';

interface Story {
  id: number;
  slug: string;
  titulo: string;
  extracto: string | null;
  imagen_url: string | null;
  imagen_portada_alt: string | null;
  fecha: string;
  categoria_slug: string;
  categoria_nombre: string;
  autor_nombre: string | null;
  read_time_minutes?: number;
}

interface Video {
  id: number;
  slug: string;
  titulo: string;
  thumbnail_url: string | null;
  youtube_id?: string;
}

interface Props {
  latest: Story[];
  masLeidos: Story[];
  videos?: Video[];
}

const { latest, masLeidos, videos = [] } = Astro.props;
const hasVideos = videos.length > 0;
---

<section class="bj-mixed-feed">
  <div class="bj-container">
    <div class="bj-mixed-feed__grid">
      <!-- Main: "Lo último" -->
      <div class="bj-mixed-feed__main">
        <SectionHead title="Lo último" accent="var(--red)" />
        <div class="bj-mixed-feed__cards">
          {latest.map((story) => (
            <StoryCard story={story} size="md" />
          ))}
        </div>
      </div>

      <!-- Rail: Más leídos + Videos -->
      <aside class="bj-mixed-feed__rail">
        <div class="bj-mixed-feed__block">
          <SectionHead title="Más leídos" accent="var(--navy)" />
          <div class="bj-mixed-feed__list">
            {masLeidos.map((story, i) => (
              <ListCard story={story} rank={i + 1} />
            ))}
          </div>
        </div>

        {hasVideos && (
          <div class="bj-mixed-feed__block">
            <SectionHead title="Videos" href="/videos" moreLabel="Ver más" accent="var(--red)" />
            <div class="bj-mixed-feed__list">
              {videos.map((video) => (
                <VideoTile video={video} />
              ))}
            </div>
          </div>
        )}
      </aside>
    </div>
  </div>
</section>

<style>
  .bj-mixed-feed {
    background: var(--surface-2, #F6F5F1);
    padding: 40px 0;
    border-top: 1px solid var(--rule, rgba(27, 42, 74, 0.10));
    border-bottom: 1px solid var(--rule, rgba(27, 42, 74, 0.10));
  }

  @media (min-width: 768px) {
    .bj-mixed-feed {
      padding: 56px 0;
    }
  }

  .bj-mixed-feed__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
  }

  @media (min-width: 1024px) {
    .bj-mixed-feed__grid {
      grid-template-columns: 1.55fr 1fr;
      gap: 52px;
      align-items: start;
    }
  }

  .bj-mixed-feed__cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: 28px;
  }

  @media (min-width: 640px) {
    .bj-mixed-feed__cards {
      grid-template-columns: 1fr 1fr;
      gap: 28px;
    }
  }

  .bj-mixed-feed__rail {
    display: flex;
    flex-direction: column;
    gap: 36px;
  }

  .bj-mixed-feed__block {
    /* Each block is a self-contained unit */
  }

  .bj-mixed-feed__list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
</style>
