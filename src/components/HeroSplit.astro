---
import type { Articulo } from '@/lib/supabase';
import { formatDate } from '@/lib/content';

interface Props {
  story: Articulo;
}

const { story } = Astro.props;

const catSlug = story.categoria?.slug ?? '';
const catName = story.categoria?.nombre ?? '';
const accent = catSlug ? `var(--cat-${catSlug})` : 'var(--gold)';
// Juvenil pill stays gold; pill text must render in navy for contrast.
const pillText = catSlug === 'juvenil' ? 'var(--navy)' : '#fff';
const altText = story.imagen_portada_alt ?? '';
const byline = story.autor?.nombre || 'Redacción Beisjoven';
const date = story.fecha ? formatDate(story.fecha) : '';
const href = `/articulo/${story.slug}`;
---

{story.imagen_url && (
  <article class="hero-split" style={`--accent:${accent};--pill-text:${pillText};`}>
    <a href={href} class="hero-split__link">
      <div class="hero-split__media">
        <img
          src={story.imagen_url}
          alt={altText}
          loading="eager"
          fetchpriority="high"
          class="hero-split__image"
        />
        {story.photo_credit && (
          <span class="hero-split__credit">Foto: {story.photo_credit}</span>
        )}
      </div>
      <div class="hero-split__text">
        <span class="hero-split__pill">{catName}</span>
        <h1 class="hero-split__h1">{story.titulo}</h1>
        {story.extracto && (
          <p class="hero-split__deck">{story.extracto}</p>
        )}
        <div class="hero-split__meta">
          <span class="hero-split__byline">{byline}</span>
          {date && <><span aria-hidden="true">·</span><span>{date}</span></>}
        </div>
      </div>
    </a>
  </article>
)}

<style>
  .hero-split {
    background: #fff;
    padding: 24px 16px 0;
  }
  .hero-split__link {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
    align-items: center;
    color: inherit;
    text-decoration: none;
  }
  .hero-split__media {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    border-radius: 4px;
  }
  .hero-split__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero-split__credit {
    position: absolute;
    right: 8px;
    bottom: 8px;
    color: #fff;
    background: rgba(0, 0, 0, 0.55);
    font-family: var(--font-body);
    font-size: 11px;
    padding: 4px 8px;
    border-radius: 2px;
  }
  .hero-split__text {
    border-left: 4px solid var(--accent);
    padding-left: 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .hero-split__pill {
    align-self: flex-start;
    background: var(--accent);
    color: var(--pill-text);
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 4px 8px;
    border-radius: 2px;
  }
  .hero-split__h1 {
    font-family: var(--font-heading);
    font-weight: 700;
    color: var(--navy);
    letter-spacing: -0.02em;
    text-wrap: balance;
    margin: 0;
    font-size: clamp(1.75rem, 1.45rem + 1.2vw, 2.5rem);
    line-height: 1.15;
  }
  .hero-split__deck {
    font-family: var(--font-body);
    color: #4B5563;
    max-width: 35rem;
    margin: 0;
    font-size: 1rem;
    line-height: 1.6;
  }
  .hero-split__meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: #6B7280;
  }
  .hero-split__byline {
    font-weight: 600;
    color: var(--navy);
  }

  @media (min-width: 768px) {
    .hero-split {
      padding: 32px 32px 0;
      max-width: 75rem;
      margin: 0 auto;
    }
    .hero-split__link {
      grid-template-columns: 1.15fr 1fr;
      gap: 40px;
    }
    .hero-split__media {
      aspect-ratio: 4 / 3;
    }
    .hero-split__text {
      padding-left: 24px;
      gap: 14px;
    }
    .hero-split__deck {
      font-size: 1.0625rem;
    }
  }
</style>
