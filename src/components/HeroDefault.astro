---
import type { Articulo } from '@/lib/supabase';
import ArticleMeta from '@/components/ArticleMeta.astro';

interface Props {
  story: Articulo;
}

const { story } = Astro.props;

const catSlug = story.categoria?.slug ?? '';
const catName = story.categoria?.nombre ?? '';
const accent = catSlug ? `var(--cat-${catSlug})` : 'var(--gold)';
// Juvenil pill stays gold; pill text must render in navy for contrast.
const pillText = catSlug === 'juvenil' ? 'var(--navy)' : '#fff';
const altText = story.imagen_portada_alt ?? '';
const href = `/articulo/${story.slug}`;
---

{story.imagen_url && (
  <article class="hero-default" style={`--accent:${accent};--pill-text:${pillText};`}>
    <a href={href} class="hero-default__link">
      <div class="hero-default__media">
        <img
          src={story.imagen_url}
          alt={altText}
          loading="eager"
          fetchpriority="high"
          class="hero-default__image"
        />
        <div class="hero-default__gradient" aria-hidden="true"></div>
        <div class="hero-default__overlay">
          <span class="hero-default__pill">{catName}</span>
          <h1 class="hero-default__h1">{story.titulo}</h1>
          <div class="hero-default__overlay-meta">
            <ArticleMeta
              fecha={story.fecha}
              autorNombre={story.autor?.nombre ?? null}
              readMinutes={story.read_time_minutes}
              variant="card"
              inverse={true}
              showAvatar={false}
            />
          </div>
        </div>
        {story.photo_credit && (
          <span class="hero-default__credit">Foto: {story.photo_credit}</span>
        )}
      </div>
      <div class="hero-default__prose">
        {story.extracto && (
          <p class="hero-default__deck">{story.extracto}</p>
        )}
        <div class="hero-default__meta-mobile">
          <ArticleMeta
            fecha={story.fecha}
            autorNombre={story.autor?.nombre ?? null}
            readMinutes={story.read_time_minutes}
            variant="card"
            showAvatar={false}
          />
        </div>
      </div>
    </a>
  </article>
)}

<style>
  .hero-default { background: #fff; }
  .hero-default__link { display: block; color: inherit; text-decoration: none; }

  .hero-default__media {
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;
  }
  .hero-default__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }
  .hero-default__gradient {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background: linear-gradient(to top,
      rgba(15, 27, 51, 0.78) 0%,
      rgba(15, 27, 51, 0.4) 18%,
      rgba(15, 27, 51, 0) 38%);
  }
  .hero-default__overlay {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 2;
    padding: 20px 16px 22px;
    color: #fff;
  }
  .hero-default__pill {
    align-self: flex-start;
    display: inline-block;
    background: var(--accent);
    color: var(--pill-text);
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 4px 8px;
    border-radius: 2px;
    line-height: 1;
    margin-bottom: 10px;
  }
  .hero-default__h1 {
    font-family: var(--font-heading);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: #fff;
    text-wrap: balance;
    margin: 0;
    font-size: clamp(1.625rem, 1.4rem + 1.2vw, 2.125rem);
    line-height: 1.15;
  }
  .hero-default__overlay-meta {
    display: none;
    margin-top: 12px;
  }
  .hero-default__credit {
    position: absolute;
    right: 8px;
    bottom: 8px;
    z-index: 2;
    color: #fff;
    background: rgba(0, 0, 0, 0.55);
    font-family: var(--font-body);
    font-size: 11px;
    padding: 4px 8px;
    border-radius: 2px;
  }

  .hero-default__prose {
    padding: 16px 16px 4px;
    max-width: 60rem;
    margin: 0 auto;
  }
  .hero-default__deck {
    font-family: var(--font-body);
    color: #4B5563;
    margin: 0;
    font-size: 1rem;
    line-height: 1.6;
  }
  .hero-default__meta-mobile {
    margin-top: 12px;
  }

  @media (min-width: 768px) {
    .hero-default__media {
      aspect-ratio: 16 / 9;
    }
    .hero-default__overlay {
      padding: 28px 32px 30px;
    }
    .hero-default__pill {
      margin-bottom: 14px;
    }
    .hero-default__h1 {
      font-size: clamp(2rem, 1.55rem + 1.4vw, 2.75rem);
      line-height: 1.1;
    }
    .hero-default__overlay-meta {
      display: block;
    }
    .hero-default__prose {
      display: none;
    }
  }
</style>
