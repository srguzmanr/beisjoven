---
import { getCategoryAccent, getCategoryLabel } from '@/lib/categoryAccents.js';

interface Story {
  id: number;
  slug: string;
  titulo: string;
  extracto: string | null;
  imagen_url: string | null;
  imagen_portada_alt: string | null;
  fecha: string;
  categoria_slug: string;
  categoria_nombre: string;
  autor_nombre: string | null;
  read_time_minutes?: number;
}

interface Props {
  story: Story;
  rank?: number;
  inverse?: boolean;
}

const { story, rank, inverse = false } = Astro.props;

const accent = getCategoryAccent(story.categoria_slug);
const label = getCategoryLabel(story.categoria_slug);
const pillFg = story.categoria_slug === 'juvenil' ? 'var(--navy)' : '#fff';
const href = `/articulo/${story.slug}`;
const hasRank = typeof rank === 'number';
const gridCols = hasRank ? '20px 72px 1fr' : '72px 1fr';

const dateLabel = story.fecha
  ? new Intl.DateTimeFormat('es-MX', {
      day: 'numeric',
      month: 'short',
      year: 'numeric',
    }).format(new Date(story.fecha))
  : '';

const readMin = story.read_time_minutes ?? 1;
const imgAlt = story.imagen_portada_alt || story.titulo;
---

<a
  href={href}
  class:list={['bj-list-card', { 'bj-list-card--inverse': inverse }]}
  style={`--bj-accent: ${accent}; grid-template-columns: ${gridCols};`}
>
  {hasRank && <span class="bj-list-card__rank">{rank}</span>}
  {story.imagen_url ? (
    <img
      src={story.imagen_url}
      alt={imgAlt}
      loading="lazy"
      class="bj-list-card__img"
    />
  ) : (
    <div class="bj-list-card__img ph" aria-hidden="true"></div>
  )}
  <div class="bj-list-card__body">
    <span class="bj-list-card__pill" style={`color: ${pillFg};`}>{label}</span>
    <h4 class="bj-list-card__title">{story.titulo}</h4>
    <div class="bj-list-card__meta">
      <span>Redacción Beisjoven</span>
      <span aria-hidden="true">·</span>
      <time datetime={story.fecha}>{dateLabel}</time>
      <span aria-hidden="true">·</span>
      <span>{readMin} min</span>
    </div>
  </div>
</a>

<style>
  .bj-list-card {
    display: grid;
    gap: 12px;
    align-items: start;
    padding: 14px 0;
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
  }

  .bj-list-card--inverse {
    color: #fff;
    border-bottom-color: rgba(255, 255, 255, 0.1);
  }

  .bj-list-card__rank {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 20px;
    letter-spacing: -0.02em;
    line-height: 1;
    color: var(--navy);
  }

  .bj-list-card--inverse .bj-list-card__rank {
    color: rgba(255, 255, 255, 0.6);
  }

  .bj-list-card__img {
    display: block;
    width: 72px;
    height: 72px;
    object-fit: cover;
    aspect-ratio: 1 / 1;
  }

  .bj-list-card__body {
    border-left: 3px solid var(--bj-accent);
    padding-left: 10px;
    min-width: 0;
  }

  .bj-list-card__pill {
    display: inline-block;
    background: var(--bj-accent);
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 2px;
    line-height: 1;
    margin-bottom: 4px;
  }

  .bj-list-card__title {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 15px;
    line-height: 1.3;
    letter-spacing: -0.005em;
    color: var(--navy);
    text-wrap: balance;
    margin: 0;
  }

  .bj-list-card--inverse .bj-list-card__title {
    color: #fff;
  }

  .bj-list-card__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 4px;
    margin-top: 6px;
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--gray-medium);
    font-weight: 500;
    min-width: 0;
  }

  .bj-list-card--inverse .bj-list-card__meta {
    color: rgba(255, 255, 255, 0.6);
  }
</style>
