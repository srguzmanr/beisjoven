---
// DESIGN-04f: Newsletter signup ("El Diamante") — last module of homepage stack.
// Reuses the established direct-insert pattern from public/js/pages.js
// (submitNewsletter): anon client → suscriptores.insert, with 23505 handling
// for duplicate emails. No RPC, no new lib helper — anon RLS policy already
// permits the insert (same row was being written by the legacy newsletter page).
---

<div class="bj-newsletter">
  <div class="bj-newsletter__inner bj-container">
    <div class="bj-newsletter__copy">
      <span class="bj-newsletter__eyebrow">Newsletter</span>
      <h3 class="bj-newsletter__title">
        El Diamante &mdash; Lo esencial del beis mexicano, cada mañana.
      </h3>
      <p class="bj-newsletter__subtitle">
        7 minutos de lectura. Gratis. En español.
      </p>
    </div>

    <form id="newsletter-form" class="bj-newsletter__form" novalidate>
      <div class="bj-newsletter__fields">
        <input
          type="email"
          name="email"
          required
          placeholder="tu@email.com"
          autocomplete="email"
          aria-label="Correo electrónico"
          class="bj-newsletter__input"
        />
        <button type="submit" class="bj-newsletter__button">Suscribirse</button>
      </div>
      <div class="bj-newsletter__status form-status" role="status" aria-live="polite"></div>
      <p class="form-microcopy bj-newsletter__microcopy">
        Al suscribirte aceptas nuestra <a href="/privacidad">Política de Privacidad</a>.
      </p>
    </form>
  </div>
</div>

<script is:inline src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script is:inline>
  (function () {
    var form = document.getElementById('newsletter-form');
    if (!form) return;

    var SUPABASE_URL = 'https://yulkbjpotfmwqkzzfegg.supabase.co';
    var SUPABASE_ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inl1bGtianBvdGZtd3FrenpmZWdnIiwicm9sZSI6ImFub24iLCJpYXQiOjE3Njk2OTk3NTYsImV4cCI6MjA4NTI3NTc1Nn0.PK8mq4CeQkTdurdJ1EV_GOkrY2X4SCsst8O1NnoBWAU';

    var EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    var input = form.querySelector('input[name="email"]');
    var button = form.querySelector('button[type="submit"]');
    var status = form.querySelector('.form-status');

    function setStatus(message, tone) {
      status.textContent = message;
      status.dataset.tone = tone || '';
    }

    function setBusy(busy) {
      button.disabled = busy;
      button.textContent = busy ? 'Enviando...' : 'Suscribirse';
    }

    function showSuccess() {
      var parent = form.parentNode;
      var done = document.createElement('p');
      done.className = 'bj-newsletter__success';
      done.textContent = '¡Listo! Cuando arranquemos los envíos te avisamos.';
      parent.replaceChild(done, form);
    }

    form.addEventListener('submit', async function (event) {
      event.preventDefault();
      try {
        var email = (input.value || '').trim();
        if (!email || !EMAIL_RE.test(email)) {
          setStatus('Ingresa un correo válido.', 'error');
          return;
        }

        if (!window.supabase || !window.supabase.createClient) {
          setStatus('Algo falló. Intenta de nuevo.', 'error');
          console.error('[NewsletterBlock] Supabase client not loaded');
          return;
        }

        setBusy(true);
        setStatus('', '');

        var client = window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);
        var result = await client
          .from('suscriptores')
          .insert([{ email: email, activo: true }]);

        var error = result && result.error;
        if (error) {
          var isDuplicate =
            error.code === '23505' ||
            (error.message && error.message.toLowerCase().indexOf('duplicate') !== -1);
          if (isDuplicate) {
            setStatus('Ya estás suscrito a El Diamante.', 'muted');
          } else {
            setStatus('Algo falló. Intenta de nuevo.', 'error');
            console.error('[NewsletterBlock] Insert failed:', error);
          }
          setBusy(false);
          return;
        }

        showSuccess();
      } catch (err) {
        console.error('[NewsletterBlock] Submit threw:', err);
        setStatus('Algo falló. Intenta de nuevo.', 'error');
        setBusy(false);
      }
    });
  })();
</script>

<style>
  .bj-newsletter {
    background: var(--navy, #1B2A4A);
    padding: 40px 0;
    position: relative;
    overflow: hidden;
  }

  /* Subtle gold accent strip at top */
  .bj-newsletter::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--gold, #D4A843) 0%, var(--gold-light, #E1BC6A) 50%, var(--gold, #D4A843) 100%);
  }

  @media (min-width: 768px) {
    .bj-newsletter {
      padding: 56px 0;
    }
  }

  .bj-newsletter__inner {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  @media (min-width: 768px) {
    .bj-newsletter__inner {
      flex-direction: row;
      align-items: center;
      gap: 48px;
    }
  }

  .bj-newsletter__copy {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  @media (min-width: 768px) {
    .bj-newsletter__copy {
      flex: 1;
      min-width: 0;
    }
  }

  .bj-newsletter__eyebrow {
    font-family: var(--font-heading);
    font-size: 10px;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold, #D4A843);
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .bj-newsletter__eyebrow::before {
    content: '';
    display: inline-block;
    width: 20px;
    height: 2px;
    background: var(--gold, #D4A843);
    border-radius: 2px;
  }

  .bj-newsletter__title {
    font-family: var(--font-heading);
    font-size: clamp(1.125rem, 1rem + 0.5vw, 1.5rem);
    font-weight: 800;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: #fff;
    margin: 0;
    text-wrap: balance;
  }

  .bj-newsletter__subtitle {
    font-family: var(--font-body);
    font-size: 13px;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.55);
    margin: 0;
  }

  .bj-newsletter__form {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  @media (min-width: 768px) {
    .bj-newsletter__form {
      flex: 0 0 auto;
      min-width: 320px;
    }
  }

  .bj-newsletter__fields {
    display: flex;
    gap: 0;
    flex-wrap: wrap;
  }

  .bj-newsletter__input {
    flex: 1;
    min-width: 0;
    min-height: 48px;
    padding: 12px 14px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-right: none;
    font-family: var(--font-body);
    font-size: 14px;
    color: #fff;
    border-radius: var(--radius-sm, 6px) 0 0 var(--radius-sm, 6px);
    outline: none;
    transition: border-color 0.15s, background 0.15s;
  }

  .bj-newsletter__input::placeholder {
    color: rgba(255, 255, 255, 0.35);
  }

  .bj-newsletter__input:focus {
    background: rgba(255, 255, 255, 0.12);
    border-color: var(--gold, #D4A843);
  }

  @media (min-width: 768px) {
    .bj-newsletter__input {
      min-width: 220px;
    }
  }

  .bj-newsletter__button {
    min-height: 48px;
    padding: 12px 20px;
    background: var(--gold, #D4A843);
    color: var(--navy, #1B2A4A);
    border: 1px solid var(--gold, #D4A843);
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 13px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    cursor: pointer;
    border-radius: 0 var(--radius-sm, 6px) var(--radius-sm, 6px) 0;
    transition: background 0.15s, border-color 0.15s;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .bj-newsletter__button:hover:not(:disabled) {
    background: var(--gold-light, #E1BC6A);
    border-color: var(--gold-light, #E1BC6A);
  }

  .bj-newsletter__button:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .bj-newsletter__status {
    font-family: var(--font-body);
    font-size: 13px;
    line-height: 1.4;
    min-height: 0;
    color: rgba(255, 255, 255, 0.65);
  }

  .bj-newsletter__status:empty {
    display: none;
  }

  .bj-newsletter__status[data-tone='error'] {
    color: var(--gold-light, #E1BC6A);
  }

  .bj-newsletter__status[data-tone='muted'] {
    color: rgba(255, 255, 255, 0.55);
  }

  .bj-newsletter__success {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--gold, #D4A843);
    margin: 0;
    font-weight: 600;
  }

  .bj-newsletter__microcopy {
    margin-top: 4px;
    font-size: 11px;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.35);
  }

  .bj-newsletter__microcopy a {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .bj-newsletter__microcopy a:hover {
    color: rgba(255, 255, 255, 0.6);
  }
</style>
