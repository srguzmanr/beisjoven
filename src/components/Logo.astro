---
type Format = 'lockup' | 'mark';

interface Props {
  format?: Format;
  height?: number;
  width?: number;
  alt?: string;
  class?: string;
}

const {
  format = 'lockup',
  height = 40,
  width,
  alt = 'Beisjoven',
  class: className = '',
} = Astro.props;

const src = format === 'mark' ? '/brand/logo-mark.png' : '/brand/logo-lockup.png';
---

<img src={src} alt={alt} height={height} width={width} class={className} />
