---
interface Props {
  title: string;
  href?: string;
  linkText?: string;
}

const { title, href, linkText = 'Ver más' } = Astro.props;
---

<div class="flex items-center justify-between mb-4 border-b-2 border-navy pb-2">
  <h2 class="text-lg md:text-xl font-bold uppercase tracking-wide text-navy">{title}</h2>
  {href && (
    <a href={href} class="text-sm font-semibold text-steel-blue hover:text-navy transition-colors">
      {linkText} &rarr;
    </a>
  )}
</div>
