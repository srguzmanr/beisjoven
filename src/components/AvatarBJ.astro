---
interface Props {
  size?: number;
  title?: string;
}
const { size = 20, title = 'Beisjoven' } = Astro.props;
---

<img
  src="/brand/logo-mark.png"
  alt={title}
  role="img"
  aria-label={title}
  width={size}
  height={size}
  style={`width: ${size}px; height: ${size}px; border-radius: 50%; object-fit: cover; flex-shrink: 0;`}
/>
